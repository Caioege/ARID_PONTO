@using AriD.BibliotecaDeClasses.Entidades
@using AriD.BibliotecaDeClasses.Enumeradores
@using AriD.Servicos.Extensao
@model List<ManutencaoVeiculo>

<div class="maintenance-list-grid">
    @if (Model == null || !Model.Any())
    {
        <div class="maintenance-empty">Nenhum registro de manutenção encontrado.</div>
    }
    else
    {
        foreach (var item in Model)
        {
            var situacao = item.Situacao.DescricaoDoEnumerador();
            var valor = item.ValorTotalGasto ?? item.CustoPrevisto;
            <div class="maintenance-list-card">
                <div class="d-flex justify-content-between align-items-start gap-2">
                    <div>
                        <strong>@item.Descricao</strong>
                        <span>@(item.Categoria ?? "Manutenção") · @situacao</span>
                    </div>
                    <div class="d-flex gap-1">
                        <button type="button" class="btn btn-sm btn-icon btn-outline-secondary" onclick="abrirModalManutencao(@item.Id)" title="Editar">
                            <i class='bx bx-edit-alt'></i>
                        </button>
                        <button type="button" class="btn btn-sm btn-icon btn-outline-danger" onclick="removerManutencao(@item.Id)" title="Remover">
                            <i class='bx bx-trash'></i>
                        </button>
                    </div>
                </div>
                <div class="maintenance-list-meta">
                    <span><i class="bx bx-calendar"></i> @item.DataManutencao.ToString("dd/MM/yyyy")</span>
                    <span><i class="bx bx-tachometer"></i> @item.KmNaManutencao.ToString("N0") km</span>
                    <span><i class="bx bx-map"></i> @(item.LocalExecucaoServico ?? item.Fornecedor ?? "Local não informado")</span>
                    <span><i class="bx bx-money"></i> @(valor.HasValue ? valor.Value.ToString("C") : "Sem valor")</span>
                    <span><i class="bx bx-calendar-exclamation"></i> Próx.: @(item.DataVencimentoManutencao?.ToString("dd/MM/yyyy") ?? "-") / @(item.KmProximaManutencao?.ToString("N0") ?? "-") km</span>
                </div>
            </div>
        }
    }
</div>

<style>
    .maintenance-list-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 12px;
    }

    .maintenance-list-card,
    .maintenance-empty {
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        background: #fff;
        padding: 12px;
    }

    .maintenance-empty {
        color: #64748b;
        text-align: center;
        grid-column: 1 / -1;
    }

    .maintenance-list-card strong,
    .maintenance-list-card span {
        display: block;
    }

    .maintenance-list-card strong {
        color: #1f2937;
        font-weight: 800;
    }

    .maintenance-list-card span {
        color: #64748b;
        font-size: .84rem;
    }

    .maintenance-list-meta {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 6px 10px;
        margin-top: 10px;
    }

    .maintenance-list-meta span {
        min-width: 0;
        overflow-wrap: anywhere;
    }
</style>
