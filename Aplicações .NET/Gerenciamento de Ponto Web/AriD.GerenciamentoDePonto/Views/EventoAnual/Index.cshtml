@model ListaPaginada<EventoAnual>

<div class="card mb-6">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="bx bxs-calendar-event"></i> Listagem de Eventos Anuais
        </h5>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-5 col-sm-6 col-xs-12">
                <div class="input-group">
                    @Html.TextBox("TermoDeBusca", Model.TermoDeBusca, new { @class = "form-control", @placeholder = "Digite para buscar", @style = "background: white" })
                    <button class="btn btn-primary" type="button" onclick="carregarTabelaPaginadaComPesquisa('@Url.Action("TabelaPaginada")')">
                        <i class='bx bx-search-alt'></i> Pesquisar
                    </button>
                </div>
            </div>

            @{
                var podeAdicionar = Context.PossuiPermissao(eItemDePermissao_EventoAnual.CadastrarOuAlterar);
                var podeExportar = Context.PossuiPermissao(eItemDePermissao_EventoAnual.Exportar);
            }
            <div class="col-md-7 col-sm-6 col-xs-12">
                @if (podeAdicionar)
                {
                    <button type="button" onclick="AbrirModal(0)" class="btn btn-primary float-end">
                        <i class="bx bx-plus"></i> Adicionar
                    </button>
                }

                @if (podeExportar)
                {
                    <button type="button" onclick="exportarListagem(0)" class="btn btn-secondary float-end" style="margin-right: 5px;">
                        <i class="bx bx-download"></i> Exportar
                    </button>
                }
            </div>
        </div>
        <br />

        <div id="grid">
            @await Html.PartialAsync("_TabelaPaginada")
        </div>

        <div id="div-modal"></div>
    </div>
</div>

<script src="/Scripts/Paginas/EventoAnual/index.js?t=@DateTime.Now.Ticks"></script>