@model ListaPaginada<Organizacao>

<button type="button" onclick="CarregarPagina('@Url.Action("Adicionar")')" class="btn btn-primary">
    <i class="bx bx-plus"></i> Adicionar
</button>
<br />
<br />

<div id="grid">
    @await Html.PartialAsync("_TabelaPaginada")
</div>

<script>
    function autenticarEmOutraOrganizacao(id) {
        RequisicaoAjaxComCarregamento(
            '/Organizacao/AutenticarOrganizacao',
            'POST',
            { id },
            function (data) {
                if (data.sucesso) {
                    location.reload(true);
                } else {
                    MensagemRodape('warning', data.mensagem);
                }
            });
    }
</script>