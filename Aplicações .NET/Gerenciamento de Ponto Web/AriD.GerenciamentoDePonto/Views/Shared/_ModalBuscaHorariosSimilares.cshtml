<div class="modal fade" id="modalBuscaHorariosSimilares" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Busca de Horários Similares</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <!-- State 1: Thinking -->
                <div id="buscaHorarioPensando" style="display:none; padding: 40px 0;">
                    <div class="spinner-border text-primary" role="status" style="width: 4rem; height: 4rem;">
                        <span class="visually-hidden">Pensando...</span>
                    </div>
                    <h4 class="mt-4" id="buscaHorarioTextoAnimado">Verificando as jornadas ativas...</h4>
                </div>

                <!-- State 2: Results -->
                <div id="buscaHorarioResultados" style="display:none;">
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover mt-3">
                            <thead>
                                <tr>
                                    <th>Sigla/Descrição</th>
                                    <th>Carga Horária</th>
                                    <th>Diferença</th>
                                    <th>Ação</th>
                                </tr>
                            </thead>
                            <tbody id="buscaHorarioTabelaBody">
                                <!-- Preenchido via JS -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- State 3: Error / Empty -->
                <div id="buscaHorarioErro" style="display:none; padding: 40px 0;">
                    <i class="bx bx-error-circle text-danger" style="font-size: 4rem;"></i>
                    <h5 class="mt-3" id="buscaHorarioTextoErro">Nenhum horário similar encontrado.</h5>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>
            </div>
        </div>
    </div>
</div>

<script>
    function selecionarHorarioSimilar(id) {
        if ($('#HorarioDeTrabalhoId').length > 0) {
            $('#HorarioDeTrabalhoId').val(id).trigger('change');
            var modalEl = document.getElementById('modalBuscaHorariosSimilares');
            var modal = bootstrap.Modal.getInstance(modalEl);
            if(modal) modal.hide();
            
            if (typeof MensagemRodape !== 'undefined') {
                MensagemRodape('success', 'Horário selecionado com sucesso!');
            }
        }
    }

    function buscarHorariosSimilares(horarioOrigemId) {
        if (!horarioOrigemId || horarioOrigemId == '0' || horarioOrigemId === '') {
            if (typeof Swal !== 'undefined') {
                Swal.fire('Atenção', 'Selecione um Horário de Trabalho origem para buscar similares.', 'warning');
            } else {
                alert("Selecione um Horário de Trabalho origem para buscar similares.");
            }
            return;
        }

        $('#buscaHorarioPensando').show();
        $('#buscaHorarioResultados').hide();
        $('#buscaHorarioErro').hide();
        $('#buscaHorarioTabelaBody').empty();

        var modalEl = document.getElementById('modalBuscaHorariosSimilares');
        var modal = bootstrap.Modal.getInstance(modalEl);
        if(!modal) { modal = new bootstrap.Modal(modalEl); }
        modal.show();

        // Animação de textos
        var textos = [
            "Analisando cargas horárias...",
            "Comparando os totais de horas...",
            "Identificando modalidades de jornadas idênticas...",
            "Filtrando os horários mais parecidos com o atual..."
        ];
        var txtIndex = 0;
        $('#buscaHorarioTextoAnimado').text(textos[0]);
        var intervalTextos = setInterval(function () {
            txtIndex++;
            if (txtIndex >= textos.length) txtIndex = 0;
            $('#buscaHorarioTextoAnimado').text(textos[txtIndex]);
        }, 1200);

        // Simulando delay de busca para mostrar a animação (UX de inteliência)
        setTimeout(function() {
            $.ajax({
                url: '/HorarioDeTrabalho/BuscarHorariosSimilares/' + horarioOrigemId,
                type: 'GET',
                success: function (res) {
                    clearInterval(intervalTextos);

                    if (res.erro) {
                        $('#buscaHorarioPensando').hide();
                        $('#buscaHorarioTextoErro').text(res.mensagem || "Erro na busca.");
                        $('#buscaHorarioErro').show();
                    } else if (res.dados && res.dados.length > 0) {
                        $('#buscaHorarioPensando').hide();
                        
                        var html = '';
                        var hasSelect = $('#HorarioDeTrabalhoId').length > 0;

                        $.each(res.dados, function(i, h) {
                            var id = h.Id || h.id;
                            var diffVal = h.Diferenca !== undefined ? h.Diferenca : h.diferenca;
                            var desc = h.Descricao || h.descricao;
                            var carga = h.CargaHoraria || h.cargaHoraria;

                            var diff = diffVal === 0 ? "Exata" : diffVal + " min";
                            
                            var selectBtn = '';
                            if (hasSelect) {
                                selectBtn = '<button type="button" class="btn btn-sm btn-success me-1" onclick="selecionarHorarioSimilar(' + id + ')" title="Usar este horário"><i class="bx bx-check"></i> Selecionar</button>';
                            }

                            html += '<tr>' +
                                    '<td class="text-start">' + desc + '</td>' +
                                    '<td class="text-center">' + carga + '</td>' +
                                    '<td class="text-center text-muted"><small>' + diff + '</small></td>' +
                                    '<td class="text-center">' +
                                        selectBtn +
                                        '<a href="/HorarioDeTrabalho/Alterar/' + id + '" target="_blank" class="btn btn-sm btn-info" title="Visualizar detalhes da jornada"><i class="bx bx-window-open"></i> Ver</a>' +
                                    '</td>' +
                                '</tr>';
                        });

                        $('#buscaHorarioTabelaBody').html(html);
                        $('#buscaHorarioResultados').show();
                    } else {
                        $('#buscaHorarioPensando').hide();
                        $('#buscaHorarioTextoErro').text("Nenhum horário similar encontrado nesta mesma modalidade de carga horária.");
                        $('#buscaHorarioErro').show();
                    }
                },
                error: function () {
                    clearInterval(intervalTextos);
                    $('#buscaHorarioPensando').hide();
                    $('#buscaHorarioTextoErro').text("Erro de comunicação com o servidor.");
                    $('#buscaHorarioErro').show();
                }
            });
        }, 4000); // 4s de "pensando" para exibição da UI
    }
</script>
