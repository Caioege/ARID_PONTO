@{
    ViewBag.Title = "Monitoramento - Gestão Mobile";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

<style>
    .monitor-dashboard {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        min-height: calc(100vh - 155px);
    }

    .monitor-topbar,
    .monitor-kpis,
    .monitor-quick-filters,
    .monitor-shell,
    .monitor-alerts-panel,
    .monitor-routes-list {
        transition: opacity .2s ease, max-height .2s ease, margin .2s ease, padding .2s ease;
    }

    .monitor-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    .monitor-title h4 {
        margin: 0;
        font-weight: 700;
        color: #1f2937;
    }

    .monitor-title span {
        display: block;
        margin-top: .15rem;
        color: #6b7280;
        font-size: .875rem;
    }

    .monitor-actions {
        display: flex;
        align-items: center;
        gap: .5rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .monitor-actions .monitor-date-filter {
        min-width: 150px;
    }

    .monitor-actions .monitor-finalizadas-filter {
        align-items: center;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        display: inline-flex;
        gap: .45rem;
        min-height: 31px;
        padding: .25rem .65rem;
        white-space: nowrap;
    }

    .monitor-actions .monitor-finalizadas-filter label {
        color: #374151;
        font-size: .82rem;
        font-weight: 600;
        margin: 0;
    }

    .monitor-kpis {
        display: grid;
        grid-template-columns: repeat(7, minmax(140px, 1fr));
        gap: .75rem;
    }

    .monitor-quick-filters {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        box-shadow: 0 1px 2px rgba(15, 23, 42, .04);
        display: flex;
        flex-wrap: wrap;
        gap: .5rem;
        padding: .7rem;
    }

    .monitor-filter-chip {
        align-items: center;
        border: 1px solid #dbe3ef;
        border-radius: 999px;
        background: #fff;
        color: #334155;
        cursor: pointer;
        display: inline-flex;
        font-size: .78rem;
        font-weight: 800;
        gap: .35rem;
        min-height: 32px;
        padding: .35rem .75rem;
        transition: background-color .15s ease, border-color .15s ease, color .15s ease;
    }

    .monitor-filter-chip.active {
        background: #1d4ed8;
        border-color: #1d4ed8;
        color: #fff;
    }

    .monitor-kpi {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: .85rem;
        min-height: 86px;
        display: flex;
        justify-content: space-between;
        gap: .75rem;
        box-shadow: 0 1px 2px rgba(15, 23, 42, .04);
    }

    .monitor-kpi small {
        display: block;
        color: #6b7280;
        font-weight: 600;
        line-height: 1.2;
    }

    .monitor-kpi strong {
        display: block;
        margin-top: .35rem;
        color: #111827;
        font-size: 1.55rem;
        line-height: 1;
    }

    .monitor-kpi i {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
    }

    .monitor-kpi.success i { color: #047857; background: #d1fae5; }
    .monitor-kpi.danger i { color: #b91c1c; background: #fee2e2; }
    .monitor-kpi.warning i { color: #b45309; background: #fef3c7; }
    .monitor-kpi.primary i { color: #1d4ed8; background: #dbeafe; }
    .monitor-kpi.muted i { color: #475569; background: #e2e8f0; }

    .monitor-shell {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 360px;
        gap: 1rem;
        min-height: 560px;
        flex: 1;
    }

    .monitor-map-panel,
    .monitor-side-panel,
    .monitor-alerts-panel,
    .monitor-routes-list {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        box-shadow: 0 1px 2px rgba(15, 23, 42, .04);
    }

    .monitor-map-panel {
        position: relative;
        overflow: hidden;
        min-height: 560px;
    }

    #map {
        width: 100%;
        height: 100%;
        min-height: 560px;
        z-index: 1;
    }

    .map-toolbar {
        position: absolute;
        left: 1rem;
        top: 1rem;
        right: 1rem;
        z-index: 900;
        display: flex;
        align-items: flex-start;
        justify-content: flex-end;
        gap: .75rem;
        pointer-events: none;
    }

    .map-toolbar > * {
        pointer-events: auto;
    }

    .status-indicador,
    .offline-alerta-indicador {
        position: absolute;
        left: 1rem;
        z-index: 900;
        background: rgba(255, 255, 255, .96);
        border: 1px solid #e5e7eb;
        border-radius: 999px;
        box-shadow: 0 6px 18px rgba(15, 23, 42, .12);
        padding: .5rem .75rem;
        font-size: .82rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: .45rem;
    }

    .status-indicador {
        bottom: 1rem;
        color: #166534;
    }

    .offline-alerta-indicador {
        bottom: 3.9rem;
        color: #92400e;
        display: none;
    }

    .pulse,
    .offline-alerta-pulse {
        width: 9px;
        height: 9px;
        border-radius: 50%;
    }

    .pulse {
        background: #22c55e;
        animation: pulse-animation 2s infinite;
    }

    .offline-alerta-pulse {
        background: #f59e0b;
        animation: offline-alerta-pulse 1.6s infinite;
    }

    @@keyframes pulse-animation {
        0% { transform: scale(.95); box-shadow: 0 0 0 0 rgba(34, 197, 94, .7); }
        70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(34, 197, 94, 0); }
        100% { transform: scale(.95); box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); }
    }

    @@keyframes offline-alerta-pulse {
        0% { transform: scale(.95); box-shadow: 0 0 0 0 rgba(245, 158, 11, .7); }
        70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(245, 158, 11, 0); }
        100% { transform: scale(.95); box-shadow: 0 0 0 0 rgba(245, 158, 11, 0); }
    }

    .animated-route {
        stroke-dasharray: 10, 15;
        animation: route-dash 20s linear infinite;
    }

    .offline-route,
    .possivelmente-offline-route {
        stroke-dasharray: 8, 8;
    }

    @@keyframes route-dash {
        to { stroke-dashoffset: -1000; }
    }

    .monitor-side-panel {
        min-height: 560px;
        max-height: 640px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .side-section {
        padding: 1rem;
        border-bottom: 1px solid #eef2f7;
    }

    .side-section:last-child {
        border-bottom: 0;
    }

    .side-scroll {
        overflow-y: auto;
        min-height: 0;
        flex: 1;
    }

    .route-heading {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: .75rem;
    }

    .route-heading h5 {
        margin: 0;
        font-size: 1rem;
        font-weight: 800;
        color: #111827;
    }

    .route-heading-actions {
        display: flex;
        align-items: flex-start;
        gap: .4rem;
    }

    .status-chip {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        border-radius: 999px;
        padding: .2rem .5rem;
        font-size: .72rem;
        font-weight: 800;
        white-space: nowrap;
    }

    .status-chip.em-rota { background: #dcfce7; color: #166534; }
    .status-chip.em-almoco { background: #fef3c7; color: #92400e; }
    .status-chip.em-ocorrencia { background: #fee2e2; color: #991b1b; }
    .status-chip.finalizada { background: #e2e8f0; color: #334155; }

    .driver-role-badge {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: .16rem .45rem;
        font-size: .66rem;
        font-weight: 800;
        line-height: 1;
        white-space: nowrap;
        vertical-align: middle;
        margin-left: .35rem;
        text-transform: uppercase;
    }

    .driver-role-badge.principal {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .driver-role-badge.secundario {
        background: #fef3c7;
        color: #92400e;
    }

    .driver-role-badge.motorista {
        background: #e2e8f0;
        color: #475569;
    }

    .detail-grid {
        display: grid;
        gap: .55rem;
        margin-top: .8rem;
    }

    .detail-item span {
        display: block;
        color: #64748b;
        font-size: .72rem;
        font-weight: 800;
        text-transform: uppercase;
    }

    .detail-item strong {
        display: block;
        color: #111827;
        font-size: .88rem;
        line-height: 1.25;
        word-break: break-word;
    }

    .side-actions {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: .5rem;
        margin-top: .85rem;
    }

    #btn-comparar-rota {
        grid-column: 1 / -1;
    }

    .alert-list,
    .event-list,
    .stop-list {
        display: grid;
        gap: .5rem;
    }

    .alert-item {
        border-radius: 8px;
        border: 1px solid #e5e7eb;
        padding: .65rem;
        background: #f8fafc;
        cursor: pointer;
        transition: border-color .15s ease, box-shadow .15s ease, transform .15s ease;
    }

    .alert-item:hover {
        border-color: #93c5fd;
        box-shadow: 0 6px 14px rgba(15, 23, 42, .08);
        transform: translateY(-1px);
    }

    .alert-item.critico,
    .alert-item.alto {
        border-color: #fecaca;
        background: #fff1f2;
    }

    .alert-item.medio {
        border-color: #fde68a;
        background: #fffbeb;
    }

    .alert-item.baixo {
        border-color: #dbeafe;
        background: #eff6ff;
    }

    .alert-item strong,
    .event-item strong,
    .stop-item strong {
        display: block;
        color: #111827;
        font-size: .82rem;
    }

    .alert-item span,
    .event-item span,
    .stop-item span {
        display: block;
        margin-top: .15rem;
        color: #64748b;
        font-size: .75rem;
        line-height: 1.25;
    }

    .event-item,
    .stop-item,
    .timeline-item {
        border-left: 3px solid #dbeafe;
        padding: .2rem 0 .2rem .55rem;
    }

    .timeline-list {
        display: flex;
        flex-direction: column;
        gap: .7rem;
        position: relative;
        padding-left: .35rem;
    }

    .timeline-item {
        border-left: 0;
        display: grid;
        gap: .1rem;
        grid-template-columns: 26px minmax(0, 1fr) auto;
        padding: 0;
        position: relative;
    }

    .timeline-item:before {
        background: #cbd5e1;
        bottom: -.7rem;
        content: "";
        left: 12px;
        position: absolute;
        top: 25px;
        width: 2px;
    }

    .timeline-item:last-child:before {
        display: none;
    }

    .timeline-dot {
        align-items: center;
        background: #dbeafe;
        border: 2px solid #fff;
        border-radius: 999px;
        box-shadow: 0 0 0 1px #bfdbfe;
        color: #1d4ed8;
        display: flex;
        height: 24px;
        justify-content: center;
        margin-top: 1px;
        width: 24px;
        z-index: 1;
    }

    .timeline-dot.critico,
    .timeline-dot.alto,
    .timeline-dot.evento {
        background: #fee2e2;
        box-shadow: 0 0 0 1px #fecaca;
        color: #b91c1c;
    }

    .timeline-dot.parada {
        background: #dcfce7;
        box-shadow: 0 0 0 1px #bbf7d0;
        color: #166534;
    }

    .timeline-dot.parada-realizada {
        background: #dcfce7;
        box-shadow: 0 0 0 1px #86efac;
        color: #15803d;
    }

    .timeline-dot.parada-nao-realizada {
        background: #fee2e2;
        box-shadow: 0 0 0 1px #fecaca;
        color: #b91c1c;
    }

    .timeline-content strong {
        display: block;
        color: #111827;
        font-size: .82rem;
    }

    .timeline-content span {
        display: block;
        margin-top: .15rem;
        color: #64748b;
        font-size: .75rem;
        line-height: 1.25;
    }

    .timeline-pin-btn {
        align-self: start;
        border-radius: 999px;
        height: 28px;
        line-height: 1;
        padding: 0;
        width: 28px;
    }

    .event-item-clickable {
        cursor: pointer;
        border-left-color: #ef4444;
        border-radius: 4px;
        transition: background-color .15s ease, transform .15s ease;
    }

    .event-item-clickable:hover {
        background: #f8fafc;
        transform: translateX(2px);
    }

    .route-event-pin {
        background: transparent;
        border: 0;
    }

    .route-event-pin-inner {
        align-items: center;
        background: #ef4444;
        border: 2px solid #fff;
        border-radius: 999px;
        box-shadow: 0 8px 18px rgba(15, 23, 42, .35);
        color: #fff;
        display: flex;
        font-size: 22px;
        height: 34px;
        justify-content: center;
        width: 34px;
    }

    .monitor-alerts-panel {
        overflow: hidden;
    }

    .alerts-card-list,
    .maintenance-card-list {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: .75rem;
        padding: .85rem;
    }

    .alert-route-card,
    .maintenance-card {
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: .75rem;
        background: #fff;
        cursor: pointer;
        transition: border-color .15s ease, box-shadow .15s ease;
        min-width: 0;
    }

    .alert-route-card:hover,
    .maintenance-card:hover {
        border-color: #93c5fd;
        box-shadow: 0 6px 14px rgba(15, 23, 42, .08);
    }

    .alert-route-card.critico,
    .alert-route-card.alto,
    .maintenance-card.vencida {
        border-color: #fecaca;
        background: #fff1f2;
    }

    .alert-route-card.medio,
    .maintenance-card.proxima {
        border-color: #fde68a;
        background: #fffbeb;
    }

    .alert-route-card.baixo {
        border-color: #dbeafe;
        background: #eff6ff;
    }

    .alert-route-card strong,
    .maintenance-card strong {
        display: block;
        color: #111827;
        font-size: .86rem;
        line-height: 1.25;
    }

    .alert-route-card span,
    .maintenance-card span {
        display: block;
        margin-top: .25rem;
        color: #64748b;
        font-size: .76rem;
        line-height: 1.3;
    }

    .maintenance-modal-preview {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: .65rem;
        margin-bottom: 1rem;
    }

    .maintenance-route-list {
        display: grid;
        gap: .6rem;
    }

    .maintenance-route-item {
        align-items: center;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        display: flex;
        gap: .75rem;
        justify-content: space-between;
        padding: .75rem;
    }

    .maintenance-route-item strong,
    .maintenance-route-item span {
        display: block;
    }

    .maintenance-route-item span {
        color: #64748b;
        font-size: .78rem;
        margin-top: .15rem;
    }

    .route-chat-messages {
        height: 420px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: .55rem;
        padding: .75rem;
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
    }

    .route-chat-message {
        max-width: 78%;
        border-radius: 8px;
        padding: .55rem .65rem;
        border: 1px solid #e5e7eb;
        background: #fff;
    }

    .route-chat-message.sistema {
        align-self: flex-end;
        background: #dbeafe;
        border-color: #bfdbfe;
    }

    .route-chat-message.aplicativo {
        align-self: flex-start;
        background: #fff;
    }

    .route-chat-message strong {
        display: block;
        color: #111827;
        font-size: .78rem;
    }

    .route-chat-message span {
        display: block;
        color: #111827;
        font-size: .88rem;
        line-height: 1.35;
        white-space: pre-wrap;
        word-break: break-word;
    }

    .route-chat-message small {
        display: block;
        color: #64748b;
        font-size: .7rem;
        margin-top: .25rem;
        text-align: right;
    }

    .monitor-routes-list {
        overflow: hidden;
    }

    .routes-list-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .85rem 1rem;
        border-bottom: 1px solid #eef2f7;
    }

    .routes-list-header h6 {
        margin: 0;
        font-weight: 800;
    }

    .routes-card-list {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
        gap: .75rem;
        padding: .85rem;
        max-height: 330px;
        overflow-y: auto;
    }

    .route-summary-card {
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: .75rem;
        cursor: pointer;
        background: #fff;
        transition: border-color .15s ease, box-shadow .15s ease;
        min-width: 0;
    }

    .route-summary-card:hover,
    .route-summary-card.active {
        border-color: #93c5fd;
        box-shadow: 0 6px 14px rgba(15, 23, 42, .08);
    }

    .route-summary-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: .65rem;
    }

    .route-summary-head strong {
        color: #111827;
        display: block;
        font-size: .9rem;
        line-height: 1.25;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .route-summary-meta,
    .route-summary-people {
        margin-top: .55rem;
        color: #64748b;
        font-size: .78rem;
        line-height: 1.35;
    }

    .route-summary-people {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .route-summary-footer {
        margin-top: .65rem;
        display: flex;
        justify-content: space-between;
        gap: .5rem;
        align-items: center;
        color: #64748b;
        font-size: .76rem;
    }

    .empty-state {
        color: #64748b;
        font-size: .86rem;
        padding: 1rem;
        text-align: center;
    }

    .monitor-dashboard.mapa-em-foco {
        min-height: calc(100vh - 90px);
    }

    .monitor-dashboard.mapa-em-foco .monitor-topbar,
    .monitor-dashboard.mapa-em-foco .monitor-kpis,
    .monitor-dashboard.mapa-em-foco .monitor-quick-filters,
    .monitor-dashboard.mapa-em-foco .monitor-side-panel,
    .monitor-dashboard.mapa-em-foco .monitor-alerts-panel,
    .monitor-dashboard.mapa-em-foco .monitor-routes-list {
        opacity: 0;
        max-height: 0;
        margin: 0;
        padding: 0;
        overflow: hidden;
        border: 0;
        pointer-events: none;
    }

    .monitor-dashboard.mapa-em-foco .monitor-shell {
        display: block;
        min-height: calc(100vh - 110px);
    }

    .monitor-dashboard.mapa-em-foco .monitor-map-panel,
    .monitor-dashboard.mapa-em-foco #map {
        min-height: calc(100vh - 110px);
    }

    @@media (max-width: 1200px) {
        .monitor-kpis {
            grid-template-columns: repeat(3, minmax(150px, 1fr));
        }

        .monitor-shell {
            grid-template-columns: minmax(0, 1fr);
        }

        .monitor-side-panel {
            max-height: none;
        }
    }

    @@media (max-width: 768px) {
        .monitor-topbar {
            align-items: flex-start;
            flex-direction: column;
        }

        .monitor-actions {
            justify-content: flex-start;
        }

        .monitor-kpis {
            grid-template-columns: repeat(2, minmax(140px, 1fr));
        }

        .map-toolbar {
            flex-direction: column;
        }
    }
</style>

<div class="monitor-dashboard" id="monitor-dashboard">
    <div class="monitor-topbar">
        <div class="monitor-title">
            <h4>Gestão Mobile - Rotas em Tempo Real</h4>
            <span>Monitoramento operacional dos veículos, alertas e execuções em andamento.</span>
        </div>
        <div class="monitor-actions">
            <input type="date" id="M_FiltroData" class="form-control form-control-sm monitor-date-filter" value="@DateTime.Now.ToString("yyyy-MM-dd")" onchange="obterDadosMonitoramento()" />
            <div class="form-check form-switch monitor-finalizadas-filter">
                <input class="form-check-input" type="checkbox" id="M_FiltroFinalizadas" onchange="aplicarFiltrosMap()">
                <label class="form-check-label" for="M_FiltroFinalizadas">Exibir finalizadas</label>
            </div>
            <button type="button" class="btn btn-primary btn-sm" onclick="obterDadosMonitoramento()">
                <i class="bx bx-refresh"></i> Atualizar
            </button>
        </div>
    </div>

    <div class="monitor-kpis">
        <div class="monitor-kpi success">
            <div><small>Veículos em rota</small><strong id="kpi-em-rota">0</strong></div>
            <i class="bx bxs-car"></i>
        </div>
        <div class="monitor-kpi danger">
            <div><small>Ocorrências</small><strong id="kpi-ocorrencias">0</strong></div>
            <i class="bx bx-error-circle"></i>
        </div>
        <div class="monitor-kpi warning">
            <div><small>Manutenções próximas</small><strong id="kpi-manutencoes">0</strong></div>
            <i class="bx bx-wrench"></i>
        </div>
        <div class="monitor-kpi primary">
            <div><small>Rotas finalizadas</small><strong id="kpi-finalizadas">0</strong></div>
            <i class="bx bx-check-double"></i>
        </div>
        <div class="monitor-kpi muted">
            <div><small>Sem sinal GPS</small><strong id="kpi-offline">0</strong></div>
            <i class="bx bx-wifi-off"></i>
        </div>
        <div class="monitor-kpi primary">
            <div><small>Mensagens não lidas</small><strong id="kpi-chat-nao-lidas">0</strong></div>
            <i class="bx bx-message-square-dots"></i>
        </div>
        <div class="monitor-kpi warning">
            <div><small>Atraso operacional</small><strong id="kpi-atrasadas">0</strong></div>
            <i class="bx bx-time-five"></i>
        </div>
    </div>

    <div class="monitor-quick-filters" aria-label="Filtros rápidos de monitoramento">
        <button type="button" class="monitor-filter-chip active" data-monitor-filter="todos" onclick="aplicarFiltroRapidoMonitoramento('todos')">
            <i class="bx bx-layer"></i> Todos
        </button>
        <button type="button" class="monitor-filter-chip" data-monitor-filter="em-rota" onclick="aplicarFiltroRapidoMonitoramento('em-rota')">
            <i class="bx bxs-car"></i> Em rota
        </button>
        <button type="button" class="monitor-filter-chip" data-monitor-filter="ocorrencia" onclick="aplicarFiltroRapidoMonitoramento('ocorrencia')">
            <i class="bx bx-error-circle"></i> Em ocorrência
        </button>
        <button type="button" class="monitor-filter-chip" data-monitor-filter="sem-sinal" onclick="aplicarFiltroRapidoMonitoramento('sem-sinal')">
            <i class="bx bx-wifi-off"></i> Sem sinal
        </button>
        <button type="button" class="monitor-filter-chip" data-monitor-filter="com-mensagem" onclick="aplicarFiltroRapidoMonitoramento('com-mensagem')">
            <i class="bx bx-message-rounded-dots"></i> Com mensagem
        </button>
        <button type="button" class="monitor-filter-chip" data-monitor-filter="finalizadas" onclick="aplicarFiltroRapidoMonitoramento('finalizadas')">
            <i class="bx bx-check-double"></i> Finalizadas
        </button>
        <button type="button" class="monitor-filter-chip" data-monitor-filter="atrasadas" onclick="aplicarFiltroRapidoMonitoramento('atrasadas')">
            <i class="bx bx-time-five"></i> Atrasadas
        </button>
    </div>

    <div class="monitor-shell">
        <div class="monitor-map-panel">
            <div id="map"></div>

            <div class="map-toolbar">
                <button type="button" class="btn btn-light btn-sm shadow-sm" id="btn-mapa-foco" onclick="alternarFocoMapa()">
                    <i class="bx bx-fullscreen"></i> Focar mapa
                </button>
            </div>

            <div class="status-indicador">
                <div class="pulse"></div>
                <span id="ultima-sincronizacao">Sincronizando...</span>
            </div>

            <div class="offline-alerta-indicador" id="contador-possivelmente-offline">
                <div class="offline-alerta-pulse"></div>
                <span id="contador-possivelmente-offline-texto">0 rotas possivelmente offline</span>
            </div>
        </div>

        <aside class="monitor-side-panel">
            <div class="side-section">
                <div class="route-heading">
                    <div>
                        <h5 id="side-rota-titulo">Nenhuma rota selecionada</h5>
                        <small class="text-muted" id="side-rota-subtitulo">Clique em um veículo no mapa ou selecione uma rota na lista.</small>
                    </div>
                    <div class="route-heading-actions">
                        <span class="status-chip em-rota" id="side-rota-status">Aguardando</span>
                        <button type="button" class="btn btn-sm btn-icon btn-outline-secondary" id="btn-limpar-foco-rota" onclick="limparFocoRota()" disabled title="Remover foco da rota">
                            <i class="bx bx-x"></i>
                        </button>
                    </div>
                </div>
                <div class="side-actions">
                    <button type="button" class="btn btn-outline-primary btn-sm" id="btn-chat-rota" onclick="abrirChatRota()" disabled>
                        <i class="bx bx-message-rounded-dots"></i> Chat
                        <span class="badge bg-danger ms-1 d-none" id="badge-chat-rota">0</span>
                    </button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-centralizar-rota" onclick="centralizarRotaSelecionada()" disabled>
                        <i class="bx bx-current-location"></i> Centralizar
                    </button>
                    <button type="button" class="btn btn-outline-info btn-sm" id="btn-comparar-rota" onclick="alternarComparativoRota()" disabled>
                        <i class="bx bx-git-compare"></i> Prevista x executada
                    </button>
                    <button type="button" class="btn btn-outline-dark btn-sm" id="btn-checklist-rota" onclick="abrirChecklistExecucaoRota()" disabled>
                        <i class="bx bx-list-check"></i> Checklist
                    </button>
                </div>
            </div>

            <div class="side-scroll">
                <div class="side-section">
                    <div class="detail-grid" id="side-detalhes-rota"></div>
                </div>

                <div class="side-section">
                    <h6 class="fw-bold mb-2">Linha do tempo</h6>
                    <div class="timeline-list" id="side-timeline">
                        <div class="empty-state">Nenhuma rota selecionada.</div>
                    </div>
                </div>

                <div class="side-section">
                    <h6 class="fw-bold mb-2">Paradas</h6>
                    <div class="stop-list" id="side-paradas">
                        <div class="empty-state">Nenhuma parada selecionada.</div>
                    </div>
                </div>
            </div>
        </aside>
    </div>

    <div class="monitor-alerts-panel">
        <div class="routes-list-header">
            <h6>Alertas por rota</h6>
            <small class="text-muted" id="alerts-routes-count">0 alertas</small>
        </div>
        <div class="alerts-card-list" id="alertas-rotas-lista">
            <div class="empty-state">Sem alertas para exibir.</div>
        </div>
    </div>

    <div class="monitor-routes-list">
        <div class="routes-list-header">
            <h6>Rotas em acompanhamento</h6>
            <small class="text-muted" id="routes-list-count">0 rotas</small>
        </div>
        <div class="routes-card-list" id="rotas-monitoramento-lista">
            <div class="empty-state">Carregando rotas...</div>
        </div>
    </div>

    <div class="monitor-alerts-panel">
        <div class="routes-list-header">
            <h6>Manutenções próximas ou vencidas</h6>
            <small class="text-muted" id="maintenance-list-count">0 manutenções</small>
        </div>
        <div class="maintenance-card-list" id="manutencoes-rotas-lista">
            <div class="empty-state">Sem manutenções próximas ou vencidas.</div>
        </div>
    </div>
</div>

<div class="modal fade" id="modal-checklist-execucao" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title mb-0" id="checklist-modal-titulo">Checklist da execução</h5>
                    <small class="text-muted" id="checklist-modal-subtitulo">Preenchido antes do início da rota</small>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div class="modal-body">
                <div id="checklist-modal-conteudo">
                    <div class="empty-state">Carregando checklist...</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modal-manutencao-veiculo" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title mb-0" id="manutencao-modal-titulo">Manutenção do veículo</h5>
                    <small class="text-muted" id="manutencao-modal-veiculo">Veículo não informado</small>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div class="modal-body">
                <div id="manutencao-modal-preview"></div>
                <h6 class="fw-bold mb-2">Rotas vinculadas ao veículo</h6>
                <div class="maintenance-route-list" id="manutencao-modal-rotas">
                    <div class="empty-state">Nenhuma rota vinculada.</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modal-chat-rota" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title mb-0" id="chat-rota-titulo">Chat da rota</h5>
                    <small class="text-muted" id="chat-rota-subtitulo">Somente texto</small>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div class="modal-body">
                <div class="route-chat-messages" id="chat-rota-mensagens">
                    <div class="empty-state">Carregando mensagens...</div>
                </div>
            </div>
            <div class="modal-footer d-block">
                <div class="alert alert-warning py-2 px-3 d-none" id="chat-rota-finalizada">
                    Esta rota foi finalizada. O histórico está disponível apenas para consulta.
                </div>
                <div class="input-group">
                    <textarea class="form-control" id="chat-rota-texto" rows="2" maxlength="1000" placeholder="Digite uma mensagem para o motorista"></textarea>
                    <button type="button" class="btn btn-primary" id="chat-rota-enviar" onclick="enviarMensagemChatRota()">
                        <i class="bx bx-send"></i> Enviar
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    var mapLatCentro = @ViewBag.LatCentro;
    var mapLonCentro = @ViewBag.LonCentro;
    var mapUnidades = @Html.Raw(ViewBag.UnidadesJson ?? "[]");
</script>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script src="~/Scripts/Paginas/Rota/monitoramento.js?v=@(DateTime.Now.Ticks)"></script>
