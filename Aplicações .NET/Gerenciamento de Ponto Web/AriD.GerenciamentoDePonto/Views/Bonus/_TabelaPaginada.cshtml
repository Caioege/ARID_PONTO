@using AriD.BibliotecaDeClasses.Enumeradores
@using AriD.Servicos.Extensao
@model ListaPaginada<ConfiguracaoBonus>

@{
    var tabela = new WebGrid<ConfiguracaoBonus>(Model, "grid", null);

    var listaDeColunas = new List<WebGridColumn>
    {
        tabela.Column("Descricao", "Descrição", width: 40f),
        tabela.Column("TipoBonus", "Tipo", format: (item) => ((eTipoBonus)item.TipoBonus).DescricaoDoEnumerador(), width: 30f),
        tabela.Column("ValorDiario", "Valor", format: (item) => item.ValorDiario.ToString("C"), width: 15f),
        tabela.Column("Ativo", "Status", format: 
            @<text>
                @if (item.Ativo)
                {
                    <span class="badge bg-label-success">Ativo</span>
                }
                else
                {
                    <span class="badge bg-label-secondary">Inativo</span>
                }
            </text>, width: 10f),
        tabela.Column(string.Empty, "Ação", format:
            @<text>
                <div class="btn-group">
                    <button type="button" class="btn btn-primary btn-sm" onclick="CarregarPagina('@Url.Action("Alterar", "Bonus", new { id = item.Id })')" title="Editar">
                        <i class='bx bxs-edit-alt'></i>
                    </button>
                    <button type="button" class="btn btn-warning btn-sm" onclick="abrirModalApuracao(@item.Id, '@item.Descricao')" title="Apurar Mês">
                        <i class='bx bx-calculator'></i>
                    </button>
                </div>
            </text>, width: 15f)
    };
}

@(await tabela.Table(listaDeColunas, string.Empty, Html.PartialAsync("_PaginacaoWebGrid")))
