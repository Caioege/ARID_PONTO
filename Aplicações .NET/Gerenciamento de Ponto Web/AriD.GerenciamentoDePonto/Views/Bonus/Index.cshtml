@using AriD.Servicos.Extensao
@model ListaPaginada<ConfiguracaoBonus>

<div class="card mb-6">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="bx bx-money"></i> Configurações de Bônus (VT/VA)
        </h5>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-5 col-sm-6 col-xs-12">
                <div class="input-group">
                    @Html.TextBox("TermoDeBusca", Model.TermoDeBusca, new { @class = "form-control", @placeholder = "Digite para buscar", @style = "background: white" })
                    <button class="btn btn-primary" type="button" onclick="carregarTabelaPaginadaComPesquisa('@Url.Action("TabelaPaginada")')">
                        <i class='bx bx-search-alt'></i> Pesquisar
                    </button>
                </div>
            </div>

            <div class="col-md-7 col-sm-6 col-xs-12">
                <div class="d-flex justify-content-end gap-2">
                    <button type="button" onclick="CarregarPagina('@Url.Action("Relatorio")')" class="btn btn-outline-secondary">
                        <i class="bx bx-list-ul"></i> Ver Bônus Calculados
                    </button>
                    @if (Context.PossuiPermissao(eItemDePermissao_Bonus.CadastrarOuAlterar))
                    {
                        <button type="button" onclick="CarregarPagina('@Url.Action("Adicionar")')" class="btn btn-primary">
                            <i class="bx bx-plus"></i> Adicionar
                        </button>
                    }
                </div>
            </div>
        </div>

        <br />

        <div id="grid">
            @await Html.PartialAsync("_TabelaPaginada")
        </div>
    </div>
</div>

<div class="modal fade" id="modalApuracao" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Apurar Bônus: <span id="apuracaoDesc"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Escolha o mês de referência para o cálculo:</p>
                <input type="text" id="mesReferencia" class="form-control" placeholder="MM/AAAA" value="@DateTime.Now.ToString("MM/yyyy")" />
                <input type="hidden" id="apuracaoId" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" onclick="executarApuracao()">Calcular Agora</button>
            </div>
        </div>
    </div>
</div>

<script>
    function abrirModalApuracao(id, desc) {
        $('#apuracaoId').val(id);
        $('#apuracaoDesc').text(desc);
        $('#modalApuracao').modal('show');
    }

    function executarApuracao() {
        let id = $('#apuracaoId').val();
        let mes = $('#mesReferencia').val();

        if (!mes || !/^\d{2}\/\d{4}$/.test(mes)) {
            Swal.fire('Atenção', 'Informe o mês no formato MM/AAAA', 'warning');
            return;
        }

        $.post('@Url.Action("ProcessarCalculoDoMes")', { configuracaoBonusId: id, mesReferencia: mes }, function (res) {
            $('#modalApuracao').modal('hide');
            if (res.sucesso) {
                Swal.fire('Sucesso', res.mensagem, 'success').then(() => {
                    CarregarPagina('@Url.Action("Relatorio")');
                });
            } else {
                Swal.fire('Erro', res.mensagem, 'error');
            }
        });
    }
</script>
