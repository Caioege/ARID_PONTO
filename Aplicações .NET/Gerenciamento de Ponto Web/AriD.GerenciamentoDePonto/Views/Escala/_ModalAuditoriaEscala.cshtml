@model int

<div class="modal fade" id="modalAuditoriaEscala" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class='bx bx-history'></i> Auditoria da Escala</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="escalaIdAuditoria" value="@Model" />
                <div class="row">
                    <div class="col-md-3">
                        <label class="form-label" for="mesAnoAuditoria">Mês/Ano</label>
                        <input type="text" id="mesAnoAuditoria" class="form-control" placeholder="MM/AAAA" />
                    </div>
                    <div class="col-md-7">
                        <label class="form-label" for="termoAuditoria">Buscar (Ação, Descrição, Usuário)</label>
                        <input type="text" id="termoAuditoria" class="form-control" />
                    </div>
                    <div class="col-md-2 mt-4">
                        <button type="button" class="btn btn-primary w-100" onclick="buscarAuditoriaEscala()"><i class='bx bx-search'></i> Filtrar</button>
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-12">
                        <div id="tabelaAuditoriaEscalaContainer"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">
                    Fechar
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $('#mesAnoAuditoria').mask('00/0000');
        buscarAuditoriaEscala();
    });

    function buscarAuditoriaEscala(pagina = 1) {
        var escalaId = $('#escalaIdAuditoria').val();
        var mesAno = $('#mesAnoAuditoria').val();
        var termo = $('#termoAuditoria').val();

        var params = {
            Pagina: pagina,
            QuantidadeDeItensPorPagina: 10,
            TermoDeBusca: termo,
            escalaId: escalaId,
            mesAno: mesAno
        };

        CarregarDiv('@Url.Action("TabelaPaginadaAuditoria", "Escala")', params, 'tabelaAuditoriaEscalaContainer');
    }
</script>
