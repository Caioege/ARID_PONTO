@using AriD.BibliotecaDeClasses.DTO
@using AriD.BibliotecaDeClasses.Enumeradores
@model List<AriD.BibliotecaDeClasses.Entidades.MapeamentoEventoFolhaPagamento>

@{
    var tipos = (List<CodigoDescricaoDTO>)ViewBag.TiposEvento;
}

<div class="modal fade" id="_ModalCodigosFolha" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Códigos da Folha (Mapeamento)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="MapeamentosJson" />

                <div class="d-flex justify-content-between align-items-center">
                    <small class="text-muted">Preencha os códigos que sua folha usa. Sem código, o evento não exporta.</small>
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="adicionarLinhaCodigo()">
                        + Adicionar
                    </button>
                </div>

                <div class="table-responsive mt-2">
                    <table class="table table-bordered" id="tbl-codigos">
                        <thead style="background:#f3f3f3">
                            <tr>
                                <th>Tipo</th>
                                <th style="width:120px">Percentual</th>
                                <th style="width:160px">Código</th>
                                <th>Descrição</th>
                                <th style="width:80px"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <select class="form-select tipo">
                                            @foreach (var t in tipos)
                                            {
                                                <option value="@t.Codigo" selected="@(t.Codigo == (int)item.TipoEvento ? "selected" : null)">@t.Descricao</option>
                                            }
                                        </select>
                                    </td>
                                    <td><input class="form-control percentual" value="@(item.Percentual?.ToString() ?? "")" placeholder="(opcional)" /></td>
                                    <td><input class="form-control codigo" value="@item.Codigo" /></td>
                                    <td><input class="form-control descricao" value="@item.Descricao" /></td>
                                    <td class="text-center">
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="removerLinhaCodigo(this)">X</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <small class="text-muted">Percentual é opcional agora. Quando você voltar com HE 50/70/100, você mapeia cada percentual aqui.</small>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fechar</button>
                <button type="button" class="btn btn-primary" onclick="salvarCodigos()">Salvar</button>
            </div>
        </div>
    </div>
</div>