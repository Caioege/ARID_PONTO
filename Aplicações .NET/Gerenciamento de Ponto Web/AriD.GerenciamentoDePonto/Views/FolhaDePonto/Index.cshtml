@using AriD.BibliotecaDeClasses.Enumeradores

@{
    var dadosDaSessao = Context.DadosDaSessao();
}

<style>
    .swal-zindex-alto {
        z-index: 99999 !important;
    }

    .btn-acao-ponto {
        margin-top: 23px;
        display: none !important;
    }

    .popup {
        position: absolute;
        background: #fff;
        border: 1px solid #ccc;
        padding: 8px;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2);
        z-index: 1000;
        font-size: 14px;
        transition: opacity 0.1s;
        display: flex;
        flex-direction: column;
    }

    .oculto {
        display: none;
    }

    .popup button {
        margin: 5px 2px;
    }

    /* Estilos centralizados da Folha de Ponto para evitar acúmulo de estilos via AJAX */
    .table-folha thead tr th,
    .table-folha tbody tr td {
        padding: 5px !important;
        vertical-align: middle;
        line-height: 1.4;
    }

    /* Garantir que o body não acumule padding do Bootstrap/SweetAlert2 */
    body {
        padding-right: 0 !important;
    }
    
    .modal-open {
        overflow: hidden;
        padding-right: 0 !important;
    }

    .linha-servidor:hover {
        background-color: #e9e9e938;
    }

    .item-selecionavel:hover {
        cursor: pointer;
        background: lightyellow !important;
    }

    .linha-afastamento-abono > td:not(:first-child) {
        background: ivory;
    }

    .linha-afastamento-sem-abono > td:not(:first-child) {
        background: #fff0f3;
    }

    .legenda > ul {
        list-style-type: none;
        padding: 0;
        margin: 0;
    }

    .he-pendente {
        background: #fff3cd !important;
    }

    .he-badge {
        cursor: pointer;
        padding: 2px 6px;
        border-radius: 10px;
        font-size: 11px;
        border: 1px solid #ffeeba;
        background: #fff3cd;
        color: #856404;
        display: inline-flex;
        gap: 6px;
        align-items: center;
    }

    .he-badge:hover {
        filter: brightness(0.98);
    }
</style>

@Html.Hidden("TelaFolhaDePonto", true)
<div class="card mb-6">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            Folha de Ponto
        </h5>
        <small class="text-muted float-end">
            Campos com <span style="color: red">*</span> são obrigatórios.
        </small>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col col-md-12">
                <label class="form-label obrigatorio" for="Unidade">Unidade</label>
                @if (dadosDaSessao.Perfil == ePerfilDeAcesso.UnidadeOrganizacional) 
                {
                    @Html.TextBox("UnidadeOrganizacionalNome", "UNIDADE NOME", new { @class = "form-control", @disabled = "disabled", @readonly = "readonly" })
                    @Html.Hidden("UnidadeOrganizacionalId", dadosDaSessao.UnidadeOrganizacionais.First())
                }
                else 
                {
                    @Html.DropDownList("UnidadeOrganizacionalId", (SelectList)ViewBag.Unidades, string.Empty, new { @class = "select2" })
                }
            </div>
        </div>

        <div class="row">
            <div class="col col-md-6 col-sm-12 col-12">
                <label class="form-label obrigatorio" for="ServidorId">@Context.NomenclaturaServidor()</label>
                @Html.DropDownList("ServidorId", new SelectList(string.Empty), new { @class = "select2" })
            </div>

            <div class="col col-md-6 col-sm-12 col-12">
                <label class="form-label obrigatorio" for="VinculoDeTrabalhoId">Vínculo de Trabalho</label>
                @Html.DropDownList("VinculoDeTrabalhoId", new SelectList(string.Empty), new { @class = "select2" })
            </div>
        </div>

        <div class="row">
            <div class="col col-md-4 col-sm-12 col-12">
                <label class="form-label obrigatorio" for="MesDeReferencia">Período</label>
                <div class="input-group">
                    <input id="MesDeReferencia" type="month" class="form-control" />
                    <button class="btn btn-primary" type="button" onclick="carregarFolhaDePonto()">
                        <i class='bx bx-search-alt'></i> Pesquisar
                    </button>
                </div>
            </div>

            <div id="btn-acoes-container" class="col col-md-8 col-sm-12 col-12 float-end" style="display: none; text-align: right;">
                <div class="btn-group float-end" style="margin-top: 23px;">
                    <button type="button" class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class='bx bx-wrench'></i> Ações
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <button id="btn-imprimir" type="button" class="dropdown-item" onclick="imprimirFolhaDePonto()">
                                <i class='bx bx-printer'></i> Imprimir
                            </button>
                        </li>
                        <li>
                            <button id="btn-fechar-ponto" type="button" class="dropdown-item" onclick="fecharPeriodoPonto()">
                                <i class='bx bxs-lock-alt'></i> Fechar Ponto
                            </button>
                        </li>
                        <li>
                            <button id="btn-abrir-ponto" type="button" class="dropdown-item" onclick="abrirPeriodoPonto()">
                                <i class='bx bxs-lock-open-alt'></i> Abrir Ponto
                            </button>
                        </li>
                        @if (Context.PossuiPermissao(eItemDePermissao_FolhaDePonto.Resetar))
                        {
                            <li>
                                <button id="btn-resetar" type="button" class="dropdown-item" onclick="resetarFolhaDePonto()">
                                    <i class='bx bx-refresh'></i> Resetar Folha
                                </button>
                            </li>
                        }
                        @if (Context.PossuiPermissao(eItemDePermissao_FolhaDePonto.GerenciarRegistrosDoAplicativo))
                        {
                            <li>
                                <button id="btn-gerenciar-app" type="button" class="dropdown-item" onclick="abrirModalGerenciarRegistrosApp()">
                                    <i class='bx bx-mobile-alt'></i> Solicitações App
                                </button>
                            </li>
                            <li>
                                <button id="btn-ocorrencias-espelho" type="button" class="dropdown-item" onclick="abrirModalOcorrenciasEspelho()">
                                    <i class='bx bx-message-square-detail'></i> Ocorrências Espelho
                                </button>
                            </li>
                        }
                        @if (Context.PossuiPermissao(eItemDePermissao_FolhaDePonto.VisualizarHistorico))
                        {
                            <li>
                                <button id="btn-visualizarhistoricofolha" type="button" class="dropdown-item" onclick="modalAuditoriaFolha(null)">
                                    <i class='bx bx-history'></i> Alterações Gerais
                                </button>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>


        <br />

        <div id="div-ponto"></div>
    </div>
</div>

<div id="popup" class="popup oculto"></div>

<div id="imagemExpandida" class="d-none"
     style="position: fixed; z-index: 2000; top: 0; left: 0; width: 100%; height: 100%;
            background-color: rgba(0,0,0,0.85); display: flex; justify-content: center; align-items: center;">
    <img id="imagemExpandidaSrc" src="" style="max-width: 95%; max-height: 95%; border: 4px solid #fff;" />
    <button class="btn btn-light position-absolute top-0 end-0 m-3" onclick="fecharImagemExpandida()">
        Fechar <i class="bx bx-x"></i>
    </button>
</div>

<div class="modal fade" id="modalAjusteBH" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Ajuste Manual de Banco de Horas</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="hdnPontoIdAjuste" />

                <div class="mb-3">
                    <label class="form-label d-block">Tipo de Ajuste</label>
                    <div class="btn-group w-100" role="group">
                        <input type="radio" class="btn-check" name="rdTipoAjuste" id="rdCreditar" value="C" checked>
                        <label class="btn btn-outline-success" for="rdCreditar">
                            <i class='bx bx-plus-circle'></i> Creditar
                        </label>

                        <input type="radio" class="btn-check" name="rdTipoAjuste" id="rdDebitar" value="D">
                        <label class="btn btn-outline-danger" for="rdDebitar">
                            <i class='bx bx-minus-circle'></i> Debitar
                        </label>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Quantidade de Horas</label>
                    <input type="text" id="txtValorAjuste" class="form-control hora-3" placeholder="000:00" maxlength="5" autocomplete="off" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" onclick="salvarAjusteBH()">Salvar</button>
            </div>
        </div>
    </div>
</div>


<div id="div-modal"></div>
<script src="/Scripts/Paginas/FolhaDePonto/funcoesDePonto.js?t=@DateTime.Now.Ticks"></script>
<script src="/Scripts/Paginas/FolhaDePonto/folhaDePonto.js?t=@DateTime.Now.Ticks"></script>