@using AriD.BibliotecaDeClasses.DTO
@using AriD.GerenciamentoDePonto.Helpers
@model AriD.GerenciamentoDePonto.WebGrid.ListaPaginada<RegistroForaDaToleranciaDTO>

<div class="row">
    <div class="col-xs-12 col-sm-7 col-md-7 col-lg-4">
        <h1 class="page-title txt-color-blueDark">
            <i class="bx bx-time-five"></i> Aprovação de Marcações (Lote)
        </h1>
    </div>
</div>

<section id="widget-grid" class="">
    <div class="row">
        <article class="col-xs-12 col-sm-12 col-md-12 col-lg-12">
            <div class="jarviswidget jarviswidget-color-blueDark" id="wid-id-0">
                <header>
                    <span class="widget-icon"> <i class="bx bx-filter-alt"></i> </span>
                    <h2>Filtros de Busca</h2>
                </header>
                <div>
                    <div class="widget-body">
                        <form id="formFiltros" method="get" action="@Url.Action("AprovarMarcacaoLote")">
                            <div class="row">
                                <div class="col-md-3">
                                    <label>Unidade</label>
                                    @Html.DropDownList("unidadeId", (SelectList)ViewBag.Unidades, "(Todas as Unidades)", new { @class = "form-control select2" })
                                </div>
                                <div class="col-md-3">
                                    <label>Data Inicial *</label>
                                    <input type="date" name="dataInicial" class="form-control" value="@(ViewBag.DataInicial != null ? ((DateTime)ViewBag.DataInicial).ToString("yyyy-MM-dd") : "")" required />
                                </div>
                                <div class="col-md-3">
                                    <label>Data Final *</label>
                                    <input type="date" name="dataFinal" class="form-control" value="@(ViewBag.DataFinal != null ? ((DateTime)ViewBag.DataFinal).ToString("yyyy-MM-dd") : "")" required />
                                </div>
                                <div class="col-md-3">
                                    <label>&nbsp;</label>
                                    <button type="submit" class="btn btn-primary btn-block">
                                        <i class="bx bx-search-alt"></i> Filtrar Registros
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="jarviswidget jarviswidget-color-blueDark" id="wid-id-list">
                <header>
                    <span class="widget-icon"> <i class="bx bx-list-ul"></i> </span>
                    <h2>Lista de Registros Fora da Tolerância</h2>
                </header>
                <div>
                    <div class="widget-body">
                        <div class="table-responsive">
                            <table class="table table-striped table-bordered table-hover" width="100%">
                                <thead>
                                    <tr>
                                        <th style="width: 30px;"><input type="checkbox" id="checkAll" /></th>
                                        <th>Servidor</th>
                                        <th>Unidade</th>
                                        <th>Registro</th>
                                        <th>Esperado</th>
                                        <th>Status/Ação</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model != null && Model.Itens.Count > 0)
                                    {
                                        foreach (var item in Model.Itens)
                                        {
                                            <tr>
                                                <td>
                                                    @if (item.AprovadoForaTolerancia == null)
                                                    {
                                                        <input type="checkbox" class="chk-registro" value="@item.RegistroId" />
                                                    }
                                                </td>
                                                <td>@item.ServidorNome</td>
                                                <td><small>@item.UnidadeNome</small></td>
                                                <td>
                                                    @($"{item.DataHoraRegistro:dd/MM/yyyy HH:mm}") 
                                                    <span class="label label-warning">@item.TipoRegistro</span>
                                                </td>
                                                <td><strong>@item.HorarioEsperado.ToString(@"hh\:mm")</strong></td>
                                                <td>
                                                    @if (item.AprovadoForaTolerancia == true)
                                                    {
                                                        <span class="text-success"><i class="bx bx-check-double"></i> @item.AcaoAprovacao</span>
                                                    }
                                                    else if (item.AprovadoForaTolerancia == false)
                                                    {
                                                        <span class="text-danger"><i class="bx bx-x"></i> @item.AcaoAprovacao</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">Pendente</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center">
                                                @if (ViewBag.DataInicial == null)
                                                {
                                                    <div class="alert alert-info" style="margin-bottom: 0;">
                                                        <i class="bx bx-info-circle"></i> Selecione um período para carregar os registros.
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span>Nenhuma marcação fora da tolerância encontrada para este período/filtro.</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            @await Html.PartialAsync("_PaginacaoWebGrid", Model)
                        </div>

                        <div class="row" style="margin-top: 20px;">
                            <div class="col-md-3">
                                <select id="ddlAcaoLote" class="form-control">
                                    <option value="">(Selecione a Ação em Lote)</option>
                                    <option value="Aprovar">Aprovar Marcação</option>
                                    <option value="Desconsiderar">Desconsiderar Registro</option>
                                </select>
                            </div>
                            <div class="col-md-5">
                                <input type="text" id="txtMotivo" class="form-control" placeholder="Motivo da ação" />
                            </div>
                            <div class="col-md-4">
                                <button type="button" class="btn btn-primary" onclick="ExecutarLote()">Executar Lote</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </article>
    </div>
</section>

@section pagespecific {
    <script>
        $('#checkAll').change(function () {
            $('.chk-registro').prop('checked', $(this).prop('checked'));
        });

        function ExecutarLote() {
            var acao = $('#ddlAcaoLote').val();
            var motivo = $('#txtMotivo').val();
            var ids = $('.chk-registro:checked').map(function () { return $(this).val(); }).get();

            if (!acao) { alert('Selecione uma ação.'); return; }
            if (ids.length === 0) { alert('Selecione ao menos um registro.'); return; }

            $.post('/FolhaDePonto/ExecutarAprovacaoMarcacaoLote', { registrosIds: ids, acao: acao, motivo: motivo }, function (res) {
                if (res.sucesso) {
                    Swal.fire('Sucesso', res.mensagem, 'success').then(() => { window.location.reload(); });
                } else {
                    Swal.fire('Erdro', res.mensagem, 'error');
                }
            });
        }
    </script>
}
