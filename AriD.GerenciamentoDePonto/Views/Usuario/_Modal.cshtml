@using AriD.BibliotecaDeClasses.DTO
@using AriD.BibliotecaDeClasses.Enumeradores
@using AriD.Servicos.Extensao
@model Usuario

@{
    var adicionar = Model.Id == 0;
    var dadosDaSessao = Context.DadosDaSessao();

    var podeRemover = Context.PossuiPermissao(eItemDePermissao_Usuarios.Excluir);
}

<div class="modal" tabindex="-1" id="_Modal" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@(adicionar ? "Adicionar" : "Alterar") Usuário</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="formulario-usuario">
                    @Html.HiddenFor(model => model.Id)
                    <div class="row">
                        <div class="col col-md-12">
                            <label class="form-label obrigatorio" for="NomeDaPessoa">Nome da Pessoa</label>
                            @Html.TextBoxFor(model => model.NomeDaPessoa, new { @class = "form-control", @maxlength = "100"})
                        </div>
                    </div>
                    <div class="row">
                        <div class="col col-lg-6 col-md-6 col-md-12">
                            <label class="form-label obrigatorio" for="UsuarioDeAcesso">Usuário</label>
                            @Html.TextBoxFor(model => model.UsuarioDeAcesso, new { @class = "form-control", @maxlength = "100" })
                        </div>

                        <div class="col col-lg-6 col-md-6 col-md-12">
                            <label class="form-label @(Model.Id == 0 ? "obrigatorio" : string.Empty)" for="Senha">Senha</label>
                            @Html.PasswordFor(model => model.Senha, new { @class = "form-control", @maxlength = "100" })
                        </div>
                    </div>

                    <div class="row">
                        <div class="col col-lg-4 col-md-6 col-sm-12">
                            <label class="form-label obrigatorio" for="Ativo">Ativo</label>
                            @Html.CheckboxDropDownListFor(model => model.Ativo, new { @class = "form-select" })
                        </div>

                        <div class="col col-lg-8 col-md-6 col-sm-12">
                            <label class="form-label obrigatorio" for="PerfilDeAcesso">Perfil de Acesso</label>
                            @if (Model.Id > 0 || dadosDaSessao.Perfil == ePerfilDeAcesso.AdministradorDeSistema)    {
                                @Html.TextBox("PerfilDeAcessoDescricao", Model.PerfilDeAcesso.DescricaoDoEnumerador(), new { @class = "form-control", @disabled = "disabled", @readonly = "readonly" })
                            }
                            else 
                            {
                                var listaDePerfis = new List<CodigoDescricaoDTO>()
                                {
                                    new CodigoDescricaoDTO((int)ePerfilDeAcesso.Organizacao, ePerfilDeAcesso.Organizacao.DescricaoDoEnumerador()),
                                    new CodigoDescricaoDTO((int)ePerfilDeAcesso.UnidadeOrganizacional, ePerfilDeAcesso.UnidadeOrganizacional.DescricaoDoEnumerador()),
                                    new CodigoDescricaoDTO((int)ePerfilDeAcesso.Departamento, ePerfilDeAcesso.Departamento.DescricaoDoEnumerador())
                                };

                                @Html.DropDownList("PerfilDeAcesso", new SelectList(listaDePerfis, "Codigo", "Descricao", (int)Model.PerfilDeAcesso), new { @class = "select2" })
                            }
                        </div>
                    </div>

                    @if (Context.DadosDaSessao().Perfil != ePerfilDeAcesso.AdministradorDeSistema) 
                    {
                        <div class="row">
                            <div class="col col-lg-12">
                                <label class="form-label obrigatorio" for="GrupoDePermissaoId">Grupo de Permissão</label>
                                @Html.DropDownListFor(model => model.GrupoDePermissaoId, (SelectList)ViewBag.Grupos, string.Empty, new { @class = "select2" })
                            </div>
                        </div>

                        @if (Model.Id == 0)
                        {
                            <div class="row" id="div-unidade" style="display:none;">
                                <div class="col col-lg-12">
                                    <label class="form-label" id="label-unidade" for="UnidadeOrganizacionalId">Unidade</label>
                                    @Html.DropDownListFor(model => model.UnidadeOrganizacionalId, (SelectList)ViewBag.Unidades, string.Empty, new { @class = "select2" })
                                </div>
                            </div>

                            <div class="row" style="display:none;" id="div-departamento">
                                <div class="col col-md-12">
                                    <label class="form-label" id="label-departamento" for="DepartamentoId">Departamento</label>
                                    @Html.DropDownList("DepartamentoId", (SelectList)ViewBag.Departamentos, string.Empty, new { @class = "select2" })
                                </div>
                            </div>
                        }
                        else if (Model.PerfilDeAcesso == ePerfilDeAcesso.Departamento)
                        {
                            <div class="row" >
                                <div class="col col-md-12">
                                    <label class="form-label obrigatorio" for="DepartamentoId">Departamento</label>
                                    @Html.HiddenFor(model => model.DepartamentoId)
                                    @Html.TextBox("DepartamentoNome", Model.Departamento.SiglaComDescricao, new { @class = "form-control", @disabled = "disabled", @readonly = "readonly" })
                                </div>
                            </div>
                        }
                        else if (Model.PerfilDeAcesso == ePerfilDeAcesso.UnidadeOrganizacional)
                        {
                            <div class="row">
                                <div class="col col-md-12">
                                    <label class="form-label obrigatorio" for="UnidadeOrganizacionalId">Unidade</label>
                                    @Html.TextBox("UnidadeNome", Model.UnidadeOrganizacional.Nome, new { @class = "form-control", @readonly = "readonly", @disabled = "disabled" })
                                    @Html.HiddenFor(model => model.UnidadeOrganizacionalId)
                                </div>
                            </div>
                        }
                    }
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class='bx bx-window-close'></i> Fechar
                </button>

                @if (Model.Id > 0 && podeRemover)
                {
                    <button type="button" class="btn btn-danger" onclick="removerUsuario(@Model.Id)">
                        <i class="bx bx-trash"></i> Remover
                    </button>
                }

                <button type="button" class="btn btn-primary" id="btn-salvar-modal">
                    <i class='bx bxs-save'></i> Salvar
                </button>
            </div>
        </div>
    </div>
</div>