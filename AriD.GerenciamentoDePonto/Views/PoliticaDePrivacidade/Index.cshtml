<!doctype html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Política de Privacidade – AriD Ponto | AriD Tecnologia</title>
    <meta name="description" content="Política de Privacidade do aplicativo AriD Ponto, da AriD Tecnologia, em conformidade com a LGPD (Lei nº 13.709/2018)." />
    <style>
        :root{
          --bg:#0e0f12; --card:#151922; --muted:#9aa3b2; --text:#e7ecf3; --brand:#5aa6ff; --ok:#1db954; --warn:#ffb020;
        }
        *{box-sizing:border-box}
        html,body{height:100%}
        body{margin:0; font:16px/1.6 system-ui,-apple-system,Segoe UI,Roboto,Ubuntu,Cantarell,"Helvetica Neue",Arial; color:var(--text); background:linear-gradient(180deg,#0e0f12,#10141b 60%,#0e0f12)}
        .wrap{max-width:920px;margin:40px auto;padding:0 20px 80px}
        header{background:var(--card); border:1px solid #212735; padding:28px; border-radius:18px; box-shadow:0 10px 30px rgba(0,0,0,.25)}
        h1{margin:0 0 6px; font-size:clamp(24px,3.5vw,34px)}
        .sub{color:var(--muted); font-size:14px}
        .chip{display:inline-flex; align-items:center; gap:8px; background:#0f1520; border:1px solid #20283a; color:var(--muted); padding:6px 10px; border-radius:999px; font-size:12px}
        .chip b{color:#cfd7e6}
        main{margin-top:22px}
        section{background:var(--card); border:1px solid #212735; padding:22px; border-radius:18px; margin:16px 0}
        h2{margin:0 0 12px; font-size:clamp(18px,2.6vw,22px)}
        h3{margin:18px 0 8px; font-size:17px}
        p{margin:10px 0}
        ul{margin:8px 0 8px 18px}
