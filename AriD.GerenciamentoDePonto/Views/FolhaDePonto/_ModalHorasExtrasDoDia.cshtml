@using AriD.BibliotecaDeClasses.Enumeradores
@using AriD.Servicos.Extensao
@model List<PontoDoDiaHoraExtra>

@{
    var pontoDoDia = (PontoDoDia)ViewBag.PontoDoDia;
    bool podeAprovar = (bool)ViewBag.PodeAprovar;

    string fmtMin(int m) => TimeSpan.FromMinutes(m).ToString(@"hh\:mm");
}

<div class="modal fade" id="_ModalHorasExtras" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    Horas Extras - @pontoDoDia.Data.ToShortDateString() (@pontoDoDia.DiaDaSemana.SiglaDaSemanaDoEnumerador())
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                @if (Model == null || Model.Count == 0)
                {
                    <div class="alert alert-info">Não há eventos de hora extra para este dia.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead style="background:#f3f3f3">
                                <tr>
                                    <th>Tipo Dia</th>
                                    <th>Origem</th>
                                    <th>%</th>
                                    <th>Minutos</th>
                                    <th>Status</th>
                                    <th>Aprovado</th>
                                    @if (podeAprovar)
                                    {
                                        <th style="width:220px">Ações</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.OrderBy(x => x.TipoDia).ThenBy(x => x.Origem).ThenBy(x => x.Percentual))
                                {
                                    <tr>
                                        <td>@item.TipoDia</td>
                                        <td>@item.Origem</td>
                                        <td>@item.Percentual</td>
                                        <td>@fmtMin(item.Minutos)</td>
                                        <td>@item.Status</td>
                                        <td>@fmtMin(item.MinutosAprovados)</td>

                                        @if (podeAprovar)
                                        {
                                            <td>
                                                <div style="display:flex;gap:6px;align-items:center;">
                                                    <input type="number"
                                                           class="form-control form-control-sm"
                                                           style="width:90px"
                                                           id="min-aprov-@item.Id"
                                                           min="0"
                                                           max="@item.Minutos"
                                                           value="@(item.Status == eStatusAprovacaoHoraExtra.Aprovado ? item.MinutosAprovados : item.Minutos)" />

                                                    <button class="btn btn-sm btn-success"
                                                            type="button"
                                                            onclick="aprovarHoraExtra(@item.Id, @item.Minutos);">
                                                        Aprovar
                                                    </button>

                                                    <button class="btn btn-sm btn-danger"
                                                            type="button"
                                                            onclick="reprovarHoraExtra(@item.Id);">
                                                        Reprovar
                                                    </button>
                                                </div>
                                                <small class="text-muted">Aprovação parcial: informe minutos (0..@item.Minutos).</small>
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fechar</button>
            </div>
        </div>
    </div>
</div>