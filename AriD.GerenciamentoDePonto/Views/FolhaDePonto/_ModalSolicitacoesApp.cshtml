@model List<RegistroAplicativo>

@{
    var registrosManuais = Model
        .Where(c => !c.JustificativaDeAusenciaId.HasValue)
        .OrderBy(c => c.DataHora);

    var registrosJustificativas = Model
        .Where(c => c.JustificativaDeAusenciaId.HasValue)
        .OrderBy(c => c.DataInicialAtestado);
}

<div class="modal" tabindex="-1" id="_ModalSolicitacoesApp" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    Solicitações feitas no Aplicativo
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                @Html.Hidden("RecarregarFolhaDePontoAoFechar", false)
                @if (registrosManuais.Count() > 0)
                {
                    <h6><i class='bx bx-calendar-edit'></i> Registros manuais</h6>
                    <table class="table table-condensed table-responsive table-bordered">
                        <thead style="background-color: aliceblue">
                            <tr>
                                <th class="text-center" width="20%">
                                    Data/Hora
                                </th>
                                <th class="text-center" width="60%">
                                    Observação
                                </th>
                                <th width="20%">
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var registro in registrosManuais)
                            {
                                <tr id="linha-registro-app-@registro.Id">
                                    <td class="text-center">
                                        @registro.DataHora.ToString("dd/MM/yyyy")
                                        <br />
                                        @registro.DataHora.ToString("HH:mm")
                                    </td>
                                    <td style="text-align: justify">
                                        @registro.Observacao
                                    </td>
                                    <td class="text-center">
                                        <button type="button" class="btn btn-success" onclick="aprovaRegistro(@registro.Id)">
                                            <i class='bx bxs-check-square'></i>
                                        </button>

                                        <button type="button" class="btn btn-danger" onclick="reprovaRegistro(@registro.Id)">
                                            <i class='bx bxs-checkbox-minus'></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                @if (registrosJustificativas.Count() > 0)
                {
                    <h6><i class='bx bx-paperclip' ></i> Atestados</h6>
                    <table class="table table-condensed table-responsive table-bordered">
                        <thead style="background-color: aliceblue">
                            <tr>
                                <th class="text-center" width="20%">
                                    Início/Fim
                                </th>
                                <th class="text-center" width="60%">
                                    Justificativa
                                </th>
                                <th width="20%">
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var registro in registrosJustificativas)
                            {
                                <tr id="linha-registro-app-@registro.Id">
                                    <td class="text-center">
                                        @(registro.DataInicialAtestado?.ToString("dd/MM/yyyy"))
                                        <br />
                                        @(registro.DataFinalAtestado?.ToString("dd/MM/yyyy"))
                                    </td>
                                    <td style="text-align: justify">
                                        @(registro.JustificativaDeAusencia?.SiglaComDescricao)
                                    </td>
                                    <td class="text-center">
                                        <button type="button" class="btn btn-success" onclick="aprovaRegistro(@registro.Id)">
                                            <i class='bx bxs-check-square'></i>
                                        </button>

                                        <button type="button" class="btn btn-danger" onclick="reprovaRegistro(@registro.Id)">
                                            <i class='bx bxs-checkbox-minus'></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class='bx bx-window-close'></i> Fechar
                </button>
            </div>
        </div>
    </div>
</div>