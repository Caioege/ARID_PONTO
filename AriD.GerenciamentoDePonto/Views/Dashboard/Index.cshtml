@using AriD.BibliotecaDeClasses.Enumeradores
@{
    var dadosDaSessao = Context.DadosDaSessao();
}

<style>
    .card-total {
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-direction: row;
    }

    .card-com-linha-esquerda {
        position: relative;
        border-left: 4px solid var(--linha-cor, #696cff);
        border-radius: 0.375rem;
        overflow: hidden;
    }
</style>

@Html.Hidden("TelaDashboard", "True")

<div class="card mb-6" id="dashboard-body">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class='bx bxs-dashboard'></i> Dashboard
        </h5>
    </div>
    <div class="card-body">
        @if (dadosDaSessao.Perfil != ePerfilDeAcesso.UnidadeOrganizacional)
        {
            <div class="row">
                <div class="col col-md-12 col-12">
                    <label class="form-label">Unidade</label>
                    @Html.DropDownList("UnidadeId", (SelectList)ViewBag.Unidades, "Todas", new { @class = "select2", @onchange = "carregarDashboard()" })
                </div>
            </div>
            <br />
        }
        <div class="row">
            <div class="col-md-4 col-sm-6 mb-4">
                <div class="card text-center card-com-linha-esquerda" style="--linha-cor: #FF9F43;">
                    <div class="card-body card-total">
                        <span><i class='bx bxs-user-account' style="color: #FF9F43"></i> Vínculos ativos</span>
                        <div class="spinner-border text-primary d-none" role="status" id="loader-contratos"></div>
                        <h4 class="mb-0">
                            <span id="valor-contratos-ativos"></span>
                        </h4>
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-sm-6 mb-4">
                <div class="card text-center card-com-linha-esquerda" style="--linha-cor: #96d27d;">
                    <div class="card-body card-total">
                        <span><i class='bx bxs-calendar-event' style="color: #96d27d;"></i> Registros Hoje</span>
                        <div class="spinner-border text-primary d-none" role="status" id="loader-registros"></div>
                        <h4 class="mb-0">
                            <span id="valor-registros"></span>
                        </h4>
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-sm-6 mb-4">
                <div class="card text-center card-com-linha-esquerda">
                    <div class="card-body card-total">
                        <span><i class='bx bx-mobile-alt' style="color: #696cff;"></i> Equipamentos Ativos</span>
                        <div class="spinner-border text-primary d-none" role="status" id="loader-equipamentos"></div>
                        <h4 class="mb-0">
                            <span id="valor-equipamentos"></span>
                        </h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12 mb-4">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="card-title">Registros por hora (últimas 5 horas)</h5>
                        <div class="spinner-border text-primary d-none" role="status" id="loader-equipamento-grafico"></div>
                    </div>
                    <div class="card-body" style="height: 300px">
                        <canvas id="graficoHoras"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-md-12 mb-4" id="div-equipamentos" style="@(dadosDaSessao.Perfil == ePerfilDeAcesso.UnidadeOrganizacional ? string.Empty : "display:none;")">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="card-title">Registros por Equipamento</h5>
                        <div class="spinner-border text-primary d-none" role="status" id="loader-equipamento-grafico"></div>
                    </div>
                    <div class="card-body" style="height: 300px">
                        <canvas id="graficoEquipamento"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-md-12">
                <div class="card card-com-linha-esquerda" style="--linha-cor: #8c8c8c;">
                    <div class="card-header">
                        <h5 class="card-title">
                            <i class='bx bxs-time' style="color: #8c8c8c"></i>
                            Registros dos últimos 30 minutos
                        </h5>
                        <div class="spinner-border text-primary d-none" role="status" id="loader-tabela"></div>
                    </div>
                    <div class="table-responsive text-nowrap">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Data/Hora</th>
                                    <th>Unidade</th>
                                    <th>@Context.NomenclaturaServidor()</th>
                                    <th>Id Equipamento</th>
                                    <th>Equipamento</th>
                                </tr>
                            </thead>
                            <tbody id="tabela-registros">
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="/Scripts/Paginas/Dashboard/index.js?t=@DateTime.Now.Ticks"></script>