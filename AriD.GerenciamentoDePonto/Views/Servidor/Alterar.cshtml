@model Servidor

@{
    var podeAlterar = Context.PossuiPermissao(eItemDePermissao_Servidor.CadastrarOuAlterar);
    var podeRemover = Context.PossuiPermissao(eItemDePermissao_Servidor.Excluir);
    var podeGerirAnexos = Context.PossuiPermissao(eItemDePermissao_Servidor.GerenciarAnexos);
    var podeGerirAfastamentos = Context.PossuiPermissao(eItemDePermissao_Servidor.GerenciarAfastamentos);
}

<style>
    .custom-nav-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: flex-start;
        padding-bottom: 0;
    }

    .custom-nav-pills .nav-item {
        width: 160px;
        flex-grow: 0;
    }

    .custom-nav-pills .nav-link {
        width: 100%;
        height: 100%;
        min-height: 50px;
        
        border: 1px solid #d9dee3;
        background-color: #f5f5f9;
        color: #697a8d;
        border-radius: 6px;
        font-size: 0.75rem; 
        font-weight: 600;
        text-transform: uppercase;
        
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 8px 4px;
        line-height: 1.1;
        transition: all 0.2s ease;
    }

    .custom-nav-pills .nav-link i {
        font-size: 1.2rem;
        margin-bottom: 4px;
        margin-right: 0 !important;
    }
    
    .custom-nav-pills .nav-link.active {
        background-color: #606060 !important;
        border-color: #606060 !important;
        color: #fff !important;
        box-shadow: 0 4px 8px rgba(105, 108, 255, 0.4);
        transform: translateY(-2px);
    }

    .custom-nav-pills .nav-link.active i {
        color: #fff !important;
    }

    .custom-nav-pills .nav-link:hover:not(.active) {
        background-color: #e1e4e8;
        border-color: #cdd2d8;
    }
    .img-servidor {
        height: 100%;
        width: 100%
    }
    .img-servidor:hover {
        cursor: pointer;
    }
</style>

<div class="card mb-6">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div class="row" style="width: 100%">
            <div class="col col-md-8 col-sm-12">
                <h5 class="mb-0">
                    Alterar @Context.NomenclaturaServidor()
                </h5>
            </div>
            <div class="col-md-4 col-xs-12">
                <small class="text-muted float-end">
                    Campos com <span style="color: red">*</span> são obrigatórios.
                </small>
            </div>
        </div>
    </div>
    <div class="card-body">
        <form id="formulario-servidor">
            @Html.HiddenFor(model => model.Id)
            @Html.HiddenFor(model => model.Pessoa.EnderecoId)
            <div style="display: flex">
                <div style="width: 180px; height: 195px; border: 1px solid black;" >
                    <img class="img-servidor" src="/Foto/Servidor/@(Model.Id)?t=@DateTime.Now.Ticks" data-bs-toggle="offcanvas" data-bs-target="#offcanvasBottom" aria-controls="offcanvasBottom" />
                    <div style="height: auto !important; text-align: center;" class="offcanvas offcanvas-bottom" tabindex="-1" id="offcanvasBottom" aria-labelledby="offcanvasBottomLabel">
                        <div class="offcanvas-header" style="display: block;">
                            <h4 id="offcanvasBottomLabel" class="offcanvas-title">Gerenciar Foto da Pessoa</h4>
                        </div>
                        <div class="offcanvas-body">
                            <button type="button" class="btn btn-primary me-3" onclick="abrirSelecionarArquivoImagem()">
                                <i class='bx bx-upload'></i>&nbsp;
                                Atualizar foto
                            </button>
                            <button type="button" class="btn btn-danger me-3" onclick="removerFotoServidor()">
                                <i class='bx bxs-trash-alt'></i>&nbsp;
                                Remover foto
                            </button>
                            <button type="button" id="fechar-offcanvas" class="btn btn-outline-secondary" data-bs-dismiss="offcanvas">
                                <i class='bx bx-window-close'></i>&nbsp;
                                Fechar
                            </button>
                        </div>
                        <br />
                    </div>
                </div>
                <div style="width: 100%; margin-left: 15px;">
                    <div class="row">
                        <div class="col col-lg-12col-xs-12">
                            <label class="form-label obrigatorio" for="Pessoa_Nome">Nome</label>
                            @Html.TextBoxFor(model => model.Pessoa.Nome, new { @class = "form-control", @maxlength = "100" })
                        </div>
                    </div>
                    <div class="row">
                        <div class="col col-lg-12col-xs-12">
                            <label class="form-label">Nome Social</label>
                            @Html.TextBoxFor(model => model.Pessoa.NomeSocial, new { @class = "form-control", @maxlength = "100" })
                        </div>
                    </div>
                    <div class="row">
                        <div class="col col-lg-4 col-md-4 col-sm-12">
                            <label class="form-label obrigatorio" for="Pessoa_Cpf">CPF</label>
                            @Html.TextBoxFor(model => model.Pessoa.Cpf, new { @class = "form-control cpf" })
                        </div>

                        <div class="col col-lg-4 col-md-4 col-sm-12">
                            <label class="form-label obrigatorio" for="Pessoa_DataDeNascimento">Data de Nascimento</label>
                            @Html.TextBox("Pessoa.DataDeNascimento", Model.Pessoa.DataDeNascimento.ToString("yyyy-MM-dd"), new { @class = "form-control data" })
                        </div>

                        <div class="col col-lg-4 col-md-4 col-sm-12">
                            <label class="form-label">RG</label>
                            @Html.TextBoxFor(model => model.Pessoa.Rg, new { @class = "form-control so-numeros" })
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <section class="col col-md-3 col-sm-6">
                    <label class="form-label">Acesso ao Aplicativo/Portal</label>
                    @Html.CheckboxDropDownListFor(model => model.AcessoAoAplicativo, new { @class = "form-select" })
                </section>

                <section class="col col-md-3 col-sm-6">
                    <label class="form-label">Registro de ponto no Aplicativo</label>
                    @Html.CheckboxDropDownListFor(model => model.RegistroDePontoNoAplicativo, new { @class = "form-select" })
                </section>

                <section class="col col-md-3 col-sm-6">
                    <label class="form-label">Registro manual no Aplicativo/Portal</label>
                    @Html.CheckboxDropDownListFor(model => model.RegistroManualNoAplicativo, new { @class = "form-select" })
                </section>

                <section class="col col-md-3 col-sm-6">
                    <label class="form-label">Registro de atestado no Aplicativo/Portal</label>
                    @Html.CheckboxDropDownListFor(model => model.RegistroDeAtestadoNoAplicativo, new { @class = "form-select" })
                </section>
            </div>
            <br />
            <div class="nav-align-top mb-6">

                <ul class="nav nav-pills custom-nav-pills mb-3" role="tablist">

                    <li class="nav-item" role="presentation">
                        <button type="button" class="nav-link active" role="tab" data-bs-toggle="tab" data-bs-target="#s1" aria-controls="s1" aria-selected="true">
                            <i class="tf-icons bx bx-home"></i>
                            CONTATO/ENDEREÇO
                        </button>
                    </li>

                    <li class="nav-item" role="presentation">
                        <button type="button" class="nav-link" role="tab" data-bs-toggle="tab" data-bs-target="#s2" aria-controls="s2" aria-selected="false" tabindex="-1">
                            <i class="tf-icons bx bx-user"></i>
                            VÍNCULOS DE TRABALHO
                        </button>
                    </li>

                    @if (podeGerirAfastamentos)
                    {
                        <li class="nav-item" role="presentation">
                            <button type="button" class="nav-link" role="tab" data-bs-toggle="tab" data-bs-target="#s3" aria-controls="s3" aria-selected="false" tabindex="-1">
                                <i class="tf-icons bx bx-bookmarks"></i>
                                AFASTAMENTOS
                            </button>
                        </li>
                    }

                    <li class="nav-item" role="presentation">
                        <button type="button" class="nav-link" role="tab" data-bs-toggle="tab" data-bs-target="#s4" aria-controls="s4" aria-selected="false" tabindex="-1">
                            <i class="tf-icons bx bx-file"></i>
                            ANEXOS
                        </button>
                    </li>

                    <li class="nav-item" role="presentation">
                        <button type="button" class="nav-link" role="tab" data-bs-toggle="tab" data-bs-target="#s5" aria-controls="s5" aria-selected="false" tabindex="-1">
                            <i class="tf-icons bx bx-notepad"></i>
                            ALERTA/OBSERVAÇÕES
                        </button>
                    </li>

                </ul>

                <div class="border rounded p-4 shadow-sm" style="background-color: #fff; border-color: #d9dee3 !important;">
                    <div class="tab-content" style="padding: 0 !important; box-shadow: none;">

                        <div class="tab-pane fade active show" id="s1" role="tabpanel">
                            <div class="row">
                                <section class="col col-md-3 col-sm-6">
                                    <label class="form-label">Telefone/WhatsApp</label>
                                    @Html.TextBoxFor(model => model.TelefoneDeContato, new { @class = "form-control celular" })
                                </section>
                                <section class="col col-md-9 col-sm-6">
                                    <label class="form-label">E-mail</label>
                                    @Html.TextBoxFor(model => model.Email, new { @class = "form-control", @maxlength = "120" })
                                </section>
                            </div>
                            <br />
                            @{
                                ViewBag.PrefixoEndereco = "Pessoa.Endereco.";
                                ViewBag.EnderecoObrigatorio = true;
                            }
                            @await Html.PartialAsync("_EnderecoPartial", Model.Pessoa.Endereco)
                        </div>

                        <div class="tab-pane fade" id="s2" role="tabpanel">
                            <div class="row">
                                <section class="col col-md-3 col-sm-6">
                                    <label class="form-label">Código CRM</label>
                                    @Html.TextBoxFor(model => model.CodigoCRM, new { @class = "form-control", @maxlength = "20" })
                                </section>
                                <section class="col col-md-6 col-sm-6">
                                    <label class="form-label @(string.IsNullOrEmpty(Model.CodigoCRM) ? "" : "obrigatorio")" for="EspecialidadeMedica">Especialidade Médica</label>
                                    @Html.TextBoxFor(model => model.EspecialidadeMedica, new { @class = "form-control", @maxlength = "200" })
                                </section>
                                <section class="col col-md-3 col-sm-6">
                                    <label class="form-label">Exportação para Folha de Pagamento</label>
                                    @Html.CheckboxDropDownListFor(model => model.HabilitaExportacaoParaFolhaDePagamento, new { @class = "form-select" })
                                </section>
                            </div>
                            <br />
                            @await Html.PartialAsync("_VinculosDeTrabalho", Model.VinculosDeTrabalho)
                        </div>

                        @if (podeGerirAfastamentos)
                        {
                            <div class="tab-pane fade" id="s3" role="tabpanel">
                                @await Html.PartialAsync("_Afastamentos", Model)
                            </div>
                        }

                        <div class="tab-pane fade" id="s4" role="tabpanel">
                            @await Html.PartialAsync("_Anexos", Model)
                        </div>

                        <div class="tab-pane fade" id="s5" role="tabpanel">
                            @await Html.PartialAsync("_Observacoes", Model)
                        </div>

                    </div>
                </div>
            </div>

            <br />
            <button type="button" class="btn btn-secondary" onclick="CarregarPagina('@Url.Action("Index", "Servidor")')">
                <i class='bx bxs-left-arrow-circle'></i> Voltar
            </button>

            @if (Model.Id > 0 && podeRemover)
            {
                <button type="button" class="btn btn-danger" onclick="removerServidor(@Model.Id)">
                    <i class="bx bx-trash"></i> Remover
                </button>
            }

            <button type="button" class="btn btn-dark" data-bs-toggle="modal" data-bs-target="#modalRelatoriosServidor">
                <i class='bx bxs-file-doc'></i> Gerar Relatório
            </button>

            @if (podeAlterar)
            {

                <button type="button" class="btn btn-primary" id="btn-salvar">
                    <i class='bx bxs-save'></i> Salvar
                </button>
            }
        </form>
    </div>
</div>

<div class="modal fade" id="modalRelatoriosServidor" tabindex="-1" aria-labelledby="modalRelatoriosServidorLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalRelatoriosAlunoLabel">Gerar Relatórios do Servidor</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="list-group">
                    <a href="javascript:void(0)" onclick="gerarRelatorioServidor('/ProcessarRelatorioFichaDoServidor')" class="list-group-item list-group-item-action">
                        <i class='bx bx-file me-2'></i>Ficha do Servidor
                    </a>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class='bx bx-window-close'></i> Fechar
                </button>
            </div>
        </div>
    </div>
</div>

<input style="display:none;" id="input-file" type="file" accept="image/png, image/jpg" />
<div id="div-modal"></div>

<script src="/Scripts/Paginas/Servidor/alterar.js?t=@DateTime.Now.Ticks"></script>