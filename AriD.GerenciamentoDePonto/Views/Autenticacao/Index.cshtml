@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta name="google-site-verification" content="8lD1XREHyQjKY90abb8ERMA12BcTuAySzmYo3V60L-8" />
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Entrar - AriD Ponto</title>
    <link rel="stylesheet" href="style.css">
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
</head>
<body>
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

        :root {
            --primary-color: #12192c;
            --primary-light: #2a3352;
            --text-main: #1f2937;
            --text-muted: #6b7280;
            --bg-light: #f9fafb;
            --white: #ffffff;
            --border-color: #e5e7eb;
        }

        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            color: var(--text-main);
            background-color: var(--bg-light);
            height: 100vh;
            overflow: hidden;
        }

        .login-wrapper {
            display: flex;
            height: 100vh;
            width: 100vw;
        }

        .login-banner {
            display: none;
            background: linear-gradient(135deg, var(--primary-color) 0%, #0d1221 100%);
            position: relative;
            overflow: hidden;
            color: var(--white);
        }

        .banner-content {
            position: relative;
            z-index: 2;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100%;
            text-align: center;
            padding: 2rem;
        }

        .banner-image {
            max-width: 85%;
            height: auto;
            margin-bottom: 2rem;
            filter: drop-shadow(0 20px 30px rgba(0,0,0,0.3));
            transition: transform 0.5s ease;
        }

        .banner-image:hover {
            transform: translateY(-10px);
        }

        .banner-title {
            font-size: 2.5rem;
            font-weight: 700;
            margin: 0 0 0.5rem 0;
            letter-spacing: -1px;
        }

        .banner-subtitle {
            font-size: 1.1rem;
            font-weight: 300;
            opacity: 0.8;
            margin: 0;
        }

        .login-banner::before {
            content: '';
            position: absolute;
            top: -20%;
            left: -10%;
            width: 70vw;
            height: 70vw;
            background: radial-gradient(circle, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0) 70%);
            border-radius: 50%;
        }

        .login-panel {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: var(--white);
            padding: 2rem;
            box-shadow: -10px 0 30px rgba(0,0,0,0.05);
            z-index: 10;
        }

        .login-form-container {
            width: 100%;
            max-width: 380px;
        }

        .logo {
            max-width: 150px;
            margin-bottom: 2.5rem;
        }

        .welcome-text {
            font-size: 1.8rem;
            font-weight: 700;
            margin: 0 0 0.5rem 0;
            color: var(--text-main);
            letter-spacing: -0.5px;
        }

        .instruction-text {
            font-size: 0.95rem;
            color: var(--text-muted);
            margin-bottom: 2.5rem;
        }

        .input-group {
            margin-bottom: 1.5rem;
        }

        .input-group label {
            display: block;
            font-size: 0.875rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: var(--text-main);
        }

        .input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-wrapper i {
            position: absolute;
            left: 1rem;
            color: var(--text-muted);
            font-size: 1.25rem;
            transition: color 0.3s ease;
        }

        .input-wrapper input {
            width: 100%;
            padding: 0.875rem 1rem 0.875rem 2.8rem;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            font-size: 1rem;
            color: var(--text-main);
            transition: all 0.2s ease;
            font-family: inherit;
            background-color: var(--bg-light);
            box-sizing: border-box;
        }

        .input-wrapper input:focus {
            outline: none;
            border-color: var(--primary-light);
            background-color: var(--white);
            box-shadow: 0 0 0 4px rgba(18, 25, 44, 0.1);
        }

        .input-wrapper input:focus + i, .input-wrapper input:not(:placeholder-shown) + i {
            color: var(--primary-color);
        }

        .input-wrapper input.error-highlight {
            border-color: #e63946 !important;
            background-color: #fdf2f2 !important;
        }

        .input-wrapper input.error-highlight + i {
            color: #e63946 !important;
        }

        .btn-login {
            width: 100%;
            padding: 1rem;
            background-color: var(--primary-color);
            color: var(--white);
            border: none;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 0.5rem;
            margin-top: 2rem;
            transition: all 0.3s ease;
        }

        .btn-login:hover {
            background-color: var(--primary-light);
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(18, 25, 44, 0.2), 0 4px 6px -2px rgba(18, 25, 44, 0.1);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        .btn-login i {
            font-size: 1.25rem;
            transition: transform 0.3s ease;
        }

        .btn-login:hover i {
            transform: translateX(4px);
        }

        @@media screen and (min-width: 900px) {
            .login-banner {
                display: block;
                flex: 1.2;
            }
            .login-panel {
                flex: 1;
                max-width: 500px;
            }
        }
    </style>

    <div class="login-wrapper">
        <div class="login-banner">
            <div class="banner-content">
                <img class="banner-image" src="/img/facial.png" alt="Simples. Digital. Seguro.">
                <h2 class="banner-title">Simples. Digital. Seguro.</h2>
                <p class="banner-subtitle">Experiência inteligente e ágil para servidores e gestores.</p>
            </div>
        </div>

        <div class="login-panel">
            <div class="login-form-container">
                <img class="logo" src="/img/logo-vertical.png" alt="AriD Tecnologia">
                
                <h1 class="welcome-text">Bem-vindo(a)</h1>
                <p class="instruction-text">Por favor, insira suas credenciais para acessar o sistema.</p>

                <form action="#" class="form-content">
                    <div class="input-group">
                        <label for="usuario">Usuário</label>
                        <div class="input-wrapper">
                            <i class='bx bxs-user'></i>
                            <input id="usuario" type="text" placeholder="Digite seu usuário" required>
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="senha">Senha</label>
                        <div class="input-wrapper">
                            <i class='bx bx-lock-alt'></i>
                            <input id="senha" type="password" placeholder="Digite sua senha" required>
                        </div>
                    </div>

                    <button type="button" class="btn-login" onclick="entrar()">
                        <span>Entrar</span>
                        <i class='bx bx-right-arrow-alt'></i>
                    </button>
                </form>
            </div>
        </div>
    </div>

    <script src="~/vendor/libs/jquery/jquery.js"></script>
    <script src="~/lib/sweetalert2/sweetalert2@11.js"></script>
    <script src="~/js/jquery.loading.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const form = document.querySelector(".form-content");

            form.addEventListener("keydown", function (event) {
                if (event.key === "Enter") {
                    event.preventDefault();
                    entrar();
                }
            });
        });

        const inputs = document.querySelectorAll(".form-input");

        function addfocus() {
            let parent = this.parentNode.parentNode;
            parent.classList.add("focus");
        }

        function remfocus() {
            let parent = this.parentNode.parentNode;
            if(this.value == ""){
                parent.classList.remove("focus");
            }
        }

        inputs.forEach(input => {
            input.addEventListener("focus", function() {
                addfocus.call(this);
                this.classList.remove("error-highlight");
            });
            input.addEventListener("blur", remfocus)
        });

        function entrar() {
            var usuario = $('#usuario').val();
            var senha = $('#senha').val();

            $('#usuario, #senha').removeClass('error-highlight');

            if (!usuario || !senha) {
                if (!usuario) $('#usuario').addClass('error-highlight');
                if (!senha) $('#senha').addClass('error-highlight');

                const Toast = Swal.mixin({
                    toast: true,
                    position: "bottom-end",
                    showConfirmButton: false,
                    timer: 5000,
                    timerProgressBar: true,
                    didOpen: (toast) => {
                        toast.onmouseenter = Swal.stopTimer;
                        toast.onmouseleave = Swal.resumeTimer;
                    }
                });
                Toast.fire({
                    icon: 'warning',
                    html: 'Por favor, preencha o usuário e a senha.'
                });
                return;
            }

            $("body").loading({
                message: 'Carregando...',
                zIndex: 2000,
                onStart: function (loading) {
                    loading.overlay.slideDown(250);
                },
                onStop: function (loading) {
                    loading.overlay.slideUp(250);
                }
            });

            setTimeout(function () {
                $.ajax({
                    url: '/Autenticacao/Entrar',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                            usuario: $('#usuario').val(),
                            senha: $('#senha').val()
                        }),
                    error: function (jqXHR, textStatus, errorThrown) {
                        $("body").loading('stop');
                    }
                }).done(function (data) {
                    $("body").loading('stop');
                    setTimeout(() => {
                        if (!data.sucesso) {
                            const Toast = Swal.mixin({
                                toast: true,
                                position: "bottom-end",
                                showConfirmButton: false,
                                timer: 10000,
                                timerProgressBar: true,
                                didOpen: (toast) => {
                                    toast.onmouseenter = Swal.stopTimer;
                                    toast.onmouseleave = Swal.resumeTimer;
                                }
                            });
                            Toast.fire({
                                icon: 'warning',
                                html: data.mensagem
                            });
                        } else {
                            location.reload(true);
                        }
                    }, 200);
                });
            }, 750);
        }
    </script>
</body>
</html>
