@using AriD.BibliotecaDeClasses.Entidades
@using AriD.BibliotecaDeClasses.Enumeradores
@using AriD.BibliotecaDeClasses.ParametrosDeConsulta
@using AriD.GerenciamentoDePonto.WebGrid
@using AriD.Servicos.Extensao
@using Newtonsoft.Json
@using AriD.BibliotecaDeClasses.Enumeradores.Permissao

@model ListaPaginada<Veiculo>
@{
    var additionalParams = JsonConvert.DeserializeObject<ParametrosConsultaUnidadesOrganizacionais>(Model.Adicional);
}

<div class="row">
    <div class="col col-lg-8 col-md-10 mt-1 col-xs-9">
        <h5>Veículos</h5>
    </div>
    <div class="col col-lg-4 col-md-2 mt-1 col-xs-3 float-end">
        @if (Context.PossuiPermissao(eItemDePermissao_Veiculo.CadastrarOuAlterar))
        {
            <button type="button" class="btn btn-primary float-end" onclick="abrirModal(0)">
                <span class="d-none d-sm-inline">+&nbsp;Adicionar</span>
            </button>
        }
    </div>
</div>

<div class="card mb-6 mb-3 p-4">
    <div class="row">
        <div class="col-lg-3 col-md-4">
            <label class="form-label" for="FiltroSituacao">Situação</label>
            <select id="FiltroSituacao" class="form-select filter-trigger">
                <option value="">Todas</option>
                @foreach (eStatusVeiculo opt in Enum.GetValues(typeof(eStatusVeiculo)))
                {
                    <option value="@opt">@opt.DescricaoDoEnumerador()</option>
                }
            </select>
        </div>
        <div class="col-lg-3 col-md-4">
            <label class="form-label" for="FiltroTipoCombustivel">Combustível</label>
            <select id="FiltroTipoCombustivel" class="form-select filter-trigger">
                <option value="">Todos</option>
                @foreach (eTipoCombustivel opt in Enum.GetValues(typeof(eTipoCombustivel)))
                {
                    <option value="@opt">@opt.DescricaoDoEnumerador()</option>
                }
            </select>
        </div>
        <div class="col-lg-6 col-md-12">
            <label class="form-label">&nbsp;</label>
            <div class="input-group input-group-merge">
                <input type="text"
                       class="form-control filter-trigger"
                       placeholder="Pesquisar por placa, marca ou modelo..."
                       aria-label="Pesquisar..."
                       aria-describedby="basic-addon-search31"
                       id="TermoDeBusca" />
                <button class="btn btn-primary" id="btn-pesquisar" type="button" onclick="aplicarFiltrosVeiculo()">
                    <i class='bx bx-search-alt'></i> Pesquisar
                </button>
            </div>
        </div>
    </div>
</div>

<div class="card" style="padding: 10px">
    @Html.Hidden("Adicional", Model.Adicional)
    <div id="grid">
        @await Html.PartialAsync("_TabelaPaginada", Model)
    </div>
</div>

<div id="div-modal"></div>

<script src="/Scripts/Paginas/Veiculo/index.js?t=@DateTime.Now.Ticks"></script>
