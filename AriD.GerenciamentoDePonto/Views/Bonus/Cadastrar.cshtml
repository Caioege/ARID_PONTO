@model ConfiguracaoBonus

<div class="card mb-6">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="bx bx-edit"></i> @(Model.Id > 0 ? "Alterar" : "Cadastrar") Configuração de Bônus
        </h5>
    </div>
    <div class="card-body">
        @using (Html.BeginForm("Cadastrar", "Bonus", FormMethod.Post, new { id = "formBonus" }))
        {
            @Html.HiddenFor(m => m.Id)
            @Html.HiddenFor(m => m.Ativo)

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label">Descrição</label>
                    @Html.TextBoxFor(m => m.Descricao, new { @class = "form-control", @required = "required", @placeholder = "Ex: Vale Alimentação" })
                </div>
                <div class="col-md-3">
                    <label class="form-label">Tipo de Bônus</label>
                    @Html.DropDownListFor(m => m.TipoBonus, Html.GetEnumSelectList<AriD.BibliotecaDeClasses.Enumeradores.eTipoBonus>(), new { @class = "form-select", @onchange = "toggleTipos()" })
                </div>
                <div class="col-md-3">
                    <label class="form-label">Valor (Diário ou Total)</label>
                    <div class="input-group">
                        <span class="input-group-text">R$</span>
                        @Html.TextBoxFor(m => m.ValorDiario, new { @class = "form-control", @required = "required", @type = "number", @step = "0.01", @min = "0.01" })
                    </div>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-12">
                    <label class="form-label">Limitar as Funções (Cargos)? (Deixe nulo para aplicar a todos)</label>
                    <select name="FuncoesIds" id="FuncoesIds" class="form-select select2" multiple="multiple" data-placeholder="Selecione as funções elegíveis">
                        @foreach (var funcao in ViewBag.Funcoes as List<AriD.BibliotecaDeClasses.Entidades.Funcao>)
                        {
                            var selected = Model.Funcoes.Any(f => f.FuncaoId == funcao.Id) ? "selected" : "";
                            <option value="@funcao.Id" @selected>@funcao.Descricao</option>
                        }
                    </select>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 divDiario">
                    <div class="form-check form-switch mt-4">
                        @Html.CheckBoxFor(m => m.PagaEmFinaisDeSemanaEFeriados, new { @class = "form-check-input" })
                        <label class="form-check-label">Paga em FDS e Feriados?</label>
                    </div>
                </div>
                <div class="col-md-4 divDiario">
                    <div class="form-check form-switch mt-4">
                        @Html.CheckBoxFor(m => m.TurnoIntercaladoPagaDobrado, new { @class = "form-check-input", onchange = "toggleTolerancia()" })
                        <label class="form-check-label">Turno Intercalado (Dobro)?</label>
                    </div>
                </div>
                <div id="divTolerancia" class="col-md-4 divDiario" style="display: @(Model.TurnoIntercaladoPagaDobrado ? "block" : "none")">
                    <label class="form-label">Min. Intervalo p/ Dobro</label>
                    @Html.TextBoxFor(m => m.MinutosIntervaloTurnoIntercalado, new { @class = "form-control", @type = "number", @min = "1" })
                </div>
                <div class="col-md-4 divMensal" style="display: none;">
                    <div class="form-check form-switch mt-4">
                        @Html.CheckBoxFor(m => m.PerdeIntegralmenteComFalta, new { @class = "form-check-input" })
                        <label class="form-check-label">Perde TUDO com 1 Falta?</label>
                    </div>
                </div>
            </div>

            <hr />

            <div class="d-flex justify-content-end gap-2">
                <button type="button" class="btn btn-outline-secondary" onclick="CarregarPagina('@Url.Action("Index")')">
                    <i class="bx bx-x"></i> Cancelar
                </button>
                <button type="submit" class="btn btn-primary">
                    <i class="bx bx-save"></i> Salvar
                </button>
            </div>
        }
    </div>
</div>

<script>
    function toggleTolerancia() {
        if ($('#TurnoIntercaladoPagaDobrado').is(':checked')) {
            $('#divTolerancia').fadeIn();
        } else {
            $('#divTolerancia').fadeOut();
        }
    }

    function toggleTipos() {
        if ($('#TipoBonus').val() == '1') { // Diario
            $('.divDiario').fadeIn();
            $('.divMensal').hide();
        } else {
            $('.divDiario').hide();
            $('.divMensal').fadeIn();
        }
    }

    $(document).ready(function() {
        toggleTipos();
        $('.select2').select2({
            width: '100%'
        });
    });
</script>
