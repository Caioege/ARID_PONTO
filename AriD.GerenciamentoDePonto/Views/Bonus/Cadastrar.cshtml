@using AriD.BibliotecaDeClasses.Entidades
@model ConfiguracaoBonus
@{
    ViewBag.Title = "Cadastrar Bônus";
    Layout = "~/Views/Shared/_LayoutListagem.cshtml";
}

<div class="row">
    <div class="col-xs-12 col-sm-7 col-md-7 col-lg-4">
        <h1 class="page-title txt-color-blueDark">
            <i class="fa fa-money fa-fw "></i> Bônus <span>> Cadastrar </span>
        </h1>
    </div>
</div>

<section id="widget-grid" class="">
    <div class="row">
        <article class="col-sm-12 col-md-12 col-lg-12">
            <div class="jarviswidget jarviswidget-color-blueDark" id="wid-id-1" data-widget-colorbutton="false" data-widget-editbutton="false" data-widget-custombutton="false">
                <header>
                    <span class="widget-icon"> <i class="fa fa-edit"></i> </span>
                    <h2>Formulário de Bônus</h2>
                </header>

                <div>
                    <div class="widget-body no-padding">
                        <form id="smart-form-register" action="@Url.Action("Cadastrar", "Bonus")" method="post" class="smart-form">
                            <fieldset>
                                <div class="row">
                                    <section class="col col-6">
                                        <label class="label">Descrição (Ex: Vale Transporte) <span style="color: red">*</span></label>
                                        <label class="input">
                                            <input type="text" name="Descricao" required value="@Model.Descricao" placeholder="Digite a descrição">
                                        </label>
                                    </section>
                                    <section class="col col-6">
                                        <label class="label">Valor Diário (R$) <span style="color: red">*</span></label>
                                        <label class="input">
                                            <input type="number" step="0.01" name="ValorDiario" required value="@Model.ValorDiario" placeholder="Ex: 30.50">
                                        </label>
                                    </section>
                                </div>

                                <div class="row">
                                    <section class="col col-6">
                                        <label class="checkbox">
                                            <input type="checkbox" name="PagaEmFinaisDeSemanaEFeriados" value="true" @(Model.PagaEmFinaisDeSemanaEFeriados ? "checked" : "")>
                                            <i></i> Paga bônus aos Finais de Semana e Feriados?
                                        </label>
                                    </section>
                                    <section class="col col-6">
                                        <label class="checkbox">
                                            <input type="checkbox" name="TurnoIntercaladoPagaDobrado" value="true" @(Model.TurnoIntercaladoPagaDobrado ? "checked" : "")>
                                            <i></i> Turno Intercalado (intervalo &gt; 2h) paga bônus em dobro no dia?
                                        </label>
                                    </section>
                                </div>
                            </fieldset>

                            <footer>
                                <button type="submit" class="btn btn-primary">Salvar</button>
                                <a href="@Url.Action("Index", "Bonus")" class="btn btn-default">Voltar</a>
                            </footer>
                        </form>
                    </div>
                </div>
            </div>
        </article>
    </div>
</section>
