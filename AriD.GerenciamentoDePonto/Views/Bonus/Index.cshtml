@using AriD.BibliotecaDeClasses.Entidades
@model AriD.GerenciamentoDePonto.WebGrid.ListaPaginada<ConfiguracaoBonus>
@{
    ViewBag.Title = "Configurações de Bônus (VT/VA)";
    Layout = "~/Views/Shared/_LayoutListagem.cshtml";
}

<div class="row">
    <div class="col-xs-12 col-sm-7 col-md-7 col-lg-4">
        <h1 class="page-title txt-color-blueDark">
            <i class="fa fa-fw fa-money"></i> Bônus (VT/VA) <span>> Configurações</span>
        </h1>
    </div>
</div>

<section id="widget-grid" class="">
    <div class="row">
        <article class="col-xs-12 col-sm-12 col-md-12 col-lg-12">
            <div class="jarviswidget jarviswidget-color-blueDark">
                <header>
                    <span class="widget-icon"> <i class="fa fa-table"></i> </span>
                    <h2>Lista de Regras e Bônus</h2>
                    <div class="widget-toolbar">
                        <a href="@Url.Action("Cadastrar", "Bonus")" class="btn btn-success"><i class="fa fa-plus"></i> Novo Bônus</a>
                    </div>
                </header>
                <div>
                    <div class="widget-body">
                        <div class="table-responsive">
                            <table class="table table-striped table-bordered table-hover" width="100%">
                                <thead>
                                    <tr>
                                        <th>Descrição</th>
                                        <th>Valor Diário</th>
                                        <th>Paga em FDS/Feriado?</th>
                                        <th>Turno Intercalado Dobrado?</th>
                                        <th>Status</th>
                                        <th>Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model != null && Model.Itens.Count > 0)
                                    {
                                        foreach (var item in Model.Itens)
                                        {
                                            <tr>
                                                <td>@item.Descricao</td>
                                                <td>@item.ValorDiario.ToString("C")</td>
                                                <td>@(item.PagaEmFinaisDeSemanaEFeriados ? "Sim" : "Não")</td>
                                                <td>@(item.TurnoIntercaladoPagaDobrado ? "Sim" : "Não")</td>
                                                <td>@(item.Ativo ? "Ativo" : "Inativo")</td>
                                                <td>
                                                    <button class="btn btn-primary btn-xs" onclick="ApurarMes(@item.Id)"><i class="fa fa-calculator"></i> Apurar Mês Atual</button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr><td colspan="6" class="text-center">Nenhuma configuração de bônus encontrada.</td></tr>
                                    }
                                </tbody>
                            </table>
                            @await Html.PartialAsync("_PaginacaoWebGrid", Model)
                        </div>
                    </div>
                </div>
            </div>
        </article>
    </div>
</section>

@section pagespecific {
    <script>
        function ApurarMes(id) {
            Swal.fire({
                title: 'Apurar Bônus Mês Atual?',
                text: "Isso vai calcular as presenças e gerar relatórios de recebimento para cada servidor da instituição.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Sim, calcular!',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    var mesAnoStr = new Date().getMonth() + 1 + "/" + new Date().getFullYear();
                    $.post('/Bonus/ProcessarCalculoDoMes', { configuracaoBonusId: id, mesReferencia: mesAnoStr }, function(res) {
                        if(res.sucesso){
                            Swal.fire('Processado', res.mensagem, 'success');
                        }else{
                            Swal.fire('Erro', res.mensagem, 'error');
                        }
                    });
                }
            });
        }
    </script>
}
