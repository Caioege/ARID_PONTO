@using AriD.BibliotecaDeClasses.Entidades
@using AriD.BibliotecaDeClasses.Enumeradores.Permissao
@model Rota

@{
    var adicionar = Model.Id == 0;
    var podeRemover = Context.PossuiPermissao(eItemDePermissao_Rota.Excluir);
    var podeAlterar = Context.PossuiPermissao(eItemDePermissao_Rota.CadastrarOuAlterar);
}

<div class="modal" tabindex="-1" id="_Modal" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@(adicionar ? "Adicionar" : "Alterar") Rota</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <ul class="nav nav-tabs mb-3" role="tablist">
                  <li class="nav-item">
                    <button type="button" class="nav-link active" role="tab" data-bs-toggle="tab" data-bs-target="#tab-dados" aria-controls="tab-dados" aria-selected="true">Dados Principais</button>
                  </li>
                  @if(!adicionar)
                  {
                      <li class="nav-item">
                        <button type="button" class="nav-link" role="tab" data-bs-toggle="tab" data-bs-target="#tab-execucoes" aria-controls="tab-execucoes" aria-selected="false" onclick="carregarHistoricoExecucoes()">Histórico de Execuções</button>
                      </li>
                  }
                </ul>

                <div class="tab-content" style="padding: 0; box-shadow: none; border: none; background: transparent;">
                    <div class="tab-pane fade show active" id="tab-dados" role="tabpanel">
                        <form id="formulario-rota">
                            @Html.HiddenFor(model => model.Id)
                            
                            <div class="row">
                                <div class="col col-lg-5 col-md-12 col-sm-12">
                                    <label class="form-label obrigatorio" for="Descricao">Descrição / Titulo da Rota</label>
                                    @Html.TextBoxFor(model => model.Descricao, new { @class = "form-control", @maxlength = "100" })
                                </div>
                                <div class="col col-lg-4 col-md-12 col-sm-12">
                                    <label class="form-label obrigatorio" for="MotoristaId">Motorista</label>
                                    @Html.DropDownListFor(model => model.MotoristaId, (SelectList)ViewBag.Motoristas, "Selecione o Motorista", new { @class = "form-select select2" })
                                </div>

                                <div class="col col-lg-3 col-md-12 col-sm-12 float-end">
                                    <label class="form-label obrigatorio" for="Situacao">Situação</label>
                                    @Html.EnumDropDownListFor(model => model.Situacao, new { @class = "form-select" })
                                </div>
                            </div>

                            <div class="row mt-2">
                                <div class="col col-lg-4 col-md-12 col-sm-12">
                                    <label class="form-label" for="VeiculoId">Veículo (Opcional)</label>
                                    @Html.DropDownListFor(model => model.VeiculoId, (SelectList)ViewBag.Veiculos, "Selecione o Veículo", new { @class = "form-select select2" })
                                </div>
                                <div class="col col-lg-4 col-md-12 col-sm-12 align-self-end text-center p-2 border rounded" style="background-color: #f8f9fa;">
                                    <div class="form-check form-switch d-inline-block">
                                        @Html.CheckBoxFor(model => model.Recorrente, new { @class = "form-check-input" })
                                        <label class="form-check-label ms-2 font-weight-bold" for="Recorrente">Rota Recorrente?</label>
                                    </div>
                                </div>
                            </div>

                    <hr />
                    <h6>Pontos de Parada</h6>
                    
                    <div class="row mt-2 mb-3 align-items-end">
                        <div class="col col-lg-4">
                            <label class="form-label" for="novaParadaEndereco">Endereço/Local</label>
                            <input type="text" class="form-control" id="novaParadaEndereco" placeholder="Ex: Rua A, 123" />
                        </div>
                        <div class="col col-lg-3">
                            <label class="form-label" for="novaParadaLink">Geo Link (Opcional)</label>
                            <input type="text" class="form-control" id="novaParadaLink" placeholder="Google maps link..." />
                        </div>
                        <div class="col col-lg-3">
                            <label class="form-label" for="novaParadaObs">Observação (Opcional)</label>
                            <input type="text" class="form-control" id="novaParadaObs" placeholder="Ex: Cuidado com o cachorro" />
                        </div>
                        <div class="col col-lg-2">
                           <button type="button" class="btn btn-primary w-100" id="btn-adicionar-parada">
                               <i class='bx bx-plus'></i> Adicionar
                           </button>
                        </div>
                    </div>

                    <div class="table-responsive text-nowrap mt-2" style="max-height: 300px; overflow-y: auto;">
                        <table class="table table-bordered table-sm" id="tabela-paradas">
                            <thead>
                                <tr>
                                    <th>Endereço/Local</th>
                                    <th>Link Mapa</th>
                                    <th>Observação</th>
                                    <th>Situação</th>
                                    <th width="50px"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if(Model.Paradas != null)
                                {
                                    foreach(var p in Model.Paradas)
                                    {
                                        <tr data-id="@p.Id" data-entregue="@(p.Entregue ? "true" : "false")"
                                            data-endereco="@p.Endereco" data-link="@p.Link" data-obs="@p.Observacao">
                                            <td>@p.Endereco</td>
                                            <td>@p.Link</td>
                                            <td>@p.Observacao</td>
                                            <td>
                                                @if(p.Entregue) { <span class="badge bg-success">Entregue/Concluído</span> } else { <span class="badge bg-secondary">Pendente</span> }
                                            </td>
                                            <td>
                                                <button type="button" class="btn btn-sm btn-icon btn-danger btn-remover-parada" onclick="removerLinhaParada(this)"><i class='bx bx-trash'></i></button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                        </form>
                    </div>

                    @if(!adicionar)
                    {
                        <div class="tab-pane fade" id="tab-execucoes" role="tabpanel">
                            <div class="table-responsive" style="max-height: 250px; overflow-y: auto;">
                                <table class="table table-sm table-bordered" id="tabela-historico-execucoes">
                                    <thead>
                                        <tr>
                                            <th>Início</th>
                                            <th>Usr. Início</th>
                                            <th>Fim</th>
                                            <th>Usr. Fim</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr><td colspan="4" class="text-center"><i class="bx bx-loader bx-spin"></i> Carregando...</td></tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="modal-footer mt-3">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class='bx bx-window-close'></i> Fechar
                </button>

                @if (Model.Id > 0 && podeRemover)
                {
                    <button type="button" class="btn btn-danger" onclick="removerRegistro()">
                        <i class='bx bx-trash'></i> Remover
                    </button>
                }

                @if (podeAlterar)
                {
                    <button type="button" class="btn btn-primary" id="btn-salvar-modal">
                        <i class='bx bxs-save'></i> Salvar
                    </button>
                }
            </div>
        </div>
    </div>
</div>

<script>
    if (typeof inicializarSelects === 'function') {
        inicializarSelects();
    }
</script>
