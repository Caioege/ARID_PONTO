@{
    ViewBag.Title = "Monitoramento - Gestão Mobile";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

<style>
    /* Styling for full page map and glassmorphism filters */
    body, html { margin: 0; padding: 0; height: 100%; }
    #monitoramento-wrapper {
        position: relative;
        height: calc(100vh - 120px); 
        width: 100%;
        border-radius: 8px;
        overflow: hidden;
    }
    #map {
        width: 100%;
        height: 100%;
        z-index: 1;
    }
    
    .map-overlay {
        position: absolute;
        top: 20px;
        right: 20px;
        z-index: 1000;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.37);
        width: 320px;
        transition: all 0.3s ease;
    }

    .map-overlay.collapsed {
        height: 60px;
        overflow: hidden;
    }

    .filter-group {
        margin-bottom: 15px;
    }

    .filter-group label {
        font-weight: 600;
        color: #333;
        display: block;
        margin-bottom: 5px;
        font-size: 0.9em;
    }
    
    .map-overlay-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
        cursor: pointer;
    }

    .map-overlay-header h5 {
        margin: 0;
        color: #2c3e50;
        font-weight: bold;
    }

    .toggle-overlay-btn {
        background: none;
        border: none;
        color: #666;
        cursor: pointer;
    }

    .status-indicador {
        position: absolute;
        bottom: 20px;
        left: 20px;
        z-index: 1000;
        background: rgba(255, 255, 255, 0.9);
        padding: 10px 15px;
        border-radius: 20px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        font-size: 0.85em;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .pulse {
        width: 10px;
        height: 10px;
        background-color: #2ecc71;
        border-radius: 50%;
        animation: pulse-animation 2s infinite;
    }

    @@keyframes pulse-animation {
        0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(46, 204, 113, 0.7); }
        70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(46, 204, 113, 0); }
        100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(46, 204, 113, 0); }
    }

    .popup-content strong {
        color: #2980b9;
    }

    .leaflet-popup-content-wrapper {
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2) !important;
    }

    /* Animação para o trajeto (Impressão de movimento) */
    .animated-route {
        stroke-dasharray: 10, 15;
        animation: route-dash 20s linear infinite;
    }
    
    @@keyframes route-dash {
        to {
            stroke-dashoffset: -1000;
        }
    }

    /* Estilo do Marcador de Parada */
    .parada-marker {
        background: #fff;
        border: 2px solid #e74c3c;
        border-radius: 50%;
        text-align: center;
        line-height: 20px;
        color: #e74c3c;
        font-weight: bold;
        font-size: 14px;
        box-shadow: 0 3px 6px rgba(0,0,0,0.3);
    }
    .parada-marker.entregue {
        border-color: #2ecc71;
        color: #2ecc71;
    }
</style>

<div class="row mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Monitoramento em Tempo Real - Gestão Mobile</h5>
            </div>
            <div class="card-body p-0">
                <div id="monitoramento-wrapper">
                    <div id="map"></div>
                    
                    <div class="status-indicador">
                        <div class="pulse"></div>
                        <span id="ultima-sincronizacao">Sincronizando...</span>
                    </div>

                    <div class="map-overlay" id="filtros-overlay">
                        <div class="map-overlay-header" onclick="toggleFiltros()">
                            <h5><i class="bx bx-filter-alt"></i> Filtros</h5>
                            <button class="toggle-overlay-btn"><i class="bx bx-chevron-up" id="toggle-icon"></i></button>
                        </div>
                        <div id="filtros-content">
                            <div class="filter-group">
                                <label for="M_FiltroRota">Rota</label>
                                @Html.DropDownList("M_FiltroRota", ViewBag.Rotas as SelectList, "Todas", new { @class = "form-select form-select-sm" })
                            </div>
                            <div class="filter-group">
                                <label for="M_FiltroMotorista">Motorista</label>
                                @Html.DropDownList("M_FiltroMotorista", ViewBag.Motoristas as SelectList, "Todos", new { @class = "form-select form-select-sm" })
                            </div>
                            <div class="filter-group">
                                <label for="M_FiltroVeiculo">Veículo</label>
                                @Html.DropDownList("M_FiltroVeiculo", ViewBag.Veiculos as SelectList, "Todos", new { @class = "form-select form-select-sm" })
                            </div>
                            <button class="btn btn-primary btn-sm w-100 mt-2" onclick="aplicarFiltrosMap()">Aplicar Filtros</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    var mapLatCentro = @ViewBag.LatCentro;
    var mapLonCentro = @ViewBag.LonCentro;
</script>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script src="~/Scripts/Paginas/Rota/monitoramento.js?v=@(DateTime.Now.Ticks)"></script>
