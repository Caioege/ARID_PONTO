@using AriD.BibliotecaDeClasses.Entidades
@using AriD.BibliotecaDeClasses.Enumeradores.Permissao
@model Rota

@{
    var adicionar = Model.Id == 0;
    var podeRemover = Context.PossuiPermissao(eItemDePermissao_Rota.Excluir);
    var podeAlterar = Context.PossuiPermissao(eItemDePermissao_Rota.CadastrarOuAlterar);
}

<div class="row mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">@(adicionar ? "Nova" : "Alterar") Rota</h5>
            </div>
            <div class="card-body">
                <ul class="nav nav-tabs mb-3" role="tablist">
                  <li class="nav-item">
                    <button type="button" class="nav-link active" role="tab" data-bs-toggle="tab" data-bs-target="#tab-dados" aria-controls="tab-dados" aria-selected="true">Dados Principais</button>
                  </li>
                  <li class="nav-item">
                    <button type="button" class="nav-link" role="tab" data-bs-toggle="tab" data-bs-target="#tab-pacientes" aria-controls="tab-pacientes" aria-selected="false">Pacientes e Acompanhantes</button>
                  </li>
                  <li class="nav-item">
                    <button type="button" class="nav-link" role="tab" data-bs-toggle="tab" data-bs-target="#tab-profissionais" aria-controls="tab-profissionais" aria-selected="false">Equipe/Profissionais</button>
                  </li>
                  @if(!adicionar)
                  {
                      <li class="nav-item">
                        <button type="button" class="nav-link" role="tab" data-bs-toggle="tab" data-bs-target="#tab-execucoes" aria-controls="tab-execucoes" aria-selected="false" onclick="carregarHistoricoExecucoes()">Histórico de Execuções</button>
                      </li>
                  }
                </ul>

                <div class="tab-content" style="padding: 0; box-shadow: none; border: none; background: transparent;">
                    <div class="tab-pane fade show active" id="tab-dados" role="tabpanel">
                        <form id="formulario-rota">
                            @Html.HiddenFor(model => model.Id)
                            
                            <div class="row">
                                <div class="col col-lg-5 col-md-12 col-sm-12">
                                    <label class="form-label obrigatorio" for="Descricao">Descrição / Titulo da Rota</label>
                                    @Html.TextBoxFor(model => model.Descricao, new { @class = "form-control", @maxlength = "100" })
                                </div>

                                <div class="col col-lg-4 col-md-12 col-sm-12">
                                    <label class="form-label obrigatorio" for="Recorrente">Recorrente</label>
                                    @Html.CheckboxDropDownListFor(model => model.Recorrente, new { @class = "form-select" })
                                </div>

                                <div class="col col-lg-3 col-md-12 col-sm-12 float-end">
                                    <label class="form-label obrigatorio" for="Situacao">Situação</label>
                                    @Html.EnumDropDownListFor(model => model.Situacao, new { @class = "form-select" })
                                </div>
                            </div>

                            <div class="row mt-2">
                                <div class="col col-lg-6 col-md-12 col-sm-12">
                                    <label class="form-label obrigatorio" for="MotoristaId">Motorista Principal</label>
                                    @Html.DropDownListFor(model => model.MotoristaId, (SelectList)ViewBag.Motoristas, string.Empty, new { @class = "select2" })
                                </div>

                                <div class="col col-lg-6 col-md-12 col-sm-12">
                                    <label class="form-label" for="veiculosSelecionados">Veículos Associados (Opcional)</label>
                                    @Html.ListBox("veiculosSelecionados", (MultiSelectList)ViewBag.Veiculos, new { @class = "select2", multiple = "multiple", data_placeholder = "Selecione os veículos..." })
                                </div>
                            </div>
                            
                            <div class="row mt-2">
                                <div class="col col-lg-12 col-md-12 col-sm-12">
                                    <label class="form-label" for="UnidadeDestinoId">Unidade de Destino (TSP Checkpoint)</label>
                                    @Html.DropDownListFor(model => model.UnidadeDestinoId, (SelectList)ViewBag.UnidadesDestino, "Selecione a Unidade Base...", new { @class = "select2" })
                                </div>
                            </div>

                            <div class="row mt-2" id="box-rota-especifica" style="display:none; padding:10px; background-color: #f9f9f9; border-radius: 4px; border: 1px solid #1abc9c38; justify-content: center; align-items: center;">
                                <div class="col col-lg-3 col-md-12 col-sm-12">
                                    <label class="form-label obrigatorio" for="DataParaExecucao">Data da Execução</label>
                                    @Html.TextBoxFor(model => model.DataParaExecucao, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                                </div>
                                <div class="col col-lg-9 col-md-12 col-sm-12">
                                    <div class="alert alert-info py-2 mb-0" role="alert">
                                      <i class="bx bx-info-circle me-1"></i> Pacientes e Médicos agora devem ser adicionados nas suas <strong>abas específicas correspondentes</strong> acima para suportar múltiplas seleções na Gestão Mobile.
                                    </div>
                                </div>
                            </div>

                            <div class="row mt-2">
                                <div class="col-12">
                                    <label class="form-label" for="Observacao">Observações Gerais da Rota</label>
                                    @Html.TextAreaFor(model => model.Observacao, new { @class = "form-control", rows = "2", placeholder = "Informações relevantes para o motorista ou equipe..." })
                                </div>
                            </div>

                            <hr class="mt-4 mb-3" />
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="mb-0 text-primary"><i class='bx bx-map-pin'></i> Pontos de Parada Espaciais</h6>
                                <button type="button" class="btn btn-sm btn-outline-info" id="btn-preview-rota">
                                    <i class='bx bx-git-branch'></i> Visualizar Rota Prevista TSP
                                </button>
                            </div>
                            
                            <div class="row mt-2 mb-3 align-items-end">
                                <div class="col col-lg-3">
                                    <label class="form-label" for="novaParadaEndereco">Endereço/Local</label>
                                    <input type="text" class="form-control" id="novaParadaEndereco" placeholder="Ex: Rua A, 123" />
                                </div>
                                <div class="col col-lg-3">
                                    <label class="form-label" for="novaParadaLat">Latitude (Opcional - GeoTSP)</label>
                                    <input type="text" class="form-control" id="novaParadaLat" placeholder="-00.00000" />
                                </div>
                                <div class="col col-lg-3">
                                    <label class="form-label" for="novaParadaLng">Longitude (Opcional - GeoTSP)</label>
                                    <input type="text" class="form-control" id="novaParadaLng" placeholder="-00.00000" />
                                </div>
                                <div class="col col-lg-2">
                                    <label class="form-label" for="novaParadaObs">Observação</label>
                                    <input type="text" class="form-control" id="novaParadaObs" placeholder="Aptidões, avisos..." />
                                </div>
                                 <div class="col col-lg-1">
                                    <button type="button" class="btn btn-primary w-100" id="btn-adicionar-parada" onclick="adicionarParadaManualmente()">
                                        <i class='bx bx-plus'></i> 
                                    </button>
                                 </div>
                            </div>

                            <div class="table-responsive text-nowrap mt-2" style="max-height: 350px; overflow-y: auto;">
                                <table class="table table-bordered table-sm" id="tabela-paradas">
                                    <thead>
                                        <tr>
                                            <th>Ordem Sugerida</th>
                                            <th>Endereço/Localização</th>
                                            <th>Coordenadas GPS</th>
                                            <th width="15%">Observação</th>
                                            @if (Model.Recorrente)
                                            {
                                                <th width="10%">Situação</th>
                                            }
                                            <th width="50px"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if(Model.Paradas != null && Model.Paradas.Any())
                                        {
                                            foreach(var p in Model.Paradas.OrderBy(x => x.Ordem))
                                            {
                                                <tr data-id="@p.Id" data-entregue="@(p.Entregue ? "true" : "false")"
                                                    data-endereco="@p.Endereco" data-lat="@p.Latitude" data-lng="@p.Longitude" data-link="@p.Link" data-obs="@p.Observacao">
                                                    <td class="text-center font-weight-bold">
                                                        <span class="badge bg-label-primary rounded-circle p-2">@(p.Ordem + 1)</span>
                                                    </td>
                                                    <td>
                                                        @p.Endereco
                                                        @if(!string.IsNullOrEmpty(p.Link)){ <br /><a target="_blank" href="@p.Link" style="color: #0000ffb5; text-decoration: underline;">Ext Link</a> }
                                                    </td>
                                                    <td>
                                                        @if(!string.IsNullOrEmpty(p.Latitude)) { <code class="small text-muted">@p.Latitude, @p.Longitude</code> } else { <span class="text-warning small"><i class="bx bx-error"></i> Geofence Offline</span> }
                                                    </td>
                                                    <td>@p.Observacao</td>
                                                    @if (Model.Recorrente)
                                                    {
                                                        <td>
                                                            @if(p.Entregue) { <span class="badge bg-success">Concluído</span> } else { <span class="badge bg-secondary">Pendente</span> }
                                                        </td>
                                                    }
                                                    <td>
                                                        <button type="button" class="btn btn-sm btn-icon btn-danger btn-remover-parada"><i class='bx bx-trash'></i></button>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else 
                                        {
                                            <tr id="empty-paradas-tr"><td colspan="6" class="text-center text-muted">Ainda não há paradas registradas na Rota.</td></tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <!-- PREVIEW AREA MAP -->
                            <div id="preview-map-container" style="display: none; height: 400px; width: 100%; margin-top: 15px; border-radius: 8px; border: 2px solid #3498db;"></div>

                        </form>
                    </div>

                    <div class="tab-pane fade" id="tab-pacientes" role="tabpanel">
                        <div class="row mb-3 mt-2" id="area-novo-paciente" style="display:none; background-color: #f0f3f5; padding: 15px; border-radius: 8px;">
                            <div class="col-md-5">
                                <label class="form-label">Nome Completo</label>
                                <input type="text" id="novo-paciente-nome" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">CPF</label>
                                <input type="text" id="novo-paciente-cpf" class="form-control cpf" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Telefone</label>
                                <input type="text" id="novo-paciente-telefone" class="form-control telefone" />
                            </div>
                            <div class="col-md-2 d-flex align-items-end">
                                <button type="button" class="btn btn-success w-100" onclick="salvarPacienteNovo()">
                                    <i class='bx bx-check'></i> Salvar
                                </button>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-8">
                                <div class="d-flex justify-content-between">
                                    <label class="form-label">Selecionar Paciente</label>
                                    <a href="javascript:void(0)" onclick="$('#area-novo-paciente').slideToggle()" class="small text-primary">Não encontrou? Cadastrar Novo</a>
                                </div>
                                <select id="selecao-paciente" class="form-select select2-cadastro">
                                    <option value="">Selecione...</option>
                                    @foreach (var p in (List<Paciente>)ViewBag.PacientesDisponiveis)
                                    {
                                        <option value="@p.Id" data-nome="@p.Nome">@p.Nome (@p.CPF)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-2 d-flex flex-column justify-content-end">
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" id="paciente-possui-acompanhante">
                                    <label class="form-check-label" for="paciente-possui-acompanhante">C/ Acomp.</label>
                                </div>
                            </div>
                            <div class="col-md-2 d-flex align-items-end">
                                <button type="button" class="btn btn-primary w-100" onclick="adicionarPacienteLista()">
                                    <i class='bx bx-plus'></i>
                                </button>
                            </div>
                        </div>
                        <div class="table-responsive" style="max-height: 300px;">
                            <table class="table table-sm table-hover border" id="tabela-pacientes-selecionados">
                                <thead class="bg-light">
                                    <tr>
                                        <th>Nome</th>
                                        <th class="text-center">Acompanhante?</th>
                                        <th width="50px"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var rp in Model.ListaDePacientes)
                                    {
                                        <tr data-id="@rp.PacienteId" data-acompanhante="@(rp.PossuiAcompanhante ? "true" : "false")">
                                            <td>@rp.Paciente.Nome</td>
                                            <td class="text-center">@(rp.PossuiAcompanhante ? "Sim" : "Não")</td>
                                            <td class="text-center">
                                                <button type="button" class="btn btn-xs btn-icon btn-outline-danger" onclick="removerLinha(this)"><i class='bx bx-trash'></i></button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="tab-profissionais" role="tabpanel">
                        <div class="row mb-3">
                            <div class="col-md-10">
                                <label class="form-label">Selecionar Profissional (Saúde/Educação)</label>
                                <select id="selecao-profissional" class="form-select select2-cadastro" onchange="aoMudarProfissional()">
                                    <option value="">Selecione...</option>
                                    @foreach (var s in (dynamic)ViewBag.ProfissionaisDisponiveis)
                                    {
                                        <option value="@s.Id" data-nome="@s.Nome" data-cargo="@s.Cargo" data-crm="@s.CRM" data-especialidade="@s.Especialidade">@s.Nome (@s.Cargo)</option>
                                    }
                                </select>
                                <div id="info-medico-selecionado" class="mt-2 small text-info" style="display:none;">
                                    <i class="bx bx-id-card"></i> <strong>CRM:</strong> <span id="label-crm">-</span> | <strong>Especialidade:</strong> <span id="label-especialidade">-</span>
                                </div>
                            </div>
                            <div class="col-md-2 d-flex align-items-end">
                                <button type="button" class="btn btn-primary w-100" onclick="adicionarProfissionalLista()">
                                    <i class='bx bx-plus'></i> 
                                </button>
                            </div>
                        </div>
                        <div class="table-responsive" style="max-height: 300px;">
                            <table class="table table-sm table-hover border" id="tabela-profissionais-selecionados">
                                <thead class="bg-light">
                                    <tr>
                                        <th>Nome</th>
                                        <th>Cargo/Função</th>
                                        <th>CRM/Especialidade</th>
                                        <th width="50px"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var rp in Model.ListaDeProfissionais)
                                    {
                                        <tr data-id="@rp.ServidorId" data-crm="@rp.Servidor.CodigoCRM" data-especialidade="@rp.Servidor.EspecialidadeMedica">
                                            <td>@rp.Servidor.Pessoa.Nome</td>
                                            <td>@(rp.Servidor.VinculosDeTrabalho?.FirstOrDefault()?.Funcao?.Descricao ?? "Servidor")</td>
                                            <td>
                                                @if(!string.IsNullOrEmpty(rp.Servidor.CodigoCRM)) {
                                                    <span class="badge bg-label-info">CRM: @rp.Servidor.CodigoCRM</span>
                                                    <br/><small>@rp.Servidor.EspecialidadeMedica</small>
                                                } else {
                                                    <span>-</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <button type="button" class="btn btn-xs btn-icon btn-outline-danger" onclick="removerLinha(this)"><i class='bx bx-trash'></i></button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    @if(!adicionar)
                    {
                        <div class="tab-pane fade" id="tab-execucoes" role="tabpanel">
                            <div class="table-responsive" id="tabela-execucoes-container" style="max-height: 250px; overflow-y: auto;">
                                <table class="table table-sm table-bordered" id="tabela-historico-execucoes">
                                    <thead>
                                        <tr>
                                            <th>Início</th>
                                            <th>Usr. Início</th>
                                            <th>Fim</th>
                                            <th>Usr. Fim</th>
                                            <th width="100px">Ações</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr><td colspan="5" class="text-center"><i class="bx bx-loader bx-spin"></i> Carregando...</td></tr>
                                    </tbody>
                                </table>
                            </div>
                            
                            <div id="map-historico-container" style="display: none;">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="mb-0 text-primary"><i class="bx bx-map"></i> Rota Analisada pelo Histórico</h6>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="voltarParaHistorico()">
                                        <i class="bx bx-arrow-back"></i> Voltar p/ Lista
                                    </button>
                                </div>
                                <div id="map-historico" style="height: 350px; width: 100%; border-radius: 8px; border: 1px solid #ddd;"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="card-footer mt-3 d-flex justify-content-between">
                <div>
                     @if (Model.Id > 0 && podeRemover)
                    {
                        <button type="button" class="btn btn-danger" onclick="removerRegistroCadastro()">
                            <i class='bx bx-trash'></i> Remover
                        </button>
                    }
                </div>
                <div>
                    <button type="button" class="btn btn-secondary me-2" onclick="CarregarPagina('/Rota/Index')">
                        <i class='bx bx-arrow-back'></i> Voltar
                    </button>

                    @if (podeAlterar)
                    {
                        <button type="button" class="btn btn-primary" id="btn-salvar-cadastro">
                            <i class='bx bxs-save'></i> Salvar
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script src="/Scripts/Paginas/Rota/index.js?t=@DateTime.Now.Ticks"></script>
<script>
    if (typeof inicializarSelects === 'function') {
        inicializarSelects();
    }

    $(document).ready(function() {
        if ($.fn.select2) {
            $('.select2-cadastro').select2({
                width: '100%'
            });
            $('#MedicoResponsavel').select2({
                tags: true,
                placeholder: 'Selecione ou digite...'
            });
        }

        function toggleSpecificBox() {
            var val = String($('#Recorrente').val() || '').toLowerCase();
            var isNaoRecorrente = (val === 'false' || ($('#Recorrente').is('input[type=checkbox]') && !$('#Recorrente').is(':checked')));
            
            if (isNaoRecorrente) {
                $('#box-rota-especifica').slideDown();
            } else {
                $('#box-rota-especifica').slideUp();
                $('#DataParaExecucao').val('');
            }
        }
        $('#Recorrente').on('change', toggleSpecificBox);
        setTimeout(toggleSpecificBox, 200);
    });
</script>
