@using AriD.BibliotecaDeClasses.Entidades
@using AriD.BibliotecaDeClasses.Enumeradores
@using AriD.BibliotecaDeClasses.Enumeradores.Permissao
@using AriD.Servicos.Extensao
@model Rota

@{
    var adicionar = Model.Id == 0;
    var podeRemover = Context.PossuiPermissao(eItemDePermissao_Rota.Excluir);
    var podeAlterar = Context.PossuiPermissao(eItemDePermissao_Rota.CadastrarOuAlterar);
}

<div class="row mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">@(adicionar ? "Nova" : "Alterar") Rota</h5>
            </div>
            <div class="card-body">
                <ul class="nav nav-tabs mb-3" role="tablist">
                  <li class="nav-item">
                    <button type="button" class="nav-link active" role="tab" data-bs-toggle="tab" data-bs-target="#tab-dados" aria-controls="tab-dados" aria-selected="true">Geral</button>
                  </li>
                  <li class="nav-item">
                    <button type="button" class="nav-link" role="tab" data-bs-toggle="tab" data-bs-target="#tab-pacientes" aria-controls="tab-pacientes" aria-selected="false">Acompanhantes/Pacientes</button>
                  </li>
                  <li class="nav-item">
                    <button type="button" class="nav-link" role="tab" data-bs-toggle="tab" data-bs-target="#tab-profissionais" aria-controls="tab-profissionais" aria-selected="false">Equipe/Profissionais</button>
                  </li>
                  @if(!adicionar)
                  {
                      <li class="nav-item">
                        <button type="button" class="nav-link" role="tab" data-bs-toggle="tab" data-bs-target="#tab-execucoes" aria-controls="tab-execucoes" aria-selected="false" onclick="carregarHistoricoExecucoes()">Histórico de Execuções</button>
                      </li>
                  }
                </ul>

                <div class="tab-content" style="padding: 0; box-shadow: none; border: none; background: transparent;">
                    <div class="tab-pane fade show active" id="tab-dados" role="tabpanel">
                        <form id="formulario-rota">
                            @Html.HiddenFor(model => model.Id)
                            
                            <div class="row">
                                <div class="col col-lg-5 col-md-12 col-sm-12">
                                    <label class="form-label obrigatorio" for="Descricao">Descrição / Titulo da Rota</label>
                                    @Html.TextBoxFor(model => model.Descricao, new { @class = "form-control", @maxlength = "100" })
                                </div>

                                <div class="col col-lg-4 col-md-12 col-sm-12">
                                    <label class="form-label obrigatorio" for="Recorrente">Recorrente</label>
                                    @Html.CheckboxDropDownListFor(model => model.Recorrente, new { @class = "form-select" })
                                </div>

                                <div class="col col-lg-3 col-md-12 col-sm-12 float-end">
                                    <label class="form-label obrigatorio" for="Situacao">Situação</label>
                                    @Html.EnumDropDownListFor(model => model.Situacao, new { @class = "form-select" })
                                </div>
                            </div>
                            
                            <div class="row mt-2" style="background: #fdfdfd; padding: 10px; border-radius: 8px; border: 1px solid #e1e1e1;">
                                <div class="col-md-6 d-flex align-items-center">
                                    <div class="form-check form-switch mb-0 text-primary">
                                       @Html.CheckBoxFor(model => model.PermitePausa, new { @class = "form-check-input", @id = "PermitePausa" })
                                       <label class="form-check-label fw-bold" for="PermitePausa">Permite pausas durante a execução da rota?</label>
                                    </div>
                                </div>
                                <div class="col-md-6" id="box-quantidade-pausas" style="@(Model.PermitePausa ? "" : "display:none;")">
                                    <label class="form-label">Quantidade de paradas permitidas durante a execução</label>
                                    @Html.TextBoxFor(model => model.QuantidadePausas, new { @class = "form-control numeric", @type="number", min="0", step="1" })
                                </div>
                            </div>

                            <div class="row mt-2">
                                <div class="col-12 mb-2">
                                    <label class="form-label obrigatorio" for="MotoristaId">Motorista Principal</label>
                                    @Html.DropDownListFor(model => model.MotoristaId, (SelectList)ViewBag.Motoristas, string.Empty, new { @class = "select2" })
                                </div>

                                <div class="col-12 mb-2">
                                    <label class="form-label" for="MotoristaSecundarioId">Motorista Secundário (Opcional)</label>
                                    @Html.DropDownListFor(model => model.MotoristaSecundarioId, (SelectList)ViewBag.MotoristaSecundario, string.Empty, new { @class = "select2" })
                                </div>

                                <div class="col-12">
                                    <label class="form-label obrigatorio" for="veiculosSelecionados">Veículos Associados</label>
                                    @Html.ListBox("veiculosSelecionados", (MultiSelectList)ViewBag.Veiculos, new { @class = "select2", multiple = "multiple", data_placeholder = "Selecione os veículos..." })
                                </div>
                            </div>
                            

                            <div class="row mt-2" id="box-config-execucao" style="display:none; padding:15px; background-color: #f8f9fa; border-radius: 6px; border: 1px solid #dee2e6;">
                                <!-- Cenário 1: Rota Pontual (Não Recorrente) -->
                                <div id="col-data-especifica" class="col col-lg-3 col-md-12 col-sm-12">
                                    <label class="form-label obrigatorio" for="DataParaExecucao">Data da Execução</label>
                                    @Html.TextBoxFor(model => model.DataParaExecucao, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                                </div>

                                <!-- Cenário 2: Rota Recorrente com Período e Dias -->
                                <div id="col-periodo-recorrente" class="col col-lg-12 col-md-12 col-sm-12" style="display:none;">
                                    <div class="row">
                                        <div class="col-md-3">
                                            <label class="form-label obrigatorio" for="DataInicio">Data Início de Validade</label>
                                            @Html.TextBoxFor(model => model.DataInicio, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label" for="DataFim">Até (Data Fim - Opcional)</label>
                                            @Html.TextBoxFor(model => model.DataFim, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label d-block text-primary fw-bold">Dias de Atividade na Semana</label>
                                            <div class="d-flex justify-content-between flex-wrap bg-white p-2 border rounded">
                                                @foreach (var dia in Enum.GetValues(typeof(eFlagDiaSemana)).Cast<eFlagDiaSemana>().Where(d => d != eFlagDiaSemana.Nenhum))
                                                {
                                                    <div class="form-check">
                                                        <input class="form-check-input check-dia-semana" type="checkbox" id="dia_@((int)dia)" value="@((int)dia)" 
                                                               @(Model.DiasSemana != null && Model.DiasSemana.Value.HasFlag(dia) ? "checked" : "")>
                                                        <label class="form-check-label" for="dia_@((int)dia)">@dia.ToString().Substring(0, 3)</label>
                                                    </div>
                                                }
                                                @Html.HiddenFor(m => m.DiasSemana)
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row mt-2">
                                <div class="col-12">
                                    <label class="form-label" for="Observacao">Observações Gerais da Rota</label>
                                    @Html.TextAreaFor(model => model.Observacao, new { @class = "form-control", rows = "2", placeholder = "Informações relevantes para o motorista ou equipe..." })
                                </div>
                            </div>

                            <div class="row mt-4 mb-2 align-items-end" style="background: #f1f4f9; padding: 15px; border-radius: 8px; border-left: 5px solid #696cff;">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold" for="UnidadeOrigemId"><i class="bx bx-log-out-circle text-primary"></i> Unidade de Partida (Origem)</label>
                                    @Html.DropDownListFor(model => model.UnidadeOrigemId, (SelectList)ViewBag.UnidadesOrigem, "Selecione a Unidade de Partida...", new { @class = "select2" })
                                    <div class="form-text mt-1 small">Se informada, a rota começará nesta unidade. Se não informada, começará do primeiro ponto da rota.</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="d-flex justify-content-between">
                                        <label class="form-label fw-bold" for="UnidadeDestinoId"><i class="bx bx-log-in-circle text-success"></i> Unidade de Destino (Finalização)</label>
                                    </div>
                                    @Html.DropDownListFor(model => model.UnidadeDestinoId, (SelectList)ViewBag.UnidadesDestino, "Selecione a Unidade de Chegada...", new { @class = "select2" })
                                    <div class="form-text mt-1 text-info small"><i class="bx bx-info-circle"></i> Quando não informada, a rota terminará no último ponto de parada.</div>
                                </div>
                            </div>

                            <hr class="mt-4 mb-3" />
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="mb-0 text-primary"><i class='bx bx-map-pin'></i> Pontos da Rota</h6>
                                <div>
                                    <button type="button" class="btn btn-sm btn-outline-info me-2" id="btn-preview-rota">
                                        <i class='bx bx-git-branch'></i> Visualizar Rota Prevista
                                    </button>
                                    @if (!adicionar)
                                    {
                                        <button type="button" class="btn btn-sm btn-success" onclick="abrirModalPonto()">
                                            <i class='bx bx-plus'></i> Adicionar Ponto
                                        </button>
                                    }
                                </div>
                            </div>
                            
                            @if (adicionar)
                            {
                                <div class="alert alert-warning d-flex align-items-center" role="alert">
                                    <i class="bx bx-error-exclamation me-2"></i>
                                    <div>
                                        Salve os dados básicos da rota primeiro para poder gerenciar os pontos de parada.
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="table-responsive text-nowrap mt-2" style="max-height: 450px; overflow-y: auto;">
                                    <table class="table table-bordered table-sm table-hover" id="tabela-paradas">
                                        <thead>
                                            <tr>
                                                <th width="30px"></th>
                                                <th>Ordem</th>
                                                <th>Endereço/Localização</th>
                                                <th>Coordenadas GPS</th>
                                                <th width="15%">Observação</th>
                                                <th width="80px"></th>
                                            </tr>
                                        </thead>
                                        <tbody id="sortable-paradas">
                                            @if(Model.Paradas != null && Model.Paradas.Any())
                                            {
                                                foreach(var p in Model.Paradas.OrderBy(x => x.Ordem))
                                                {
                                                    <tr data-id="@p.Id" data-entregue="@(p.Entregue ? "true" : "false")"
                                                        data-endereco="@p.Endereco" data-lat="@p.Latitude" data-lng="@p.Longitude" data-link="@p.Link" data-obs="@p.Observacao"
                                                        data-unidade-id="@p.UnidadeId" data-tipo-pesquisa="@(p.UnidadeId.HasValue ? $"tipo-{(int)p.Unidade?.Tipo}" : "manual")">
                                                        <td class="text-center cursor-move"><i class="bx bx-menu"></i></td>
                                                        <td class="text-center font-weight-bold">
                                                            <span class="badge bg-label-primary rounded-circle p-2 label-ordem">@(p.Ordem + 1)</span>
                                                        </td>
                                                        <td>
                                                            @p.Endereco
                                                            @if(!string.IsNullOrEmpty(p.Link)){ <br /><a target="_blank" href="@p.Link" style="color: #0000ffb5; text-decoration: underline;">Ext Link</a> }
                                                        </td>
                                                        <td>
                                                            @if(!string.IsNullOrEmpty(p.Latitude)) { 
                                                                <a href="https://www.google.com/maps/search/?api=1&query=@p.Latitude,@p.Longitude" target="_blank" title="Abrir no Google Maps">
                                                                    <code class="small text-muted">@p.Latitude, @p.Longitude</code>
                                                                </a>
                                                            } else { 
                                                                <span class="text-warning small"><i class="bx bx-error"></i> Geofence Offline</span> 
                                                            }
                                                        </td>
                                                        <td>@p.Observacao</td>
                                                        <td class="text-center">
                                                            <button type="button" class="btn btn-sm btn-icon btn-outline-primary me-1" onclick="abrirModalPonto(this)"><i class='bx bx-edit'></i></button>
                                                            <button type="button" class="btn btn-sm btn-icon btn-outline-danger" onclick="removerLinhaParada(this)"><i class='bx bx-trash'></i></button>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                            else 
                                            {
                                                <tr id="empty-paradas-tr"><td colspan="7" class="text-center text-muted">Ainda não há paradas registradas na Rota.</td></tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }


                        </form>
                    </div>

                    <div class="tab-pane fade" id="tab-pacientes" role="tabpanel">
                        <!-- Patient Registration Modal Triggered by Link -->

                        <div class="row mb-3">
                            <div class="col-md-8">
                                <div class="d-flex justify-content-between">
                                    <label class="form-label">Selecionar Paciente</label>
                                    <a href="javascript:void(0)" onclick="abrirModalNovoPaciente()" class="small text-primary" style="color: blue !important; text-decoration: underline;">Não encontrou? Cadastrar Novo</a>
                                </div>
                                <select id="selecao-paciente" class="form-select select2-cadastro">
                                    <option value="">Selecione...</option>
                                    @foreach (var p in (List<Paciente>)ViewBag.PacientesDisponiveis)
                                    {
                                        <option value="@p.Id" data-nome="@p.Nome" data-tel="@p.Telefone" data-cpf="@p.CPF">@p.Nome (@p.CPF) @(!string.IsNullOrEmpty(p.Telefone) ? $" - {p.Telefone}" : "")</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-2 d-flex flex-column justify-content-end">
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" id="paciente-possui-acompanhante">
                                    <label class="form-check-label" for="paciente-possui-acompanhante">Acompanhante</label>
                                </div>
                            </div>
                            <div class="col-md-2 d-flex align-items-end">
                                <button type="button" class="btn btn-primary w-100" onclick="adicionarPacienteLista()">
                                    <i class='bx bx-plus'></i>
                                </button>
                            </div>
                        </div>
                        <div class="table-responsive" style="max-height: 300px;">
                            <table class="table table-sm table-hover border" id="tabela-pacientes-selecionados">
                                <thead class="bg-light">
                                    <tr>
                                        <th>Nome</th>
                                        <th>CPF</th>
                                        <th>Contato</th>
                                        <th class="text-center">Tipo</th>
                                        <th width="50px"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var rp in Model.ListaDePacientes)
                                    {
                                        <tr data-id="@rp.PacienteId" data-acompanhante="@(rp.PossuiAcompanhante ? "true" : "false")">
                                            <td>@rp.Paciente.Nome</td>
                                            <td>@rp.Paciente.CPF</td>
                                            <td>@rp.Paciente.Telefone</td>
                                            <td class="text-center">
                                                @if (rp.PossuiAcompanhante)
                                                {
                                                    <span class="badge bg-label-secondary">Acompanhante</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-label-info">Paciente</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <button type="button" class="btn btn-xs btn-icon btn-outline-danger" onclick="removerLinha(this)"><i class='bx bx-trash'></i></button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="tab-profissionais" role="tabpanel">
                        <div class="row mb-3">
                            <div class="col-md-10">
                                <label class="form-label">Selecionar Profissional da Rota</label>
                                <select id="selecao-profissional" class="form-select select2-cadastro" onchange="aoMudarProfissional()">
                                    <option value="">Selecione...</option>
                                    @foreach (var s in (dynamic)ViewBag.ProfissionaisDisponiveis)
                                    {
                                        <option value="@s.Id" data-nome="@s.Nome" data-cargo="@s.Cargo" data-crm="@s.CRM" data-especialidade="@s.Especialidade">@s.Nome (@s.Cargo)</option>
                                    }
                                </select>
                                <div id="info-medico-selecionado" class="mt-2 small text-info" style="display:none;">
                                    <i class="bx bx-id-card"></i> <strong>CRM:</strong> <span id="label-crm">-</span> | <strong>Especialidade:</strong> <span id="label-especialidade">-</span>
                                </div>
                            </div>
                            <div class="col-md-2 d-flex align-items-end">
                                <button type="button" class="btn btn-primary w-100" onclick="adicionarProfissionalLista()">
                                    <i class='bx bx-plus'></i> 
                                </button>
                            </div>
                        </div>
                        <div class="table-responsive" style="max-height: 300px;">
                            <table class="table table-sm table-hover border" id="tabela-profissionais-selecionados">
                                <thead class="bg-light">
                                    <tr>
                                        <th>Nome</th>
                                        <th>Cargo/Função</th>
                                        <th>CRM/Especialidade</th>
                                        <th width="50px"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var rp in Model.ListaDeProfissionais)
                                    {
                                        <tr data-id="@rp.ServidorId" data-crm="@rp.Servidor.CodigoCRM" data-especialidade="@rp.Servidor.EspecialidadeMedica">
                                            <td>@rp.Servidor.Pessoa.Nome</td>
                                            <td>@(rp.Servidor.VinculosDeTrabalho?.FirstOrDefault()?.Funcao?.Descricao ?? "Servidor")</td>
                                            <td>
                                                @if(!string.IsNullOrEmpty(rp.Servidor.CodigoCRM)) {
                                                    <span class="badge bg-label-info">CRM: @rp.Servidor.CodigoCRM</span>
                                                    <br/><small>@rp.Servidor.EspecialidadeMedica</small>
                                                } else {
                                                    <span>-</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <button type="button" class="btn btn-xs btn-icon btn-outline-danger" onclick="removerLinha(this)"><i class='bx bx-trash'></i></button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    @if(!adicionar)
                    {
                        <div class="tab-pane fade" id="tab-execucoes" role="tabpanel">
                            <div class="table-responsive" id="tabela-execucoes-container" style="max-height: 250px; overflow-y: auto;">
                                <table class="table table-sm table-bordered" id="tabela-historico-execucoes">
                                    <thead>
                                        <tr>
                                            <th>Início</th>
                                            <th>Usr. Início</th>
                                            <th>Fim</th>
                                            <th>Usr. Fim</th>
                                            <th width="100px">Ações</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr><td colspan="5" class="text-center"><i class="bx bx-loader bx-spin"></i> Carregando...</td></tr>
                                    </tbody>
                                </table>
                            </div>
                            
                            <div id="map-historico-container" style="display: none;">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="mb-0 text-primary"><i class="bx bx-map"></i> Rota Analisada pelo Histórico</h6>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="voltarParaHistorico()">
                                        <i class="bx bx-arrow-back"></i> Voltar p/ Lista
                                    </button>
                                </div>
                                <div id="map-historico" style="height: 350px; width: 100%; border-radius: 8px; border: 1px solid #ddd;"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="card-footer mt-3 d-flex justify-content-between">
                <div>
                     @if (Model.Id > 0 && podeRemover)
                    {
                        <button type="button" class="btn btn-danger" onclick="removerRegistroCadastro()">
                            <i class='bx bx-trash'></i> Remover
                        </button>
                    }
                </div>
                <div>
                    <button type="button" class="btn btn-secondary me-2" onclick="CarregarPagina('/Rota/Index')">
                        <i class='bx bx-arrow-back'></i> Voltar
                    </button>

                    @if (podeAlterar)
                    {
                        <button type="button" class="btn btn-primary" id="btn-salvar-cadastro">
                            <i class='bx bxs-save'></i> Salvar
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Ponto de Parada -->
<div class="modal fade" id="modal-ponto" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bx bx-map-pin"></i> Gerenciar Ponto de Parada</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" id="form-ponto-parada">
        <input type="hidden" id="modal-ponto-index" />
        <input type="hidden" id="modal-ponto-id" />
        
        <div class="row mb-3" id="row-tipo-pesquisa">
            <div class="col-12">
                <div class="d-flex gap-2 flex-wrap">
                    <div class="form-check custom-option custom-option-basic" style="width: auto;">
                        <label class="form-check-label custom-option-content p-2" for="tipo-manual">
                            <input name="tipo-pesquisa" class="form-check-input" type="radio" value="manual" id="tipo-manual" checked />
                            <span class="custom-option-header pb-0">
                                <span class="fw-medium text-heading">Manual</span>
                            </span>
                        </label>
                    </div>
                    <div class="form-check custom-option custom-option-basic" style="width: auto;">
                        <label class="form-check-label custom-option-content p-2" for="tipo-cep">
                            <input name="tipo-pesquisa" class="form-check-input" type="radio" value="cep" id="tipo-cep" />
                            <span class="custom-option-header pb-0">
                                <span class="fw-medium text-heading">Busca CEP</span>
                            </span>
                        </label>
                    </div>
                    @foreach (eTipoUnidadeOrganizacional tipo in Enum.GetValues(typeof(eTipoUnidadeOrganizacional)))
                    {
                        <div class="form-check custom-option custom-option-basic" style="width: auto;">
                            <label class="form-check-label custom-option-content p-2" for="tipo_@tipo">
                                <input name="tipo-pesquisa" class="form-check-input" type="radio" value="tipo-@((int)tipo)" id="tipo_@tipo" />
                                <span class="custom-option-header pb-0">
                                    <span class="fw-medium text-heading">@tipo.DescricaoDoEnumerador()</span>
                                </span>
                            </label>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div id="section-unidade-sistema" style="display:none;" class="mb-3">
            <label class="form-label" id="label-unidade-sistema" for="modal-selecao-unidade">Selecione a Unidade</label>
            <select id="modal-selecao-unidade" class="form-select select2-modal">
                <option value="">Selecione...</option>
                @foreach(var u in (dynamic)ViewBag.UnidadesParaModal) {
                    <option value="@u.Id" data-lat="@u.Latitude" data-lng="@u.Longitude" data-end="@u.Endereco" data-tipo="tipo-@((int)u.Tipo)">@u.Nome</option>
                }
            </select>
        </div>

        <div id="section-cep" style="display:none;" class="mb-3">
            <label class="form-label" for="modal-cep">Digite o CEP</label>
            <div class="input-group">
                <input type="text" id="modal-cep" class="form-control cep" placeholder="00000-000" />
                <button type="button" class="btn btn-outline-primary" onclick="pesquisarCEPModal()"><i class="bx bx-search"></i></button>
            </div>
        </div>

        <div class="row">
            <div class="col-12 mb-3">
                <label class="form-label obrigatorio" for="modal-ponto-endereco">Endereço Completo</label>
                <textarea id="modal-ponto-endereco" class="form-control" rows="2"></textarea>
            </div>
            <div class="col-12 mb-3">
                <label class="form-label" for="modal-ponto-obs">Observação</label>
                <textarea id="modal-ponto-obs" class="form-control" rows="2" placeholder=""></textarea>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label class="form-label obrigatorio" for="modal-ponto-lat">Latitude</label>
                <input type="text" id="modal-ponto-lat" class="form-control" />
            </div>
            <div class="col-md-6">
                <label class="form-label obrigatorio" for="modal-ponto-lng">Longitude</label>
                <input type="text" id="modal-ponto-lng" class="form-control" />
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <label class="form-label mb-0">Localização no Mapa</label>
                    <small class="text-muted">Clique no mapa para ajustar a posição</small>
                </div>
                <div id="modal-map" style="height: 300px; width: 100%; border-radius: 8px; border: 1px solid #ddd;"></div>
            </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fechar</button>
        <button type="button" class="btn btn-primary" onclick="confirmarPontoModal()">Confirmar Ponto</button>
      </div>
    </div>
  </div>
</div>

