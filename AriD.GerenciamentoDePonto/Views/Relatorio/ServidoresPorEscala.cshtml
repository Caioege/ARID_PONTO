<div class="card mb-6">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="bx bx-book-content"></i> Servidores por Escola
        </h5>
    </div>
    <div class="card-body">
        <div class="row">
           <div class="col col-sm-12">
               <label class="form-label">Escala</label>
               @Html.DropDownList("EscalaId", (SelectList)ViewBag.Justificativas, "Todas", new { @class = "select2" })
           </div>
        </div>

        <br />
        <button type="button" class="btn btn-primary" onclick="processarRelatorio()">
            <i class='bx bxs-report'></i> Processar
        </button>
    </div>
</div>

<script>
    function processarRelatorio() {
        let parametros = {
            escalaId: $('#EscalaId').val()
        };

        RequisicaoAjaxComCarregamento(
            '/Relatorio/ProcessarServidoresPorEscala',
            'POST',
            parametros,
            function (data) {
                if (data.sucesso) {
                    MensagemRodape('success', 'O arquivo será baixado...');
                    downloadBase64File(data.base64, data.fileName, data.mimeType);
                } else {
                    MensagemRodape('warning', data.mensagem);
                }
            });
    }
</script>