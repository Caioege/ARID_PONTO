@using AriD.BibliotecaDeClasses.Enumeradores
@{
    var dadosDaSessao = Context.DadosDaSessao();
}

<div class="card mb-6">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class='bx bx-task-x'></i> @Context.NomenclaturaServidores() Demitidos
        </h5>
    </div>
    <div class="card-body">
        <div class="row">
           <div class="col col-md-6 col-sm-12">
               <label class="form-label">Motivo de Demissão</label>
               @Html.DropDownList("MotivoDeDemissaoId", (SelectList)ViewBag.MotivosDeDemissao, "Todos", new { @class = "select2" })
           </div>

           <div class="col col-md-3 col-sm-6">
                <label class="form-label">Início</label>
                @Html.TextBox("Inicio", string.Empty, new { @class = "form-control data" })
           </div>

            <div class="col col-md-3 col-sm-6">
                <label class="form-label">Fim</label>
                @Html.TextBox("Fim", string.Empty, new { @class = "form-control data" })
            </div>
        </div>

        @if (dadosDaSessao.Perfil != ePerfilDeAcesso.UnidadeOrganizacional)
        {
            <div class="row">
                <div class="col col-md-12">
                    <label class="form-label">Unidade</label>
                    @Html.DropDownList("UnidadeId", (SelectList)ViewBag.Unidades, "Todas", new { @class = "select2" })
                </div>
            </div>
        }

        <br />
        <button type="button" class="btn btn-primary" onclick="processarRelatorio()">
            <i class='bx bxs-report'></i> Processar
        </button>
    </div>
</div>

<script>
    function processarRelatorio() {
        let parametros = {
            unidadeLotacaoId: $('#UnidadeId').val(),
            inicio: $('#Inicio').val(),
            fim: $('#Fim').val(),
            justifimotivoDeDemissaoIdcativaId: $('#MotivoDeDemissaoId').val()
        };

        RequisicaoAjaxComCarregamento(
            '/Relatorio/ProcessarServidoresDemitidos',
            'POST',
            parametros,
            function (data) {
                if (data.sucesso) {
                    MensagemRodape('success', 'O arquivo será baixado...');
                    downloadBase64File(data.base64, data.fileName, data.mimeType);
                } else {
                    MensagemRodape('warning', data.mensagem);
                }
            });
    }
</script>