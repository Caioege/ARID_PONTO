@using AriD.BibliotecaDeClasses.Enumeradores
@{
    var dadosDaSessao = Context.DadosDaSessao();
}

<div class="card mb-6">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class='bx bx-user-x'></i> Relatório de Absenteísmo e Atrasos
        </h5>
    </div>
    <div class="card-body">
        <div class="row">
           <div class="col col-md-6 col-sm-6">
                <label class="form-label obrigatorio">Data de Início</label>
                @Html.TextBox("Inicio", DateTime.Today.AddDays(-7).ToString("yyyy-MM-dd"), new { @class = "form-control data" })
           </div>

            <div class="col col-md-6 col-sm-6">
                <label class="form-label obrigatorio">Data de Fim</label>
                @Html.TextBox("Fim", DateTime.Today.ToString("yyyy-MM-dd"), new { @class = "form-control data" })
            </div>
        </div>

        <br/>

        @if (dadosDaSessao.Perfil != ePerfilDeAcesso.UnidadeOrganizacional)
        {
            <div class="row">
                <div class="col col-md-12">
                    <label class="form-label">Unidade</label>
                    @Html.DropDownList("UnidadeId", (SelectList)ViewBag.Unidades, "Todas as Unidades", new { @class = "select2" })
                </div>
            </div>
            <br />
        }

        <button type="button" class="btn btn-primary" onclick="processarRelatorio()">
            <i class='bx bxs-report'></i> Emitir Relatório
        </button>
    </div>
</div>

<script>
    function processarRelatorio() {
        let parametros = {
            unidadeId: $('#UnidadeId').val(),
            inicio: $('#Inicio').val(),
            fim: $('#Fim').val()
        };

        if(!parametros.inicio || !parametros.fim) {
            MensagemRodape('warning', 'A data inicial e final são obrigatórias.');
            return;
        }

        RequisicaoAjaxComCarregamento(
            '/Relatorio/ProcessarAbsenteismo',
            'POST',
            parametros,
            function (data) {
                if (data.sucesso) {
                    MensagemRodape('success', 'Baixando relatório PDF...');
                    downloadBase64File(data.base64, data.fileName, data.mimeType);
                } else {
                    MensagemRodape('warning', data.mensagem);
                }
            });
    }
</script>
