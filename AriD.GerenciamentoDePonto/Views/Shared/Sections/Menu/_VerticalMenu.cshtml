@using AriD.BibliotecaDeClasses.Enumeradores
@using AriD.BibliotecaDeClasses.Enumeradores.Permissao

@{
    TempData.Keep();
}

@{
    var dadosDaSessao = this.Context.DadosDaSessao();
    var listaDePermissao = dadosDaSessao.Permissoes;
    var usuarioAdm = dadosDaSessao.UsuarioAdministradorAutenticado;

    var nomenclaturaServidores = Context.NomenclaturaServidores();
    var nomenclaturaServidor = Context.NomenclaturaServidor();
}

<style>
    #menuSearchInput {
        background-color: #ffffff !important;
        color: #495057 !important;
        border: 1px solid #d9dee3;
    }

    #menuSearchInput::placeholder {
        color: #b5b5b5;
    }

    .menu-inner > .menu-item {
        margin-left: 0 !important;
        margin-right: 0 !important;
        border-radius: 0 !important;
    }

    .menu-inner > .menu-item > .menu-link {
        padding-left: 1.5rem !important;
    }

    .menu-sub .menu-item .menu-link {
        padding-left: 2rem !important;
    }

    .menu-item.menu-group.open {
        background-color: rgba(255, 255, 255, 0.05);
        border: 1px solid #d9dee3 !important;
        border-radius: 0.375rem !important;
    }

    .menu-group.open > .menu-sub {
        background: #c8d2e0;
    }

    .menu-inner {
        padding-right: 0;
        padding-left: 0;
    }

    .search-container {
        padding: 0 1.5rem 0.5rem 1.5rem; 
    }

    mark.highlight-text {
        background-color: #ffe000;
        color: #000;
        padding: 0;
        font-weight: bold;
        border-radius: 2px;
    }

    @@keyframes balancarSinoPausado {
      0% { transform: rotate(0); }
      4% { transform: rotate(15deg); }
      8% { transform: rotate(-15deg); }
      12% { transform: rotate(15deg); }
      16% { transform: rotate(-15deg); }
      20% { transform: rotate(15deg); }
      24% { transform: rotate(-15deg); }
      28% { transform: rotate(15deg); }
      32% { transform: rotate(-15deg); }
      37.5% { transform: rotate(0); }
      100% { transform: rotate(0); }
    }

    .sino-alerta {
      animation: balancarSinoPausado 8s ease-in-out infinite;
      color: #ffc107;
    }
</style>

<aside id="layout-menu" class="layout-menu menu-vertical menu bg-menu-theme">
    <div class='app-brand demo @((@ViewData["navbarFull"] != null && Convert.ToBoolean(@ViewData["navbarFull"])) ? "d-xl-none" : "")'>
        <div class="app-brand-link">
            <span class="app-brand-logo demo">
                @await Html.PartialAsync("../_Partials/_Macros")
            </span>
            <span class="app-brand-text demo menu-text fw-bold ms-2">@TempData.Peek("appName")</span>
        </div>

        <a href="javascript:void(0);" class="layout-menu-toggle menu-link text-large ms-auto d-block d-xl-none">
            <i class="bx bx-chevron-left bx-sm d-flex align-items-center justify-content-center"></i>
        </a>
    </div>

    <div class="menu-inner-shadow"></div>

    @if (dadosDaSessao.Perfil != ePerfilDeAcesso.AdministradorDeSistema && dadosDaSessao.Perfil != ePerfilDeAcesso.Servidor)
    {
        @if (listaDePermissao.PossuiPermissao(eItemDePermissao_RecadoSistema.Visualizar, usuarioAdm))
        {
            <button type="button" class="btn btn-sm btn-secondary" id="btnRecados" onclick="abrirModalRecadosSistema()" style="margin: 5px 25px 10px 25px;">
                <i class='bx bx-bell'></i>
            </button>
        }

        <div class="search-container mb-2">
            <input type="text" id="menuSearchInput" class="form-control" placeholder="Pesquisar no menu..." autocomplete="off">
        </div>
    }

    <ul class="menu-inner py-1" id="main-menu-list">
