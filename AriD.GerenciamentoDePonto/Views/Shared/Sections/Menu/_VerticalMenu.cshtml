                            <a onclick="CarregarPagina('@Url.Action("ServidoresPorLotacao", "Relatorio")')" href="javascript:void(0)" class="menu-link">
                                <i class='menu-icon bx bx-list-ol'></i>
                                <div class="menu-text-content" style="white-space: normal !important;">@nomenclaturaServidores por Lotação</div>
                            </a>
                        </li>
                    }
                    @if (listaDePermissao.PossuiPermissao(eItemDePermissao_RelatorioHorasPorServidor.Visualizar, usuarioAdm))
                    {
                        <li class='menu-item searchable-item'>
                            <a onclick="CarregarPagina('@Url.Action("HorasPorServidor", "Relatorio")')" href="javascript:void(0)" class="menu-link">
                                <i class='menu-icon bx bx-time-five'></i>
                                <div class="menu-text-content" style="white-space: normal !important;">Horas Positivas/Negativas por @nomenclaturaServidor</div>
                            </a>
                        </li>
                    }
                </ul>
            </li>


        }
    </ul>
</aside>

<div id="div-modal-recados"></div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const menuSearchInput = document.getElementById('menuSearchInput');
        const menuItems = document.querySelectorAll('.searchable-item');
        const menuGroups = document.querySelectorAll('.menu-group');

        function removerAcentos(str) {
            return str.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase();
        }

        function criarRegexParaHighlight(termo) {
            const mapaAcentos = {
                'a': '[aáàâãä]', 'e': '[eéèêë]', 'i': '[iíìîï]',
                'o': '[oóòôõö]', 'u': '[uúùûü]', 'c': '[cç]',
                'n': '[nñ]', 'y': '[yýÿ]'
            };

            let termoSeguro = termo.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');

            termoSeguro = termoSeguro.replace(/[aeioucny]/gi, function(match) {
                return mapaAcentos[match.toLowerCase()] || match;
            });

            return new RegExp(`(${termoSeguro})`, 'gi');
        }

        function verificarGruposVazios() {
            menuGroups.forEach(group => {
                const subItems = group.querySelectorAll('.menu-sub li');
                const visibleSubItems = Array.from(subItems).filter(item => item.style.display !== 'none');

                if (visibleSubItems.length === 0) {
                    group.style.display = 'none';
                } else {
                    group.style.display = '';
                }
            });
        }

        verificarGruposVazios();

        menuSearchInput.addEventListener('input', function () {
            const textoDigitado = this.value;
            const textoFiltro = removerAcentos(textoDigitado);

            menuItems.forEach(item => {
                const textDiv = item.querySelector('.menu-text-content');

                if (!textDiv.hasAttribute('data-original-text')) {
                    textDiv.setAttribute('data-original-text', textDiv.textContent);
                }

                const textoOriginal = textDiv.getAttribute('data-original-text');
                const textoOriginalNormalizado = removerAcentos(textoOriginal);

                if (textoOriginalNormalizado.includes(textoFiltro)) {
                    item.style.display = '';

                    if (textoFiltro.length > 0) {
                        const regexHighlight = criarRegexParaHighlight(textoDigitado);
                        if (textoOriginal.match(regexHighlight)) {
                            textDiv.innerHTML = textoOriginal.replace(regexHighlight, '<mark class="highlight-text">$1</mark>');
                        } else {
                            textDiv.innerHTML = textoOriginal;
                        }

                        const parentGroup = item.closest('.menu-group');
                        if (parentGroup) {
                            parentGroup.classList.add('open');
                        }
                    } else {
                        textDiv.innerHTML = textoOriginal;
                    }
                } else {
                    item.style.display = 'none';
                    textDiv.innerHTML = textoOriginal;
                }
            });

            if (textoFiltro.length === 0) {
                document.querySelectorAll('.menu-group.open').forEach(group => {
                    group.classList.remove('open');
                });
            }

            verificarGruposVazios();
        });
    });
</script>
