@using AriD.BibliotecaDeClasses.Enumeradores
@using AriD.Servicos.Extensao
@model HorarioDeTrabalho

<style>
    .linha > td:not(:first-child) {
        padding: 5px !important;
    }

    .linha > td > input {
        text-align: center !important;
    }
</style>

<div class="card mb-6">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            Adicionar Horário de Trabalho
        </h5>
        <small class="text-muted float-end">
            Campos com <span style="color: red">*</span> são obrigatórios.
        </small>
    </div>
    <div class="card-body">
        <form id="formulario-horario-trabalho">
            @Html.HiddenFor(model => model.Id)
            <div class="row">
                <div class="col col-lg-3 col-md-6 col-sm-12">
                    <label class="form-label obrigatorio" for="Sigla">Sigla</label>
                    @Html.TextBoxFor(model => model.Sigla, new { @class = "form-control", @maxlength = "5" })
                </div>

                <div class="col col-lg-3 col-md-6 col-sm-12">
                    <label class="form-label obrigatorio" for="Ativo">Ativo</label>
                    @Html.CheckboxDropDownListFor(model => model.Ativo, new { @class = "form-select" })
                </div>

                <div class="col col-lg-6 col-md-12 col-sm-12">
                    <label class="form-label obrigatorio" for="Descricao">Descrição</label>
                    @Html.TextBoxFor(model => model.Descricao, new { @class = "form-control", @maxlength = "100" })
                </div>
            </div>

            <div class="row">
                <div class="col col-lg-3 col-md-6 col-sm-12">
                    <label class="form-label obrigatorio" for="TipoCargaHoraria">Tipo da Carga Horária</label>
                    @Html.EnumDropDownListFor(model => model.TipoCargaHoraria, new { @class = "form-select" })
                </div>

                <div class="col col-lg-3 col-md-12 col-sm-12">
                    <label id="label-chmensal-fixa" class="form-label" for="CargaHorariaMensalFixa">Carga Horária Mensal</label>
                    @if (Model.TipoCargaHoraria == eTipoCargaHoraria.MensalFixa)
                    {
                        @Html.TextBoxFor(model => model.CargaHorariaMensalFixa, new { @class = "form-control numeroAte999", @maxlength = "3" })
                    }
                    else
                    {
                        @Html.TextBoxFor(model => model.CargaHorariaMensalFixa, new { @class = "form-control numeroAte999", @maxlength = "3", @disabled = "disabled", @readonly = "readonly" })
                    }
                </div>

                <div class="col col-lg-3 col-md-6 col-sm-12" id="div-utiliza-5" style="@(Model.CargaHorariaFixa ? "display: none" : string.Empty)">
                    <label class="form-label obrigatorio" for="UtilizaCincoPeriodos">Utilizar Cinco Períodos</label>
                    @Html.CheckboxDropDownListFor(model => model.UtilizaCincoPeriodos, new { @class = "form-select" })
                </div>

                <div class="col col-lg-3 col-md-6 col-sm-12">
                    <label class="form-label obrigatorio" for="UtilizaBancoDeHoras">Utiliza Banco De Horas</label>
                    @Html.CheckboxDropDownListFor(model => model.UtilizaBancoDeHoras, new { @class = "form-select" })
                </div>

                <div id="div-data-bh" class="col col-lg-3 col-md-6 col-sm-12" style="@(Model.UtilizaBancoDeHoras ? string.Empty : "display:none")">
                    <label class="form-label">Início do Banco de Horas</label>
                    @Html.TextBoxFor(model => model.InicioBancoDeHoras, new { @class = "form-control data" })
                </div>

                <div class="col col-lg-3 col-md-6 col-sm-12">
                    <label class="form-label obrigatorio" for="IntervaloAutomatico">Intervalo automático</label>
                    @Html.EnumDropDownListFor(model => model.IntervaloAutomatico, new { @class = "form-select" })
                    <div class="form-text">Define quais batidas serão preenchidas automaticamente.</div>
                </div>

                <div class="col col-lg-3 col-md-6 col-sm-12">
                    <label class="form-label obrigatorio" for="ToleranciaDiariaEmMinutos">Tolerância Diária em Minutos</label>
                    @Html.TextBoxFor(model => model.ToleranciaDiariaEmMinutos, new { @class = "form-control numeroAte999", @maxlenth = "3" })
                </div>

                <div class="col col-lg-3 col-md-6 col-sm-12">
                    <label class="form-label" for="ToleranciaDsrEmMinutos">Tolerância DSR em Minutos</label>
                    @Html.TextBoxFor(model => model.ToleranciaDsrEmMinutos, new { @class = "form-control numeroAte999", @maxlenth = "3" })
                    <div class="form-text">Se o dia não tiver carga horária e o trabalho no dia for até esta tolerância, não gera saldo/HE.</div>
                </div>
            </div>

            <br />
            <div class="table-responsive text-nowrap">
                <table class="table table-bordered" id="tabela-horario">
                    <thead>
                        <tr>
                            <th class="text-center"><b>Dia da semana</b></th>
                            <th width="7.5%" class="colunas-horario-nao-fixo" style="@(Model.CargaHorariaFixa ? "display: none": string.Empty)"><b>Ent. 1</b></th>
                            <th width="7.5%" class="colunas-horario-nao-fixo" style="@(Model.CargaHorariaFixa ? "display: none": string.Empty)"><b>Sai. 1</b></th>
                            <th width="7.5%" class="colunas-horario-nao-fixo" style="@(Model.CargaHorariaFixa ? "display: none": string.Empty)"><b>Ent. 2</b></th>
                            <th width="7.5%" class="colunas-horario-nao-fixo" style="@(Model.CargaHorariaFixa ? "display: none": string.Empty)"><b>Sai. 2</b></th>
                            <th width="7.5%" class="colunas-horario-nao-fixo" style="@(Model.CargaHorariaFixa ? "display: none": string.Empty)"><b>Ent. 3</b></th>
                            <th width="7.5%" class="colunas-horario-nao-fixo" style="@(Model.CargaHorariaFixa ? "display: none": string.Empty)"><b>Sai. 3</b></th>
                            <th width="7.5%" class="ocultar-cinco-periodo" style="@(Model.UtilizaCincoPeriodos ? string.Empty : "display:none;")"><b>Ent. 4</b></th>
                            <th width="7.5%" class="ocultar-cinco-periodo" style="@(Model.UtilizaCincoPeriodos ? string.Empty : "display:none;")"><b>Sai. 4</b></th>
                            <th width="7.5%" class="ocultar-cinco-periodo" style="@(Model.UtilizaCincoPeriodos ? string.Empty : "display:none;")"><b>Ent. 5</b></th>
                            <th width="7.5%" class="ocultar-cinco-periodo" style="@(Model.UtilizaCincoPeriodos ? string.Empty : "display:none;")"><b>Sai. 5</b></th>
                            <th width="7.5%" class="text-center"><b>CH</b></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var diaDaSemana in Model.Dias)
                        {
                            <tr class="linha" data-diadasemana="@((int)diaDaSemana.DiaDaSemana)" data-id="@diaDaSemana.Id">
                                <td>
                                    <b>@(diaDaSemana.DiaDaSemana.DescricaoDoEnumerador())</b>
                                </td>
                                <td class="text-center colunas-horario-nao-fixo" style="@(Model.CargaHorariaFixa ? "display: none": string.Empty)">
                                    @Html.TextBox($"{diaDaSemana.DiaDaSemana.ToString()}_Ent1", diaDaSemana.Entrada1, new { @class = "form-control hora entrada1", @maxlength = "5", @placeholder = "__:__", @autocomplete = "off" })
                                </td>
                                <td class="text-center colunas-horario-nao-fixo" style="@(Model.CargaHorariaFixa ? "display: none": string.Empty)">
                                    @Html.TextBox($"{diaDaSemana.DiaDaSemana.ToString()}_Sai1", diaDaSemana.Saida1, new { @class = "form-control hora saida1", @maxlength = "5", @placeholder = "__:__", @autocomplete = "off" })
                                </td>

                                <td class="text-center colunas-horario-nao-fixo" style="@(Model.CargaHorariaFixa ? "display: none": string.Empty)">
                                    @Html.TextBox($"{diaDaSemana.DiaDaSemana.ToString()}_Ent2", diaDaSemana.Entrada2, new { @class = "form-control hora entrada2", @maxlength = "5", @placeholder = "__:__", @autocomplete = "off" })
                                </td>
                                <td class="text-center colunas-horario-nao-fixo" style="@(Model.CargaHorariaFixa ? "display: none": string.Empty)">
                                    @Html.TextBox($"{diaDaSemana.DiaDaSemana.ToString()}_Sai2", diaDaSemana.Saida2, new { @class = "form-control hora saida2", @maxlength = "5", @placeholder = "__:__", @autocomplete = "off" })
                                </td>

                                <td class="text-center colunas-horario-nao-fixo" style="@(Model.CargaHorariaFixa ? "display: none": string.Empty)">
                                    @Html.TextBox($"{diaDaSemana.DiaDaSemana.ToString()}_Ent3", diaDaSemana.Entrada3, new { @class = "form-control hora entrada3", @maxlength = "5", @placeholder = "__:__", @autocomplete = "off" })
                                </td>
                                <td class="text-center colunas-horario-nao-fixo" style="@(Model.CargaHorariaFixa ? "display: none": string.Empty)">
                                    @Html.TextBox($"{diaDaSemana.DiaDaSemana.ToString()}_Sai3", diaDaSemana.Saida3, new { @class = "form-control hora saida3", @maxlength = "5", @placeholder = "__:__", @autocomplete = "off" })
                                </td>

                                <td class="text-center ocultar-cinco-periodo" style="@(Model.UtilizaCincoPeriodos ? string.Empty : "display:none;")">
                                    @Html.TextBox($"{diaDaSemana.DiaDaSemana.ToString()}_Ent4", diaDaSemana.Entrada4, new { @class = "form-control hora entrada4", @maxlength = "5", @placeholder = "__:__", @autocomplete = "off" })
                                </td>
                                <td class="text-center ocultar-cinco-periodo" style="@(Model.UtilizaCincoPeriodos ? string.Empty : "display:none;")">
                                    @Html.TextBox($"{diaDaSemana.DiaDaSemana.ToString()}_Sai4", diaDaSemana.Saida4, new { @class = "form-control hora saida4", @maxlength = "5", @placeholder = "__:__", @autocomplete = "off" })
                                </td>

                                <td class="text-center ocultar-cinco-periodo" style="@(Model.UtilizaCincoPeriodos ? string.Empty : "display:none;")">
                                    @Html.TextBox($"{diaDaSemana.DiaDaSemana.ToString()}_Ent5", diaDaSemana.Entrada5, new { @class = "form-control hora entrada5", @maxlength = "5", @placeholder = "__:__", @autocomplete = "off" })
                                </td>
                                <td class="text-center ocultar-cinco-periodo" style="@(Model.UtilizaCincoPeriodos ? string.Empty : "display:none;")">
                                    @Html.TextBox($"{diaDaSemana.DiaDaSemana.ToString()}_Sai5", diaDaSemana.Saida5, new { @class = "form-control hora saida5", @maxlength = "5", @placeholder = "__:__", @autocomplete = "off" })
                                </td>

                                <td class="text-center carga-horaria colunas-horario-nao-fixo" style="@(Model.CargaHorariaFixa ? "display: none": string.Empty)">
                                    @(diaDaSemana.CalculeCargaHorariaTotal(false)?.ToString(@"hh\:mm"))
                                </td>

                                <td class="text-center colunas-horario-fixo" style="@(Model.CargaHorariaFixa ? string.Empty : "display: none")">
                                    @Html.TextBox($"{diaDaSemana.DiaDaSemana.ToString()}_CargaHorariaFixa", diaDaSemana.CargaHorariaFixa, new { @class = "form-control hora chfixa", @maxlength = "5", @placeholder = "__:__", @autocomplete = "off" })
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @Html.Partial("_ConfiguracaoHoraExtra", Model)

            <br />
            <h6 class="text-muted">Configuração de Exibição</h6>
            <div class="row">
                <div class="col-12">
                    @Html.HiddenFor(model => model.ColunasVisiveis)

                    <div class="row g-2">
                        @{
                            var colunas = new Dictionary<eColunasDaFolha, string>
                            {
                                { eColunasDaFolha.HorasTrabalhadas, "Horas Trabalhadas" },
                                { eColunasDaFolha.CargaHoraria, "Carga Horária" },
                                { eColunasDaFolha.HorasPositivas, "Horas Positivas" },
                                { eColunasDaFolha.HorasNegativas, "Horas Negativas" },
                                { eColunasDaFolha.BHSaldo, "BH Saldo" },
                                { eColunasDaFolha.BHAjuste, "BH Ajuste" }
                            };
                        }

                        @foreach (var coluna in colunas)
                        {
                            var isChecked = Model.ColunasVisiveis.HasFlag(coluna.Key);
                            var valorInt = (int)coluna.Key;

                            <div class="col-6 col-md-4 col-lg-2">
                                <div class="form-check card-select p-2 border rounded text-center h-100 d-flex flex-column align-items-center justify-content-center bg-light">
                                    <input class="form-check-input check-coluna mb-1"
                                           type="checkbox"
                                           value="@valorInt"
                                           id="chk_col_@valorInt"
                                    @(isChecked ? "checked" : "")
                                           style="cursor: pointer;">

                                    <label class="form-check-label cursor-pointer small fw-bold" for="chk_col_@valorInt" style="font-size: 0.85rem;">
                                        @coluna.Value
                                    </label>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="form-text mt-2">Desmarque as colunas que deseja ocultar.</div>
                </div>
            </div>

            <br />
            <button type="button" class="btn btn-secondary" onclick="CarregarPagina('@Url.Action("Index", "HorarioDeTrabalho")')">
                <i class='bx bxs-left-arrow-circle'></i> Voltar
            </button>

            <button type="button" class="btn btn-primary" id="btn-salvar">
                <i class='bx bxs-save'></i> Salvar
            </button>
        </form>
    </div>
</div>

<script src="/Scripts/Paginas/HorarioDeTrabalho/alterar.js?t=@DateTime.Now.Ticks"></script>