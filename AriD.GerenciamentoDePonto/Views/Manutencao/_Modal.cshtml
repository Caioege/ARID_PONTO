@using AriD.BibliotecaDeClasses.Entidades
@model ManutencaoVeiculo

<div class="modal fade" id="modal-manutencao" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content border-top border-primary border-3">
            <div class="modal-header">
                <h5 class="modal-title"><i class='bx bx-wrench'></i> Registro de Manutenção</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="form-manutencao">
                    @Html.HiddenFor(m => m.Id)
                    @Html.HiddenFor(m => m.VeiculoId)
                    @Html.HiddenFor(m => m.OrganizacaoId)
                    
                    <div class="row">
                        <div class="col-12 mb-3">
                            <label class="form-label obrigatorio" for="DataManutencao">Data da Manutenção</label>
                            <input type="date" id="DataManutencao" name="DataManutencao" class="form-control" value="@Model.DataManutencao.ToString("yyyy-MM-dd")" required />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12 mb-3">
                            <label class="form-label obrigatorio" for="Descricao">Descrição / Tipo</label>
                            <input type="text" id="Descricao" name="Descricao" class="form-control" value="@Model.Descricao" placeholder="Ex: Troca de óleo, Revisão de freios..." required />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label obrigatorio" for="KmNaManutencao">Km Atual</label>
                            <input type="number" id="KmNaManutencao" name="KmNaManutencao" class="form-control" value="@Model.KmNaManutencao" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="KmProximaManutencao" class="form-label">Km Próxima</label>
                            <input type="number" id="KmProximaManutencao" name="KmProximaManutencao" class="form-control" value="@Model.KmProximaManutencao" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12 mb-3">
                            <label for="DataVencimentoManutencao" class="form-label">Próxima Data (Vencimento)</label>
                            <input type="date" id="DataVencimentoManutencao" name="DataVencimentoManutencao" class="form-control" value="@(Model.DataVencimentoManutencao?.ToString("yyyy-MM-dd"))" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12 mb-3">
                            <label for="Observacao" class="form-label">Observações</label>
                            <textarea id="Observacao" name="Observacao" class="form-control" rows="3">@Model.Observacao</textarea>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fechar</button>
                <button type="button" class="btn btn-primary" onclick="salvarManutencao()">Gravar Registro</button>
            </div>
        </div>
    </div>
</div>
