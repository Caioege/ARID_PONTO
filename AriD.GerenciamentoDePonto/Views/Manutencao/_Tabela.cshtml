@using AriD.BibliotecaDeClasses.Entidades
@model List<ManutencaoVeiculo>

<div class="table-responsive">
    <table class="table table-sm table-hover border">
        <thead>
            <tr class="bg-light">
                <th>Data</th>
                <th>Descrição</th>
                <th class="text-end">Km Registro</th>
                <th class="text-end">Venc. Km</th>
                <th>Venc. Data</th>
                <th class="text-center">Ações</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !Model.Any())
            {
                <tr>
                    <td colspan="6" class="text-center p-3 text-muted">Nenhum registro de manutenção encontrado.</td>
                </tr>
            }
            else
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.DataManutencao.ToString("dd/MM/yyyy")</td>
                        <td>@item.Descricao</td>
                        <td class="text-end">@item.KmNaManutencao.ToString("N0")</td>
                        <td class="text-end">@(item.KmProximaManutencao?.ToString("N0") ?? "-")</td>
                        <td>@(item.DataVencimentoManutencao?.ToString("dd/MM/yyyy") ?? "-")</td>
                        <td class="text-center">
                            <button type="button" class="btn btn-sm btn-icon btn-outline-secondary" onclick="abrirModalManutencao(@item.Id)">
                                <i class='bx bx-edit-alt'></i>
                            </button>
                            <button type="button" class="btn btn-sm btn-icon btn-outline-danger" onclick="removerManutencao(@item.Id)">
                                <i class='bx bx-trash'></i>
                            </button>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
