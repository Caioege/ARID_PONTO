@using AriD.BibliotecaDeClasses.Enumeradores
@model Turma

@{
    var dadosDaSessao = Context.DadosDaSessao();
}

<div class="card mb-6">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            Adicionar Turma
        </h5>
        <small class="text-muted float-end">
            Campos com <span style="color: red">*</span> săo obrigatórios.
        </small>
    </div>
    <div class="card-body">
        <form id="formulario-turma">
            @Html.HiddenFor(model => model.Id)
            @Html.HiddenFor(model => model.RedeDeEnsinoId)

            <div class="row">
                <section class="col col-md-12">
                    <label class="form-label obrigatorio" for="EscolaId">Escola</label>
                    @if (dadosDaSessao.Perfil == ePerfilDeAcesso.Escola)
                    {
                        @Html.TextBox("EscolaNome", (string)ViewBag.EscolaNome, new { @class = "form-control", @disabled = "disabled", @readonly = "readonly" })
                        @Html.Hidden("EscolaId", dadosDaSessao.Escolas.First())
                    }
                    else
                    {
                        @Html.DropDownListFor(model => model.EscolaId, (SelectList)ViewBag.Escolas, string.Empty, new { @class = "select2" })
                    }
                </section>
            </div>

            <div class="row">
                <section class="col col-md-3 col-sm-12">
                    <label class="form-label obrigatorio" for="AnoLetivo">Ano Letivo</label>
                    @Html.TextBoxFor(model => model.AnoLetivo, new { @class = "form-control ano" })
                </section>

                <section class="col col-md-3 col-sm-12">
                    <label class="form-label obrigatorio" for="InicioDasAulas">Início das Aulas</label>
                    @Html.TextBox("InicioDasAulas", string.Empty, new { @class = "form-control data" })
                </section>

                <section class="col col-md-3 col-sm-12">
                    <label class="form-label obrigatorio" for="FimDasAulas">Fim das Aulas</label>
                    @Html.TextBox("FimDasAulas", string.Empty, new { @class = "form-control data" })
                </section>

                <section class="col col-md-3 col-sm-12">
                    <label class="form-label obrigatorio">Situaçăo</label>
                    @Html.TextBox("SituacaoDescricao", "Ativa", new { @class = "form-control", @disabled = "disabled", @readonly = "readonly" })
                </section>
            </div>

            <div class="row">
                <section class="col col-md-4 col-sm-12">
                    <label class="form-label obrigatorio" for="Descricao">Descriçăo</label>
                    @Html.TextBoxFor(model => model.Descricao, new { @class = "form-control", @maxlength = "100" })
                </section>

                <section class="col col-md-8 col-sm-12">
                    <label class="form-label obrigatorio" for="AnoEscolar">Ano Escolar</label>
                    @Html.EnumDropDownListFor(model => model.AnoEscolar, string.Empty, new { @class = "select2" })
                </section>
            </div>

            <div class="row">
                <section class="col col-md-4 col-sm-12">
                    <label class="form-label obrigatorio" for="Turno">Turno</label>
                    @Html.EnumDropDownListFor(model => model.Turno, string.Empty, new { @class = "form-select" })
                </section>

                <section class="col col-md-4 col-sm-12">
                    <label class="form-label obrigatorio" for="TipoDoDiario">Tipo do Diário</label>
                    @Html.EnumDropDownListFor(model => model.TipoDoDiario, string.Empty, new { @class = "form-select" })
                </section>
            </div>

            <br />
            <button type="button" class="btn btn-secondary" onclick="CarregarPagina('@Url.Action("Index", "Turma")')">
                <i class='bx bxs-left-arrow-circle'></i> Voltar
            </button>

            <button type="button" class="btn btn-primary" id="btn-salvar">
                <i class='bx bxs-save'></i> Salvar
            </button>
        </form>
    </div>
</div>

<script src="/Scripts/Paginas/Turma/alterar.js?t=@DateTime.Now.Ticks"></script>
