@using AriD.BibliotecaDeClasses.Enumeradores.Permissao
@model ListaPaginada<EquipamentoDeFrequencia>

<div class="card mb-6">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="bx bx-mobile-alt"></i> Listagem de Equipamentos de FrequÍncia
        </h5>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-5 col-sm-6 col-xs-12">
                <div class="input-group">
                    @Html.TextBox("TermoDeBusca", Model.TermoDeBusca, new { @class = "form-control", @placeholder = "Digite para buscar", @style = "background: white" })
                    <button class="btn btn-primary" type="button" onclick="carregarTabelaPaginadaComPesquisa('@Url.Action("TabelaPaginada")')">
                        <i class='bx bx-search-alt'></i> Pesquisar
                    </button>
                </div>
            </div>

            <div class="col-md-7 col-sm-6 col-xs-12">
                @if (Context.PossuiPermissao(eItemDePermissao_EquipamentoDeFrequencia.CadastrarOuAlterar))
                {
                    <button type="button" onclick="AbrirModal(0)" class="btn btn-primary float-end">
                        <i class="bx bx-plus"></i> Adicionar
                    </button>
                }
                </div>
        </div>
        <br />

        <div id="grid">
            @await Html.PartialAsync("_TabelaPaginada")
        </div>

        <div id="div-modal"></div>
    </div>
</div>

<script src="/Scripts/Paginas/EquipamentoDeFrequencia/index.js?t=@DateTime.Now.Ticks"></script>
