@{
    Layout = null;
}

<style>
    .campo-configurado-card {
        border: 1px solid #ccc;
        padding: 12px;
        border-radius: 8px;
        margin-bottom: 10px;
        background-color: #f9f9f9;
    }

        .campo-configurado-card .form-label {
            font-weight: 500;
            font-size: 0.9rem;
        }

    .switch {
        position: relative;
        display: inline-block;
        width: 44px;
        height: 24px;
    }

    .switch-input {
        opacity: 0;
        width: 0;
        height: 0;
    }

    .switch-toggle-slider {
        position: absolute;
        cursor: pointer;
        background-color: #ccc;
        border-radius: 34px;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        transition: .4s;
    }

        .switch-toggle-slider:before {
            content: "";
            position: absolute;
            height: 18px;
            width: 18px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            border-radius: 50%;
            transition: .4s;
        }

    .switch-input:checked + .switch-toggle-slider {
        background-color: #28a745;
    }

        .switch-input:checked + .switch-toggle-slider:before {
            transform: translateX(20px);
        }

    .is-invalid {
        border-color: #dc3545 !important;
        background-color: #fff5f5 !important;
    }

    .ordem-container {
        display: flex;
        align-items: center;
        gap: 5px;
    }
</style>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0"><i class="bx bxs-cog"></i> Configuração de Campos Personalizados</h5>
    </div>

    <div class="card-body">
        <form id="form-config-campos" onsubmit="salvarConfiguracao(event)">
            <ul class="nav nav-tabs" id="tabCampos" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="ativos-tab" data-bs-toggle="tab" data-bs-target="#ativos" type="button" role="tab">Campos Ativos</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="inativos-tab" data-bs-toggle="tab" data-bs-target="#inativos" type="button" role="tab">Campos Inativos</button>
                </li>
            </ul>

            <div class="tab-content mt-3">
                <div class="tab-pane fade show active" id="ativos" role="tabpanel">
                    <div id="campos-ativos"></div>
                    <button type="button" class="btn btn-secondary mt-3" onclick="adicionarCampo()">
                        <i class="bx bx-plus"></i> Adicionar campo
                    </button>
                </div>
                <div class="tab-pane fade" id="inativos" role="tabpanel">
                    <div id="campos-inativos"></div>
                </div>
            </div>

            <br />
            <button type="submit" class="btn btn-primary">
                <i class="bx bxs-save"></i> Salvar configuração
            </button>
        </form>
    </div>
</div>

<script>
    function salvarConfiguracao(event) {
        event.preventDefault();

        const camposAtivosContainer = document.getElementById("campos-ativos");
        const camposInativosContainer = document.getElementById("campos-inativos");

        const todosCampos = [...document.querySelectorAll(".campo-configurado-card")];

        let todosValidos = true;

        todosCampos.forEach(campo => {
            const nomeInput = campo.querySelector(".campo-nome");
            const maxInput = campo.querySelector(".campo-maximo");

            const nome = nomeInput.value.trim();
            const max = maxInput.value.trim();

            const campoEhValido = nome.length > 0 && max.length > 0 && !isNaN(parseInt(max));

            if (!campoEhValido) {
                nomeInput.classList.add("is-invalid");
                maxInput.classList.add("is-invalid");
                todosValidos = false;
            } else {
                nomeInput.classList.remove("is-invalid");
                maxInput.classList.remove("is-invalid");
            }
        });

        if (!todosValidos) {
            alert("⚠️ Preencha corretamente todos os campos antes de salvar.");
            return;
        }

        // Limpar os containers antes de mover os campos
        camposAtivosContainer.innerHTML = "";
        camposInativosContainer.innerHTML = "";

        todosCampos.forEach(campo => {
            const nomeInput = campo.querySelector(".campo-nome");
            const maxInput = campo.querySelector(".campo-maximo");
            const switchAtivo = campo.querySelector(".campo-ativo");
            const info = campo.querySelector(".campo-inativado-info");
            const ordem = campo.dataset.ordem;

            const nome = nomeInput.value.trim();
            const max = maxInput.value.trim();
            const ativo = switchAtivo.checked;

            if (!ativo && !info.innerText) {
                const data = new Date().toLocaleDateString("pt-BR");
                info.innerText = "Inativado em: " + data;
                info.style.display = "inline";
            } else if (ativo) {
                info.innerText = "";
                info.style.display = "none";
            }

            const novoCard = criarCardCampo(nome, max, ativo, info.innerText.replace("Inativado em: ", ""), ordem);
            if (ativo) {
                camposAtivosContainer.appendChild(novoCard);
            } else {
                camposInativosContainer.appendChild(novoCard);
            }
        });

        alert("✅ Configuração salva com sucesso!");
    }

    function criarCardCampo(nome = "", max = "", ativo = true, dataInativacao = null, ordem = null) {
        const card = document.createElement("div");
        card.className = "campo-configurado-card row align-items-center";
        card.dataset.ordem = ordem ?? document.querySelectorAll(".campo-configurado-card").length + 1;
        card.dataset.ativo = ativo;

        const botoesOrdem = ativo
            ? `<div class="ordem-container">
                    <label class="form-label">Ordem: <strong>${card.dataset.ordem}</strong></label>
                    <div class="d-flex flex-column">
                        <button class="btn btn-sm btn-light mb-1" type="button" title="Subir" onclick="moverCampo(this, -1)">🔼</button>
                        <button class="btn btn-sm btn-light" type="button" title="Descer" onclick="moverCampo(this, 1)">🔽</button>
                    </div>
               </div>`
            : `<label class="form-label text-muted">Ordem original: ${card.dataset.ordem}</label>`;

        card.innerHTML = `
            <div class="col-md-3">
                <label class="form-label">Nome do campo</label>
                <input type="text" class="form-control form-control-sm campo-nome" value="${nome}" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Máx. caracteres</label>
                <input type="number" class="form-control form-control-sm campo-maximo" value="${max}" min="1" />
            </div>
            <div class="col-md-2 text-center">
                <label class="form-label d-block">Ativo</label>
                <label class="switch">
                    <input type="checkbox" class="switch-input campo-ativo" ${ativo ? "checked" : ""} />
                    <span class="switch-toggle-slider"></span>
                </label>
            </div>
            <div class="col-md-3 d-flex align-items-end justify-content-between">
                ${botoesOrdem}
            </div>
            <div class="col-md-2 d-flex align-items-end justify-content-end">
                <button type="button" class="btn btn-sm btn-outline-danger" onclick="removerCampo(this)">
                    <i class="bx bx-trash"></i>
                </button>
            </div>
            <div class="col-md-12">
                <small class="text-muted campo-inativado-info" style="display: ${dataInativacao ? "inline" : "none"}">
                    Inativado em: ${dataInativacao || ""}
                </small>
            </div>
        `;
        return card;
    }

    function adicionarCampo(nome = "", max = "", ativo = true, dataInativacao = null, ordem = null) {
        const card = criarCardCampo(nome, max, ativo, dataInativacao, ordem);
        if (ativo) {
            document.getElementById("campos-ativos").appendChild(card);
        } else {
            document.getElementById("campos-inativos").appendChild(card);
        }
    }

    function removerCampo(botao) {
        const card = botao.closest(".campo-configurado-card");
        card.remove();
    }

    function moverCampo(botao, direcao) {
        const card = botao.closest(".campo-configurado-card");
        const container = card.parentNode;
        const campos = [...container.querySelectorAll(".campo-configurado-card")];
        const index = campos.indexOf(card);
        const novoIndex = index + direcao;

        if (novoIndex < 0 || novoIndex >= campos.length) return;

        const outroCard = campos[novoIndex];
        container.insertBefore(card, direcao === -1 ? outroCard : outroCard.nextSibling);

        atualizarOrdemCampos(container);
    }

    function atualizarOrdemCampos(container) {
        const cards = container.querySelectorAll(".campo-configurado-card");
        cards.forEach((card, i) => {
            card.dataset.ordem = i + 1;
            const label = card.querySelector(".ordem-container label.form-label");
            if (label) {
                label.innerHTML = `Ordem: <strong>${i + 1}</strong>`;
            }
        });
    }

    adicionarCampo("Descrição", "255", true);
</script>
