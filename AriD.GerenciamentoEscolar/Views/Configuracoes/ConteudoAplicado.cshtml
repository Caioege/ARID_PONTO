@{
    Layout = null;
}
<style>
    .campo-configurado-card {
        border: 1px solid #ccc;
        padding: 16px;
        border-radius: 8px;
        margin-bottom: 12px;
        background-color: #f9f9f9;
    }

        .campo-configurado-card .form-label {
            font-weight: 500;
        }

    .switch {
        position: relative;
        display: inline-block;
        width: 44px;
        height: 24px;
    }

    .switch-input {
        opacity: 0;
        width: 0;
        height: 0;
    }

    .switch-toggle-slider {
        position: absolute;
        cursor: pointer;
        background-color: #ccc;
        border-radius: 34px;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        transition: .4s;
    }

        .switch-toggle-slider:before {
            content: "";
            position: absolute;
            height: 18px;
            width: 18px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            border-radius: 50%;
            transition: .4s;
        }

    .switch-input:checked + .switch-toggle-slider {
        background-color: #28a745;
    }

        .switch-input:checked + .switch-toggle-slider:before {
            transform: translateX(20px);
        }
</style>

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bx bxs-cog"></i> Configuração de Campos Personalizados</h5>
    </div>

    <div class="card-body">
        <form id="form-config-campos">
            <div id="campos-configurados">
                <!-- Campo configurado padrão -->
                <div class="campo-configurado-card row align-items-center">
                    <div class="col-md-8">
                        <label class="form-label">Descrição</label>
                        <input type="text" name="CampoNome" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Máx. de caracteres</label>
                        <input type="number" name="CampoMaximo" class="form-control" placeholder="Max: 10.000" min="1" />
                    </div>
                    <div class="col-md-1">
                        <label class="form-label d-block">Ativo</label>
                        <label class="switch">
                            <input type="checkbox" name="CampoAtivo" class="switch-input" checked />
                            <span class="switch-toggle-slider"></span>
                        </label>
                    </div>
                    <div class="col-md-1">
                        <button type="button" class="btn btn-danger" onclick="removerCampo(this)">
                            <i class="bx bx-trash"></i>
                        </button>
                    </div>
                </div>
            </div>

            <button type="button" class="btn btn-secondary mb-3" onclick="adicionarCampo()">
                <i class="bx bx-plus"></i> Adicionar campo
            </button>

            <br />

            <button type="submit" class="btn btn-primary" onclick="salvarCampo()">
                <i class="bx bxs-save"></i> Salvar configuração
            </button>
        </form>
    </div>
</div>

<script>
    function adicionarCampo() {
        const container = document.getElementById("campos-configurados");
        const novoCampo = document.createElement("div");
        novoCampo.className = "campo-configurado-card row align-items-center";
        novoCampo.innerHTML = `
            <div class="col-md-8">
                <label class="form-label">Descrição</label>
                <input type="text" name="CampoNome" class="form-control"  />
            </div>
            <div class="col-md-2">
                <label class="form-label">Máx. de caracteres</label>
                <input type="number" name="CampoMaximo" class="form-control" placeholder="Max: 10.000" min="1" />
            </div>
            <div class="col-md-1 ">
                <label class="form-label d-block">Ativo</label>
                <label class="switch">
                    <input type="checkbox" name="CampoAtivo" class="switch-input" checked />
                    <span class="switch-toggle-slider"></span>
                </label>
            </div>
            <div class="col-md-1">
                <button type="button" class="btn btn-danger" onclick="removerCampo(this)">
                    <i class="bx bx-trash"></i>
                </button>
            </div>
        `;
        container.appendChild(novoCampo);
    }

    function removerCampo(botao) {
        const linha = botao.closest(".campo-configurado-card");
        linha.remove();
    }
</script>


