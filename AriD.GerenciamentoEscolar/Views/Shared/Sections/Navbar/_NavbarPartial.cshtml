@{
    var dadosDaSessao = this.Context.DadosDaSessao();
}

@if (ViewData["navbarFull"] != null)
{
    <div class="navbar-brand app-brand demo d-none d-xl-flex py-0 me-4">
      <div class="app-brand-link gap-2">
          <span class="app-brand-logo demo">
            @await Html.PartialAsync("../_Partials/_Macros")
          </span>
          <span class="app-brand-text demo menu-text fw-bold">@TempData.Peek("appName")</span>
      </div>
    </div>
}

@if (ViewData["navbarHideToggle"] == null)
{
  <div class="layout-menu-toggle navbar-nav align-items-xl-center me-4 me-xl-0 d-xl-none">
    <a class="nav-item nav-link px-0 me-xl-6" href="javascript:void(0)">
      <i class="bx bx-menu bx-md"></i>
    </a>
  </div>
}

<div class="navbar-nav-right d-flex align-items-center" id="navbar-collapse">
    <h6 style="margin-top: 15px;">@dadosDaSessao.RedeDeEnsinoNome</h6>
    <button type="button" class="btn btn-sm btn-primary ms-auto" onclick="confirmaSairSistema()">
        <i class='bx bxs-exit'></i> Sair
    </button>
</div>
