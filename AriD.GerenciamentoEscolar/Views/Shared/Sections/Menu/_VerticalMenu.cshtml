@using AriD.BibliotecaDeClasses.Enumeradores
@using AriD.BibliotecaDeClasses.Enumeradores.Permissao

@{
  TempData.Keep();
  string? currentPage = ViewContext.HttpContext.Request.Path;
}

@{
    var menuControlador = TempData[VariaveisDeMenu.MenuControlador] ?? string.Empty;
    var paginaAtual = TempData[VariaveisDeMenu.MenuPaginaAtual] ?? string.Empty;

    var dadosDaSessao = this.Context.DadosDaSessao();
    var listaDePermissao = dadosDaSessao.Permissoes;
    var usuarioAdm = dadosDaSessao.UsuarioAdministradorAutenticado;
}

<aside id="layout-menu" class="layout-menu menu-vertical menu bg-menu-theme">
  <div
    class='app-brand demo @((@ViewData["navbarFull"] != null && Convert.ToBoolean(@ViewData["navbarFull"])) ? "d-xl-none" : "")'>
    <div class="app-brand-link">
      <span class="app-brand-logo demo">
        @await Html.PartialAsync("../_Partials/_Macros")
      </span>
      <span class="app-brand-text demo menu-text fw-bold ms-2">@TempData.Peek("appName")</span>
    </div>

    <a href="javascript:void(0);" class="layout-menu-toggle menu-link text- large ms-auto d-block d-xl-none">
      <i class="bx bx-chevron-left bx-sm d-flex align-items-center justify-content-center"></i>
    </a>
  </div>

  <div class="menu-inner-shadow"></div>

<ul class="menu-inner py-1">
        @if (dadosDaSessao.Perfil != ePerfilDeAcesso.AdministradorDeSistema && listaDePermissao.PossuiPermissao(eItemDePermissao_Dashboard.Visualizar, usuarioAdm))
     {
         <li class='menu-item'>
            <a onclick="CarregarPagina('@Url.Action("Index", "Dashboard")')" href="javascript:void(0)" class="menu-link">
                <div>
                    <i class='bx bxs-dashboard'></i>
                    Dashboard
                </div>
            </a>
        </li>
     }
     <li class='menu-item open'>
        <div class="divider" style="margin: 0px 15px 0px 15px;">
            <div class="divider-text">
                <i class="bx bx-slider-alt"></i>
                Administraçăo
            </div>
        </div>
      <ul class="menu-sub">
          @if (dadosDaSessao.Perfil == ePerfilDeAcesso.AdministradorDeSistema) 
          {
              <li class='menu-item'>
                  <a onclick="CarregarPagina('@Url.Action("Index", "RedeDeEnsino")')" href="javascript:void(0)" class="menu-link">
                    <div>
                        <i class='bx bxs-school'></i>
                        Rede de Ensino
                    </div>
                  </a>
              </li>
          }
          else 
          {
              if (listaDePermissao.PossuiPermissao(eItemDePermissao_EquipamentoDeFrequencia.Visualizar, usuarioAdm))
              {
                    <li class='menu-item'>
                      <a onclick="CarregarPagina('@Url.Action("Index", "EquipamentoDeFrequencia")')" href="javascript:void(0)" class="menu-link">
                        <div>
                            <i class='bx bx-mobile-alt'></i>
                            Equipamentos
                        </div>
                      </a>
                    </li>
              }
                    @if (dadosDaSessao.Perfil == ePerfilDeAcesso.RedeDeEnsino && listaDePermissao.PossuiPermissao(eItemDePermissao_RedeDeEnsino.Visualizar, usuarioAdm))
                {
                    <li class='menu-item'>
                        <a onclick="CarregarPagina('@Url.Action("Alterar", "RedeDeEnsino", new { id = dadosDaSessao.RedeDeEnsinoId })')" href="javascript:void(0)" class="menu-link">
                        <div>
                            <i class='bx bxs-school'></i>
                            Minha Rede de Ensino
                        </div>
                        </a>
                    </li>
                }
                    else if (dadosDaSessao.Perfil == ePerfilDeAcesso.Escola && listaDePermissao.PossuiPermissao(eItemDePermissao_MinhaEscola.Visualizar, usuarioAdm))
                {
                    <li class='menu-item'>
                        <a onclick="CarregarPagina('@Url.Action("Alterar", "Escola", new { id = dadosDaSessao.EscolaId })')" href="javascript:void(0)" class="menu-link">
                        <div>
                            <i class='bx bxs-school'></i>
                            Minha Escola
                        </div>
                        </a>
                    </li>
                }
          }
      </ul>
    </li>
    @if (dadosDaSessao.Perfil != ePerfilDeAcesso.AdministradorDeSistema) 
    {
        <li class='menu-item open'>
            <div class="divider" style="margin: 0px 15px 0px 15px;">
                <div class="divider-text">
                    <i class='bx bxs-institution'></i>
                    Escola
                </div>
            </div>
            <ul class="menu-sub">
                @if (listaDePermissao.PossuiPermissao(eItemDePermissao_Turma.Visualizar, usuarioAdm))
                {
                    <li class='menu-item'>
                        <a onclick="CarregarPagina('@Url.Action("Index", "Turma")')" href="javascript:void(0)" class="menu-link">
                            <div>
                                <i class='bx bxs-notepad' ></i>
                                Turmas
                            </div>
                        </a>
                    </li>
                }
                @if (listaDePermissao.PossuiPermissao(eItemDePermissao_Aluno.Visualizar, usuarioAdm))
                {
                        <li class='menu-item'>
                            <a onclick="CarregarPagina('@Url.Action("Index", "Aluno")')" href="javascript:void(0)" class="menu-link">
                                <div>
                                    <i class='bx bxs-user-detail'></i>
                                    Alunos
                                </div>
                            </a>
                        </li>
                }
                @if (listaDePermissao.PossuiPermissao(eItemDePermissao_RegistrosDePonto.Visualizar, usuarioAdm))
                {
                        <li class='menu-item'>
                            <a onclick="CarregarPagina('@Url.Action("Index", "RegistroDePonto")')" href="javascript:void(0)" class="menu-link">
                                <div>
                                    <i class='bx bx-collection'></i>
                                    Registros de Frequęncia
                                </div>
                            </a>
                        </li>
                }
            </ul>
        </li>
        <li class='menu-item open'>
            <div class="divider" style="margin: 0px 15px 0px 15px;">
                <div class="divider-text">
                    <i class='bx bxs-report'></i>
                    Relatórios
                </div>
            </div>
            <ul class="menu-sub">
                @if (listaDePermissao.PossuiPermissao(eItemDePermissao_RelatorioAlunosDaEscola.Visualizar, usuarioAdm))
                {
                        <li class='menu-item'>
                            <a onclick="CarregarPagina('@Url.Action("AlunosDaEscola", "Relatorio")')" href="javascript:void(0)" class="menu-link">
                                <div style="white-space: normal !important;">
                                    <i class='bx bx-list-ul'></i>
                                    Alunos da Escola
                                </div>
                            </a>
                        </li>
                }
                
                @if (listaDePermissao.PossuiPermissao(eItemDePermissao_RelatorioFrequenciasNaData.Visualizar, usuarioAdm))
                {
                        <li class='menu-item'>
                            <a onclick="CarregarPagina('@Url.Action("FrequenciasNaData", "Relatorio")')" href="javascript:void(0)" class="menu-link">
                                <div style="white-space: normal !important;">
                                    <i class='bx bxs-calendar-event'></i>
                                    Frequęncias na Data
                                </div>
                            </a>
                        </li>
                }

                @if (listaDePermissao.PossuiPermissao(eItemDePermissao_RelatorioEquipamentosDaEscola.Visualizar, usuarioAdm))
                {
                        <li class='menu-item'>
                            <a onclick="CarregarPagina('@Url.Action("EquipamentosDaEscola", "Relatorio")')" href="javascript:void(0)" class="menu-link">
                                <div style="white-space: normal !important;">
                                    <i class='bx bx-align-justify'></i>
                                    Equipamentos da Escola
                                </div>
                            </a>
                        </li>
                }
            </ul>
        </li>
    }
    <li class='menu-item open'>
        <div class="divider" style="margin: 0px 15px 0px 15px;">
            <div class="divider-text">
                <i class='bx bxs-user-badge'></i>
                Usuários
            </div>
        </div>
        <ul class="menu-sub">
            @if (listaDePermissao.PossuiPermissao(eItemDePermissao_Usuarios.Visualizar, usuarioAdm))
            {
                    <li class='menu-item'>
                        <a onclick="CarregarPagina('@Url.Action("Index", "Usuario")')" href="javascript:void(0)" class="menu-link">
                            <div style="white-space: normal !important;">
                                <i class='bx bxs-user-account'></i>
                                Cadastro de Usuários
                            </div>
                        </a>
                    </li>
            }
            
            @if (dadosDaSessao.Perfil != ePerfilDeAcesso.AdministradorDeSistema && listaDePermissao.PossuiPermissao(eItemDePermissao_GrupoDePermissao.Visualizar, usuarioAdm))
            {
                    <li class='menu-item'>
                        <a onclick="CarregarPagina('@Url.Action("Index", "GrupoDePermissao")')" href="javascript:void(0)" class="menu-link">
                            <div style="white-space: normal !important;">
                                <i class='bx bxs-user-check'></i>
                                Grupo de Permissăo
                            </div>
                        </a>
                    </li>
            }
        </ul>
    </li>
  </ul>
</aside>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll('.menu-item.open').forEach(function (menu) {
            if (menu.querySelectorAll('li').length === 0) {
                menu.remove();
            }
        });
    });
</script>